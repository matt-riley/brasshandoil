---
import { getCollection } from "astro:content";
import Base from "@layouts/Base.astro";

const blogPosts = await getCollection("blog");
console.log(blogPosts);
---
<Base>
<ul>
  {blogPosts.map((post) => (
<li>
      <a href={`/blog/${post.slug}`}>{post.data.title}</a>
  </li>
  ) )} 
</ul>
</Base>
