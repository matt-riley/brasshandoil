---
import Base from "@layouts/Base.astro"
---

<Base title="Mnemonic Scent Customs">
  <main id="mnemonic-scent-customs" class="msc-shell" data-cleared="0">
    <section class="msc-heading" aria-labelledby="msc-title">
      <p>counter 9 / olfactory import desk</p>
      <h1 id="msc-title">Mnemonic Scent Customs</h1>
    </section>

    <section class="msc-workbench" aria-label="Mnemonic scent customs workbench">
      <div id="scent-stage" class="scent-stage" aria-label="chromatograph curtain and scent vials">
        <div class="stage-label">
          <span>chromatograph curtain</span>
          <strong id="tariff-reading">tariff 17%</strong>
        </div>

        <div id="chromatograph-curtain" class="chromatograph-curtain" aria-hidden="true">
          <i></i><i></i><i></i><i></i><i></i><i></i>
        </div>

        <svg class="customs-lines" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
          <path d="M20 78 C37 45 48 65 62 31 S83 42 91 14"></path>
          <path d="M10 18 C30 36 50 8 69 28 S86 67 95 55"></path>
        </svg>

        <button class="scent-vial selected" type="button" data-note="cedar invoice" data-index="0" style="--x: 15%; --y: 62%; --hue: #42c7bd" aria-pressed="true">
          <span>cedar invoice</span>
        </button>
        <button class="scent-vial" type="button" data-note="rain receipt" data-index="1" style="--x: 37%; --y: 28%; --hue: #7f8cff" aria-pressed="false">
          <span>rain receipt</span>
        </button>
        <button class="scent-vial" type="button" data-note="ozone ribbon" data-index="2" style="--x: 58%; --y: 68%; --hue: #b266ff" aria-pressed="false">
          <span>ozone ribbon</span>
        </button>
        <button class="scent-vial" type="button" data-note="paper static" data-index="3" style="--x: 72%; --y: 38%; --hue: #f0ca76" aria-pressed="false">
          <span>paper static</span>
        </button>
        <button class="scent-vial" type="button" data-note="citrus static" data-index="4" style="--x: 84%; --y: 76%; --hue: #e96f4d" aria-pressed="false">
          <span>citrus static</span>
        </button>
      </div>

      <aside class="customs-rail" aria-label="scent customs controls">
        <div class="readout-grid" aria-live="polite">
          <div>
            <span>cleared</span>
            <strong id="cleared-count">0</strong>
          </div>
          <div>
            <span>active vial</span>
            <strong id="active-vial">cedar invoice</strong>
          </div>
          <div class="wide">
            <span>current note</span>
            <strong id="current-note">cedar invoice held for cabinet memory</strong>
          </div>
        </div>

        <form id="memory-gates" class="memory-gates" aria-label="memory gate controls">
          <label>
            <span>attic gate</span>
            <input type="range" min="0" max="100" value="31" data-gate="attic" />
          </label>
          <label>
            <span>station gate</span>
            <input type="range" min="0" max="100" value="58" data-gate="station" />
          </label>
          <label>
            <span>summer gate</span>
            <input type="range" min="0" max="100" value="72" data-gate="summer" />
          </label>
        </form>

        <div class="rail-actions">
          <button id="stamp-selected-scent" type="button">stamp selected scent</button>
          <button id="clear-ledger" type="button">clear ledger</button>
        </div>

        <div class="ledger-wrap">
          <div class="ledger-title">
            <span>stamp ledger</span>
            <b>olfactory customs</b>
          </div>
          <div id="scent-ledger" class="scent-ledger" aria-live="polite">
            <p>No scent has cleared customs.</p>
          </div>
        </div>
      </aside>
    </section>
  </main>
</Base>

<style>
  :global(body) {
    margin: 0;
    background: #0c0d10;
  }

  :global(.container) {
    max-inline-size: none;
    padding-inline: 0;
  }

  .msc-shell {
    --ink: #0c0d10;
    --panel: rgba(21, 26, 30, 0.82);
    --line: rgba(225, 214, 189, 0.25);
    --paper: #eee3c7;
    --paper-dim: rgba(238, 227, 199, 0.72);
    --teal: #4bd4c2;
    --amber: #f1bd65;
    --purple: #9b68d7;
    --stamp: #e45642;
    min-height: calc(100vh - 6rem);
    overflow-x: hidden;
    padding: clamp(1rem, 2.2vw, 1.8rem);
    color: var(--paper);
    background:
      linear-gradient(105deg, rgba(75, 212, 194, 0.16), transparent 24rem),
      linear-gradient(290deg, rgba(155, 104, 215, 0.18), transparent 28rem),
      linear-gradient(180deg, #161719 0%, #0c0d10 56%, #08090b 100%);
    font-family: Inter, ui-sans-serif, system-ui, sans-serif;
  }

  .msc-heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: end;
    max-width: 1180px;
    margin: 0 auto clamp(1rem, 2vw, 1.45rem);
  }

  .msc-heading p,
  .stage-label,
  .readout-grid span,
  .memory-gates span,
  .ledger-title span {
    color: var(--amber);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.72rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .msc-heading h1 {
    max-width: 11ch;
    margin: 0;
    color: var(--paper);
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(3.1rem, 8vw, 7.2rem);
    font-weight: 900;
    letter-spacing: 0;
    line-height: 0.86;
    text-shadow:
      0.035em 0.035em 0 rgba(228, 86, 66, 0.58),
      -0.025em 0.04em 0 rgba(75, 212, 194, 0.36);
  }

  .msc-workbench {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 23rem);
    gap: clamp(1rem, 2vw, 1.4rem);
    max-width: 1180px;
    margin: 0 auto;
    align-items: stretch;
  }

  .scent-stage,
  .customs-rail {
    position: relative;
    min-width: 0;
    border: 1px solid var(--line);
    border-radius: 6px;
    background:
      linear-gradient(180deg, rgba(238, 227, 199, 0.07), transparent 20%),
      rgba(10, 12, 14, 0.74);
    box-shadow: 0 1.4rem 4rem rgba(0, 0, 0, 0.36);
  }

  .scent-stage {
    min-height: min(65vh, 42rem);
    overflow: hidden;
    isolation: isolate;
  }

  .stage-label {
    position: absolute;
    inset: 1rem 1rem auto;
    z-index: 6;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    color: var(--paper-dim);
  }

  .stage-label strong {
    color: var(--teal);
    font-weight: 800;
  }

  .chromatograph-curtain {
    position: absolute;
    inset: 3.7rem 8% 2.2rem;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0.36rem;
    padding-inline: 0.3rem;
    border-inline: 1px solid rgba(238, 227, 199, 0.16);
    filter: saturate(1.16);
    opacity: 0.88;
  }

  .chromatograph-curtain i {
    display: block;
    min-width: 0;
    border-radius: 3px;
    background:
      linear-gradient(180deg, transparent 0%, rgba(255, 255, 255, 0.28) 12%, transparent 18%),
      linear-gradient(180deg, var(--band), transparent 74%);
    box-shadow: inset 0 0 1.5rem rgba(255, 255, 255, 0.12);
    animation: scentBand 4.8s ease-in-out infinite alternate;
  }

  .chromatograph-curtain i:nth-child(1) { --band: rgba(75, 212, 194, 0.72); animation-delay: -1.2s; }
  .chromatograph-curtain i:nth-child(2) { --band: rgba(241, 189, 101, 0.68); animation-delay: -2.4s; }
  .chromatograph-curtain i:nth-child(3) { --band: rgba(155, 104, 215, 0.7); animation-delay: -0.8s; }
  .chromatograph-curtain i:nth-child(4) { --band: rgba(228, 86, 66, 0.55); animation-delay: -3s; }
  .chromatograph-curtain i:nth-child(5) { --band: rgba(126, 142, 255, 0.62); animation-delay: -1.8s; }
  .chromatograph-curtain i:nth-child(6) { --band: rgba(238, 227, 199, 0.5); animation-delay: -2.8s; }

  .customs-lines {
    position: absolute;
    inset: 0;
    z-index: 2;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .customs-lines path {
    fill: none;
    stroke: rgba(238, 227, 199, 0.2);
    stroke-width: 0.25;
    stroke-dasharray: 2 3;
  }

  .scent-vial {
    position: absolute;
    z-index: 5;
    left: var(--x);
    top: var(--y);
    width: clamp(5.7rem, 10vw, 8rem);
    min-height: 2.55rem;
    transform: translate(-50%, -50%) rotate(var(--tilt, -6deg));
    border: 1px solid color-mix(in srgb, var(--hue), white 20%);
    border-radius: 999px 999px 8px 8px;
    color: var(--paper);
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.34), transparent 20% 78%, rgba(255, 255, 255, 0.18)),
      linear-gradient(180deg, color-mix(in srgb, var(--hue), transparent 34%), rgba(255, 255, 255, 0.06));
    box-shadow:
      0 0 1.5rem color-mix(in srgb, var(--hue), transparent 58%),
      inset 0 0.5rem 1rem rgba(255, 255, 255, 0.08);
    cursor: pointer;
    transition: transform 150ms ease, box-shadow 150ms ease, border-color 150ms ease;
  }

  .scent-vial span {
    display: block;
    padding: 0.55rem 0.75rem;
    overflow-wrap: anywhere;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: clamp(0.66rem, 1.2vw, 0.78rem);
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .scent-vial::before {
    content: "";
    position: absolute;
    inset: -0.62rem;
    border: 1px solid transparent;
    border-radius: 999px;
    pointer-events: none;
  }

  .scent-vial:hover,
  .scent-vial:focus-visible,
  .scent-vial.selected {
    transform: translate(-50%, -50%) rotate(0deg) scale(1.06);
    border-color: var(--paper);
    outline: none;
  }

  .scent-vial:hover::before,
  .scent-vial:focus-visible::before,
  .scent-vial.selected::before {
    border-color: color-mix(in srgb, var(--hue), white 28%);
  }

  .customs-rail {
    display: grid;
    grid-template-rows: auto auto auto minmax(10rem, 1fr);
    gap: 0.9rem;
    padding: 0.95rem;
  }

  .readout-grid {
    display: grid;
    grid-template-columns: 0.72fr 1.28fr;
    gap: 0.65rem;
  }

  .readout-grid div,
  .memory-gates,
  .ledger-wrap {
    min-width: 0;
    border: 1px solid rgba(238, 227, 199, 0.18);
    border-radius: 6px;
    background: rgba(238, 227, 199, 0.055);
  }

  .readout-grid div {
    padding: 0.72rem;
  }

  .readout-grid .wide {
    grid-column: 1 / -1;
  }

  .readout-grid strong {
    display: block;
    margin-top: 0.4rem;
    color: var(--paper);
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1rem, 2.1vw, 1.34rem);
    line-height: 1.1;
    overflow-wrap: anywhere;
  }

  .memory-gates {
    display: grid;
    gap: 0.72rem;
    padding: 0.82rem;
  }

  .memory-gates label {
    display: grid;
    gap: 0.36rem;
  }

  .memory-gates input {
    width: 100%;
    accent-color: var(--teal);
  }

  .rail-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.62rem;
  }

  .rail-actions button {
    min-height: 3rem;
    border: 1px solid rgba(238, 227, 199, 0.24);
    border-radius: 6px;
    padding: 0.65rem;
    color: var(--ink);
    background: var(--amber);
    font: 850 0.72rem/1.18 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .rail-actions button:last-child {
    color: var(--paper);
    background: transparent;
  }

  .rail-actions button:hover,
  .rail-actions button:focus-visible {
    filter: brightness(1.08);
    outline: 2px solid rgba(75, 212, 194, 0.42);
    outline-offset: 2px;
  }

  .ledger-wrap {
    display: grid;
    grid-template-rows: auto 1fr;
    overflow: hidden;
  }

  .ledger-title {
    display: flex;
    justify-content: space-between;
    gap: 0.6rem;
    padding: 0.75rem;
    border-bottom: 1px solid rgba(238, 227, 199, 0.16);
  }

  .ledger-title b {
    color: var(--stamp);
    font: 800 0.72rem/1 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .scent-ledger {
    display: grid;
    align-content: start;
    gap: 0.55rem;
    min-height: 8rem;
    padding: 0.75rem;
    overflow: auto;
  }

  .scent-ledger p {
    margin: 0;
    color: var(--paper-dim);
    font-size: 0.9rem;
  }

  .ledger-slip {
    position: relative;
    min-height: 3.3rem;
    border: 1px solid rgba(91, 60, 34, 0.22);
    border-radius: 3px;
    padding: 0.65rem 4.3rem 0.65rem 0.7rem;
    color: #201915;
    background: #efe2c1;
    box-shadow: 0 0.55rem 1.4rem rgba(0, 0, 0, 0.18);
  }

  .ledger-slip b {
    display: block;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1rem;
    line-height: 1.05;
  }

  .ledger-slip span {
    color: #6b5144;
    font: 700 0.65rem/1.4 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .ledger-slip::after {
    content: "CLEARED";
    position: absolute;
    right: 0.52rem;
    top: 0.72rem;
    transform: rotate(-9deg);
    border: 2px solid var(--stamp);
    border-radius: 3px;
    padding: 0.2rem 0.34rem;
    color: var(--stamp);
    font: 900 0.62rem/1 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    letter-spacing: 0.08em;
  }

  @keyframes scentBand {
    from { transform: translateY(-1.2%); opacity: 0.52; }
    to { transform: translateY(2.6%); opacity: 0.94; }
  }

  @media (prefers-reduced-motion: reduce) {
    .chromatograph-curtain i {
      animation: none;
    }
  }

  @media (max-width: 820px) {
    .msc-heading,
    .msc-workbench {
      grid-template-columns: 1fr;
    }

    .msc-heading {
      align-items: start;
    }

    .scent-stage {
      min-height: 30rem;
    }

    .customs-rail {
      grid-template-rows: auto;
    }
  }

  @media (max-width: 520px) {
    .msc-shell {
      padding: 0.75rem;
    }

    .msc-heading h1 {
      font-size: clamp(2.65rem, 17vw, 4.4rem);
    }

    .scent-stage {
      min-height: 27rem;
    }

    .stage-label,
    .rail-actions,
    .readout-grid {
      grid-template-columns: 1fr;
    }

    .stage-label {
      display: grid;
    }

    .chromatograph-curtain {
      inset-inline: 5%;
    }

    .scent-vial {
      width: clamp(5.2rem, 28vw, 6.6rem);
    }
  }
</style>

<script>
  type CustomsWindow = Window & {
    __stampScentForTest?: (note?: string) => void
  }

  ;(() => {
    const root = document.getElementById("mnemonic-scent-customs")
    const stage = document.getElementById("scent-stage")
    const ledger = document.getElementById("scent-ledger")
    const clearedCount = document.getElementById("cleared-count")
    const activeVial = document.getElementById("active-vial")
    const currentNote = document.getElementById("current-note")
    const tariffReading = document.getElementById("tariff-reading")
    const stampButton = document.getElementById("stamp-selected-scent")
    const clearButton = document.getElementById("clear-ledger")
    const vials = Array.from(document.querySelectorAll<HTMLButtonElement>(".scent-vial"))
    const gates = Array.from(document.querySelectorAll<HTMLInputElement>("#memory-gates input"))

    if (
      !(root instanceof HTMLElement) ||
      !(stage instanceof HTMLElement) ||
      !(ledger instanceof HTMLElement) ||
      !(clearedCount instanceof HTMLElement) ||
      !(activeVial instanceof HTMLElement) ||
      !(currentNote instanceof HTMLElement) ||
      !(tariffReading instanceof HTMLElement) ||
      !(stampButton instanceof HTMLButtonElement) ||
      !(clearButton instanceof HTMLButtonElement) ||
      vials.length === 0
    ) {
      return
    }

    const rootEl: HTMLElement = root
    const stageEl: HTMLElement = stage
    const ledgerEl: HTMLElement = ledger
    const clearedCountEl: HTMLElement = clearedCount
    const activeVialEl: HTMLElement = activeVial
    const currentNoteEl: HTMLElement = currentNote
    const tariffReadingEl: HTMLElement = tariffReading

    let selectedIndex = 0
    let cleared = 0
    let pointerBias = { x: 0, y: 0 }

    const getNote = (button: HTMLButtonElement) => button.dataset.note ?? "unlabeled vapor"

    const calculateTariff = () => {
      const gateTotal = gates.reduce((sum, gate) => sum + Number(gate.value), 0)
      const selectedWeight = selectedIndex * 7
      return Math.round(((gateTotal / Math.max(gates.length, 1)) + selectedWeight) % 89) + 5
    }

    function updateReadouts() {
      const selected = vials[selectedIndex]
      const note = getNote(selected)
      const tariff = calculateTariff()
      rootEl.dataset.cleared = String(cleared)
      clearedCountEl.textContent = String(cleared)
      activeVialEl.textContent = note
      currentNoteEl.textContent = `${note} held for ${tariff < 42 ? "cabinet" : "platform"} memory`
      tariffReadingEl.textContent = `tariff ${tariff}%`
      vials.forEach((vial, index) => {
        const isSelected = index === selectedIndex
        vial.classList.toggle("selected", isSelected)
        vial.setAttribute("aria-pressed", String(isSelected))
        vial.tabIndex = isSelected ? 0 : -1
      })
    }

    function selectVial(index: number) {
      selectedIndex = (index + vials.length) % vials.length
      updateReadouts()
    }

    function stampSelectedScent(noteOverride?: string) {
      const note = noteOverride ?? getNote(vials[selectedIndex])
      const tariff = calculateTariff()
      if (cleared === 0) {
        ledgerEl.replaceChildren()
      }

      const slip = document.createElement("article")
      slip.className = "ledger-slip"
      const title = document.createElement("b")
      title.textContent = note
      const detail = document.createElement("span")
      detail.textContent = `tariff ${tariff}% / lane ${cleared + 1}`
      slip.append(title, detail)
      ledgerEl.prepend(slip)

      cleared += 1
      updateReadouts()
    }

    function clearLedger() {
      cleared = 0
      ledgerEl.replaceChildren()
      const empty = document.createElement("p")
      empty.textContent = "No scent has cleared customs."
      ledgerEl.append(empty)
      updateReadouts()
    }

    vials.forEach((vial, index) => {
      vial.addEventListener("click", () => selectVial(index))
      vial.addEventListener("keydown", (event) => {
        if (event.key === "ArrowRight" || event.key === "ArrowDown") {
          event.preventDefault()
          selectVial(index + 1)
          vials[selectedIndex]?.focus()
        }
        if (event.key === "ArrowLeft" || event.key === "ArrowUp") {
          event.preventDefault()
          selectVial(index - 1)
          vials[selectedIndex]?.focus()
        }
        if (event.key === "Enter") {
          event.preventDefault()
          selectVial(index)
        }
        if (event.key === " ") {
          event.preventDefault()
          selectVial(index)
          stampSelectedScent()
        }
      })
    })

    gates.forEach((gate) => {
      gate.addEventListener("input", updateReadouts)
    })

    stampButton.addEventListener("click", () => stampSelectedScent())
    clearButton.addEventListener("click", clearLedger)

    const applyPointerBias = (clientX: number, clientY: number) => {
      const box = stageEl.getBoundingClientRect()
      pointerBias = {
        x: ((clientX - box.left) / Math.max(box.width, 1) - 0.5) * 10,
        y: ((clientY - box.top) / Math.max(box.height, 1) - 0.5) * 8,
      }
    }

    stageEl.addEventListener("pointermove", (event) => {
      applyPointerBias(event.clientX, event.clientY)
    })

    stageEl.addEventListener(
      "touchstart",
      (event) => {
        const touch = event.touches[0]
        if (touch) {
          applyPointerBias(touch.clientX, touch.clientY)
        }
      },
      { passive: true },
    )

    let tick = 0
    const drift = () => {
      tick += 0.014
      vials.forEach((vial, index) => {
        const bob = Math.sin(tick + index * 1.4) * 4
        const sway = Math.cos(tick * 0.7 + index) * 2
        vial.style.setProperty("--tilt", `${Math.sin(tick + index) * 8}deg`)
        vial.style.translate = `${sway + pointerBias.x * 0.08}px ${bob + pointerBias.y * 0.08}px`
      })
      requestAnimationFrame(drift)
    }

    ;(window as CustomsWindow).__stampScentForTest = (note?: string) => {
      stampSelectedScent(note)
    }

    updateReadouts()
    if (!navigator.webdriver && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      requestAnimationFrame(drift)
    }
  })()
</script>
