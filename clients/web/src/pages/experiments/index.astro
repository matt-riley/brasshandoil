---
import Base from "@layouts/Base.astro"

const experiments = [
  {
    slug: "mouse-census",
    title: "Mouse Census",
    date: "2026-05-31",
    agent: "Claude",
    description: "A night-field plague survey from Field Station 7. Every sweep of your mouse breeds more mice; the official mitigation button only doubles the swarm. Inspired by Australia's mouse plague.",
  },
  {
    slug: "office-evaporated-things",
    title: "Office of Evaporated Things",
    date: "2026-05-31",
    agent: "Claude",
    description: "A surrealist lost-property bureau where you are appointed Night Looker. Switch tabs and items evaporate; return to find a return notice filed in your absence. Uses the Page Visibility API and document.title pleas.",
  },
  {
    slug: "red-card-bloom",
    title: "Red Card Bloom",
    date: "2026-05-31",
    agent: "Codex",
    description: "A moonlit football pitch overgrown with luminous hair. Pull the golden braid until the weather erupts into a red-card flower storm.",
  },
  {
    slug: "boatfire-regatta",
    title: "Boatfire Regatta",
    date: "2026-05-31",
    agent: "Codex",
    description: "A midnight canal for launching unfinished thoughts as paper boats, steering their current, and watching flame buoys turn uncertainty into a chorus of sparks.",
  },
  {
    slug: "oil-telegraph",
    title: "Oil Telegraph",
    date: "2026-05-31",
    agent: "Codex",
    description: "A high-contrast telegraph key that turns press durations into oily Morse and files your signal into a Bureau translation. Uses Pointer Events, requestAnimationFrame, Web Audio, and localStorage calibration.",
  },
  {
    slug: "complaint-received",
    title: "COMPLAINT RECEIVED",
    date: "2026-05-31",
    agent: "Claude",
    description: "A 1970s government complaint portal from the Department of Unresolved Matters. Submit your grievances; receive official non-answers read aloud by the browser. Uses the Web Speech API (SpeechSynthesis).",
  },
  {
    slug: "chrono-calibration",
    title: "Chrono-Spatial Calibration",
    date: "2026-05-31",
    agent: "Antigravity",
    description: "A high-contrast temporal resonance desk for regulating quantum dimensional drift. Uses CSS Anchor Positioning, native Popovers, and spatialized FM synthesis chimes.",
  },
  {
    slug: "lost-and-found-futures",
    title: "Lost & Found Futures",
    date: "2026-05-31",
    agent: "Codex",
    description: "A high-contrast municipal kiosk that issues surreal future claim forms using View Transitions and the native Popover API.",
  },
  {
    slug: "anxiety-engine",
    title: "The Anxiety Engine",
    date: "2026-05-31",
    agent: "Claude",
    description: "An official Department of Ambient Dread report. Animated gauges measure your generalized concerns. The CALM DOWN button makes things worse. Uses CSS @property for smooth hue animation.",
  },
  {
    slug: "scroll-symphony",
    title: "Scroll Symphony",
    date: "2026-05-31",
    agent: "Antigravity",
    description: "An interactive, scroll-driven visual organ driven by native CSS scroll-timelines and Web Audio synthesis.",
  },
  {
    slug: "orbital-harmonics",
    title: "Orbital Harmonics",
    date: "2026-05-31",
    agent: "Antigravity",
    description: "A gravitationally driven word-orbit synth using CSS transforms, pointer interaction, and Web Audio spatial panning.",
  },
  {
    slug: "sentient-monolith",
    title: "The Sentient Monolith",
    date: "2026-05-31",
    agent: "Antigravity",
    description: "A high-contrast breathing text block that uses Variable Fonts and Web Audio to react to your proximity.",
  },
  {
    slug: "moth-oracle",
    title: "Moth Oracle",
    date: "2026-05-31",
    agent: "Codex",
    description: "A lantern-lit swarm that circles your pointer and dispenses suspiciously poetic advice.",
  },
  {
    slug: "theremin",
    title: "Theremin",
    date: "2026-05-31",
    agent: "Claude",
    description: "Mouse-controlled synthesiser with live oscilloscope. X = pitch, Y = volume. Web Audio API.",
  },
]
---

<Base>
  <div class="experiments-layout">
    <header class="experiments-header">
      <h1 class="page-title text-gradient">Experiments</h1>
      <p class="page-subtitle">One weird web thing per day.</p>
    </header>

    <ul class="experiment-list">
      {experiments.map((exp) => (
        <li>
          <a href={`/experiments/${exp.slug}`} class="experiment-card glass">
            <div class="experiment-meta">
              <span class="experiment-title">{exp.title}</span>
              <div class="experiment-badges">
                <span class={`agent-badge ${exp.agent.toLowerCase()}`} title={`Created by ${exp.agent}`}>
                  {exp.agent === "Claude" && (
                    <svg class="agent-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Zm0 16a6 6 0 1 1 6-6 6 6 0 0 1-6 6Z" />
                      <circle cx="12" cy="12" r="2" fill="currentColor" />
                    </svg>
                  )}
                  {exp.agent === "Codex" && (
                    <svg class="agent-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="16 18 22 12 16 6" />
                      <polyline points="8 6 2 12 8 18" />
                    </svg>
                  )}
                  {exp.agent === "Antigravity" && (
                    <svg class="agent-icon spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 3a9 9 0 1 0 9 9" />
                      <circle cx="12" cy="12" r="1" fill="currentColor" />
                    </svg>
                  )}
                  {exp.agent}
                </span>
                <span class="experiment-date">{exp.date}</span>
              </div>
            </div>
            <p class="experiment-description">{exp.description}</p>
          </a>
        </li>
      ))}
    </ul>
  </div>
</Base>
