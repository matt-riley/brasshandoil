---
import Base from "@layouts/Base.astro"
---

<Base title="Arctic Dropstone Deposition Desk // Benthic Accretion Registry">
  <div class="desk-container" id="dropstone-root" data-biodiversity="0" data-active-stones="0" data-temperature="2.0" data-bays-completed="0" data-current-speed="0">
    <!-- CRT Screen Overlay for Immersive Depth UI -->
    <div class="crt-overlay" aria-hidden="true"></div>
    <div class="crt-flicker" aria-hidden="true"></div>
    
    <!-- Background slow drifting particles -->
    <canvas id="ambient-ocean-canvas" class="background-canvas" aria-hidden="true"></canvas>

    <!-- Header Section -->
    <header class="desk-header">
      <h1 class="page-title text-gradient">Arctic Dropstone Deposition Desk</h1>
      <p class="subtitle font-mono">BENTHIC ACCRETION REGISTRY // SEAFLOOR ECOSYSTEM OFFICE</p>
    </header>

    <!-- Arming Overlay for synthesizer system activation -->
    <div id="arming-overlay" class="overlay glass">
      <div class="overlay-content">
        <div class="overlay-icon">🧊</div>
        <h2 class="overlay-title font-mono">BENTHIC LEDGER & HYDROPHONES INITIALIZATION</h2>
        <p class="overlay-desc">
          Melting Arctic icebergs deposit mineral debris (dropstones) onto the barren ocean floor, seeding vibrant micro-habitats of soft corals, glass sponges, and cold-water anemones.
        </p>
        <div class="alert alert-info font-mono text-left">
          <strong>OPERATIONAL MANDATE:</strong><br/>
          1. Drop diverse mineral debris from the inventory into the current column.<br/>
          2. Deflect falling debris using the <strong>Thermohaline Current</strong>.<br/>
          3. Accrete exactly <strong class="text-gold">3 dropstones</strong> in each of the four seafloor sectors (A, B, C, D) to satisfy biodiversity offset quotas.<br/>
          4. <strong>CAUTION:</strong> Rising water temperatures accelerate calving but cause established benthic organisms to decay over time.
        </div>
        <button id="arm-button" class="btn btn-primary font-mono">
          Initialize Ocean Column & Synth
        </button>
      </div>
    </div>

    <!-- Main Workspace -->
    <div class="workspace-grid hidden" id="workspace">
      <!-- Left Column: Hydrographic Current Column -->
      <div class="panel stage-panel glass">
        <div class="panel-header">
          <h2 class="panel-title font-mono">I. Hydrographic Column</h2>
          <span class="status-indicator font-mono" id="simulation-status">STANDBY</span>
        </div>

        <div class="canvas-stage-wrapper">
          <div class="canvas-stage" id="canvas-stage" role="img" aria-label="Vector Water Column showing icebergs at the top, falling stones, current flow lines, and marine organisms at the seafloor.">
            <canvas id="simulation-canvas" width="400" height="500"></canvas>
            
            <!-- Accessible Keyboard Control Overlay -->
            <div id="keyboard-steer-indicator" class="keyboard-hud font-mono hidden">
              <span>ACTIVE STONE STEERING:</span>
              <div class="steer-keys">
                <span class="key-cap">Shift</span> + <span class="key-cap">&larr;</span> / <span class="key-cap">&rarr;</span>
              </div>
            </div>
          </div>
        </div>

        <div class="keyboard-hint font-mono">
          [CLICK ON CANVAS] Drop Stone at position // [TAB] Navigate Panel controls // [SHIFT + ARROWS] Steer active falling stone
        </div>
      </div>

      <!-- Right Column: Deposition Ledger & Accretion HUD -->
      <div class="panel control-panel glass">
        <h2 class="panel-title font-mono">II. Deposition Ledger</h2>

        <!-- Metrics Dashboard -->
        <div class="telemetry-grid">
          <div class="telemetry-box">
            <span class="box-label font-mono">HEAT INDEX</span>
            <div class="box-value font-mono text-danger" id="temp-display">+2.00 °C</div>
          </div>
          <div class="telemetry-box">
            <span class="box-label font-mono">GLACIAL RUNOFF</span>
            <div class="box-value font-mono text-cyan" id="melt-rate-display">0.05 m³/s</div>
          </div>
          <div class="telemetry-box full-width">
            <span class="box-label font-mono">BIODIVERSITY OFFSET ACCELERATION</span>
            <div class="offset-bar-container">
              <div class="offset-bar-fill" id="offset-bar" style="width: 0%"></div>
              <span class="offset-value font-mono" id="offset-display">0%</span>
            </div>
          </div>
        </div>

        <!-- Accretion Bays Status (Playwright Target Elements) -->
        <div class="bays-panel">
          <span class="panel-section-title font-mono">SEAFLOOR ACCRETION BAYS STATUS:</span>
          <div class="bays-grid">
            <div class="bay-status-card" id="bay-indicator-A" data-accretion="0">
              <span class="bay-name font-mono">BAY A (0-100px)</span>
              <div class="bay-progress">
                <span class="progress-dot"></span>
                <span class="progress-dot"></span>
                <span class="progress-dot"></span>
              </div>
              <span class="bay-count font-mono">0 / 3</span>
            </div>
            <div class="bay-status-card" id="bay-indicator-B" data-accretion="0">
              <span class="bay-name font-mono">BAY B (100-200px)</span>
              <div class="bay-progress">
                <span class="progress-dot"></span>
                <span class="progress-dot"></span>
                <span class="progress-dot"></span>
              </div>
              <span class="bay-count font-mono">0 / 3</span>
            </div>
            <div class="bay-status-card" id="bay-indicator-C" data-accretion="0">
              <span class="bay-name font-mono">BAY C (200-300px)</span>
              <div class="bay-progress">
                <span class="progress-dot"></span>
                <span class="progress-dot"></span>
                <span class="progress-dot"></span>
              </div>
              <span class="bay-count font-mono">0 / 3</span>
            </div>
            <div class="bay-status-card" id="bay-indicator-D" data-accretion="0">
              <span class="bay-name font-mono">BAY D (300-400px)</span>
              <div class="bay-progress">
                <span class="progress-dot"></span>
                <span class="progress-dot"></span>
                <span class="progress-dot"></span>
              </div>
              <span class="bay-count font-mono">0 / 3</span>
            </div>
          </div>
        </div>

        <!-- Debris Spawn Inventory (Draggable / Clickable) -->
        <div class="inventory-section">
          <span class="panel-section-title font-mono">SINKING DEBRIS INVENTORY:</span>
          <div class="inventory-list">
            <button class="debris-card" id="debris-granite" draggable="true" data-type="granite">
              <span class="debris-icon">🪨</span>
              <div class="debris-details text-left">
                <span class="debris-name font-mono">Granite Erratic</span>
                <span class="debris-meta font-mono">Heavy // Rapid Sinking</span>
              </div>
            </button>
            <button class="debris-card" id="debris-basalt" draggable="true" data-type="basalt">
              <span class="debris-icon">🌋</span>
              <div class="debris-details text-left">
                <span class="debris-name font-mono">Basalt Nodule</span>
                <span class="debris-meta font-mono">Medium Weight // Coarse Texture</span>
              </div>
            </button>
            <button class="debris-card" id="debris-shale" draggable="true" data-type="shale">
              <span class="debris-icon">🫓</span>
              <div class="debris-details text-left">
                <span class="debris-name font-mono">Fossilized Shale</span>
                <span class="debris-meta font-mono">Light // High Current Deflection</span>
              </div>
            </button>
            <button class="debris-card" id="debris-silt" draggable="true" data-type="silt">
              <span class="debris-icon">⏳</span>
              <div class="debris-details text-left">
                <span class="debris-name font-mono">Glacial Silt Bundle</span>
                <span class="debris-meta font-mono">Drifting // Creates Soft Anemones</span>
              </div>
            </button>
          </div>
        </div>

        <!-- Hydrographic Controls -->
        <div class="sliders-section">
          <div class="slider-container">
            <div class="slider-labels">
              <label for="current-slider" class="font-mono">THERMOHALINE CURRENT FORCE</label>
              <span id="current-val-display" class="font-mono text-cyan">0.0 px/f</span>
            </div>
            <input type="range" id="current-slider" min="-10" max="10" step="0.5" value="0" class="custom-slider" />
          </div>

          <div class="slider-container">
            <div class="slider-labels">
              <label for="temp-slider" class="font-mono">WATER TEMPERATURE STIMULUS</label>
              <span id="temp-val-display" class="font-mono text-danger">+2.0 °C</span>
            </div>
            <input type="range" id="temp-slider" min="0.5" max="4.5" step="0.1" value="2.0" class="custom-slider" />
          </div>
        </div>

        <!-- Accretion Submission Actions -->
        <div class="system-actions">
          <span class="status-indicator font-mono text-danger" id="audit-status">OFFSETS UNVERIFIED</span>
          <button id="submit-audit-btn" class="btn btn-danger font-mono" disabled>
            📁 Submit Accretion Audit
          </button>
        </div>
      </div>
    </div>

    <!-- Success Registry Confirmation Overlay -->
    <div id="success-screen" class="success-screen hidden">
      <div class="success-content glass">
        <div class="success-icon">🪸</div>
        <h1 class="success-title text-gradient">Ecosystem Offsets Verified</h1>
        <p class="success-desc">
          Benthic accretion quotas satisfied. Glacial dropstones have successfully seeded cold-water soft coral colonies, glass sponges, and anemones across all four deep-sea sectors.
        </p>
        <div class="success-metrics font-mono">
          <div class="metric-box">
            <span class="m-val text-gradient" id="final-bays-display">4 / 4</span>
            <span class="m-lbl">Sectors Accreted</span>
          </div>
          <div class="metric-box">
            <span class="m-val text-gradient" id="final-temp-display">+2.0 °C</span>
            <span class="m-lbl">Audit Temperature</span>
          </div>
          <div class="metric-box">
            <span class="m-val text-gradient">100%</span>
            <span class="m-lbl">Ecosystem Balance</span>
          </div>
        </div>
        <div class="success-quote italic">
          "The melting peaks construct the deep gardens of tomorrow."
        </div>
        <button id="restart-btn" class="btn btn-tranquil font-mono">
          Reset Accretion Records
        </button>
      </div>
    </div>
  </div>

  <style>
    /* Scoped layout styling */
    .desk-container {
      position: relative;
      min-height: calc(100vh - 6rem);
      padding: var(--spacing-6);
      display: flex;
      flex-direction: column;
      gap: var(--spacing-6);
      background-color: var(--color-bg);
      color: var(--color-text);
      overflow: hidden;
    }

    /* CRT monitor effect */
    .crt-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
      background-size: 100% 4px, 3px 100%;
      pointer-events: none;
      z-index: 10;
    }
    
    .crt-flicker {
      position: absolute;
      inset: 0;
      background: rgba(18, 16, 16, 0.02);
      opacity: 0;
      pointer-events: none;
      z-index: 10;
      animation: flicker 0.15s infinite;
    }

    @keyframes flicker {
      0% { opacity: 0.18; }
      50% { opacity: 0.22; }
      100% { opacity: 0.18; }
    }

    .background-canvas {
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 1;
      opacity: 0.25;
    }

    .desk-header {
      z-index: 2;
      display: flex;
      flex-direction: column;
      gap: var(--spacing-1);
      border-bottom: 1px solid var(--color-border);
      padding-bottom: var(--spacing-3);
    }

    .subtitle {
      font-size: 0.85rem;
      letter-spacing: 0.1em;
      opacity: 0.7;
    }

    /* Arming Screen */
    .overlay {
      position: absolute;
      inset: var(--spacing-6);
      z-index: 20;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: var(--radius-lg);
      padding: var(--spacing-8);
      text-align: center;
    }

    .overlay-content {
      max-width: 600px;
      display: flex;
      flex-direction: column;
      gap: var(--spacing-4);
      align-items: center;
    }

    .overlay-icon {
      font-size: 4rem;
      animation: float 4s ease-in-out infinite;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0px) rotate(0deg); }
      50% { transform: translateY(-10px) rotate(3deg); }
    }

    .overlay-title {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--color-brass);
    }

    .overlay-desc {
      font-size: 1.05rem;
      opacity: 0.9;
      line-height: 1.6;
    }

    .alert {
      padding: var(--spacing-4);
      border-radius: var(--radius-md);
      font-size: 0.9rem;
      line-height: 1.6;
      border: 1px solid var(--color-border);
    }

    .alert-info {
      background: oklch(90% 0.02 240 / 0.1);
      border-color: oklch(75% 0.1 240 / 0.3);
      color: oklch(90% 0.05 240);
    }

    .btn {
      padding: var(--spacing-3) var(--spacing-6);
      border-radius: var(--radius-md);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      cursor: pointer;
      border: 1px solid var(--color-border);
      transition: all 0.2s ease;
    }

    .btn-primary {
      background-color: var(--color-brass);
      color: var(--color-bg);
      border-color: var(--color-brass);
      box-shadow: 0 0 15px var(--color-brass-light);
    }

    .btn-primary:hover {
      transform: scale(1.03);
      box-shadow: 0 0 25px var(--color-brass-light);
    }

    /* Workspace */
    .workspace-grid {
      z-index: 2;
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: var(--spacing-6);
      flex: 1;
    }

    .panel {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-4);
      padding: var(--spacing-6);
      border-radius: var(--radius-lg);
      overflow: hidden;
    }

    .panel-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid var(--color-border);
      padding-bottom: var(--spacing-2);
    }

    .panel-title {
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--color-brass);
    }

    .status-indicator {
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.05em;
    }

    .status-indicator.text-danger {
      color: #ef4444;
    }

    .status-indicator.text-cyan {
      color: #06b6d4;
    }

    .status-indicator.text-gold {
      color: #f59e0b;
    }

    /* Simulation Canvas column */
    .canvas-stage-wrapper {
      position: relative;
      flex: 1;
      display: flex;
      justify-content: center;
      align-items: center;
      background: oklch(0% 0 0 / 0.25);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      overflow: hidden;
      min-height: 400px;
    }

    #simulation-canvas {
      display: block;
      background-color: oklch(8% 0.03 240);
      cursor: crosshair;
      max-width: 100%;
      height: auto;
      aspect-ratio: 4 / 5;
    }

    .keyboard-hud {
      position: absolute;
      top: 12px;
      right: 12px;
      background: rgba(0, 0, 0, 0.7);
      padding: 6px 12px;
      border-radius: 4px;
      border: 1px solid var(--color-border);
      font-size: 0.75rem;
      display: flex;
      flex-direction: column;
      gap: 4px;
      color: #f59e0b;
    }

    .key-cap {
      background: #333;
      padding: 2px 6px;
      border-radius: 3px;
      border: 1px solid #555;
      color: #fff;
    }

    .keyboard-hint {
      font-size: 0.75rem;
      opacity: 0.6;
      text-align: center;
    }

    /* Telemetry grid */
    .telemetry-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-3);
    }

    .telemetry-box {
      background: oklch(100% 0 0 / 0.02);
      border: 1px solid var(--color-border);
      padding: var(--spacing-3);
      border-radius: var(--radius-md);
      display: flex;
      flex-direction: column;
      gap: var(--spacing-1);
    }

    .telemetry-box.full-width {
      grid-column: span 2;
    }

    .box-label {
      font-size: 0.7rem;
      opacity: 0.6;
      letter-spacing: 0.05em;
    }

    .box-value {
      font-size: 1.25rem;
      font-weight: 700;
    }

    .text-danger { color: #f87171; }
    .text-cyan { color: #22d3ee; }
    .text-gold { color: #fbbf24; }

    .offset-bar-container {
      position: relative;
      height: 1.5rem;
      background: rgba(255, 255, 255, 0.05);
      border-radius: var(--radius-sm);
      overflow: hidden;
      border: 1px solid var(--color-border);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .offset-bar-fill {
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      background: linear-gradient(90deg, #06b6d4, #10b981);
      box-shadow: 0 0 10px rgba(6, 182, 212, 0.5);
      transition: width 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .offset-value {
      position: relative;
      z-index: 2;
      font-size: 0.85rem;
      font-weight: 800;
      color: #fff;
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.8);
    }

    /* Accretion Bays Status Grid */
    .bays-panel {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-2);
    }

    .panel-section-title {
      font-size: 0.75rem;
      font-weight: 800;
      opacity: 0.8;
      letter-spacing: 0.05em;
      color: var(--color-brass);
    }

    .bays-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-2);
    }

    .bay-status-card {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: var(--spacing-3);
      display: flex;
      flex-direction: column;
      gap: var(--spacing-2);
      transition: all 0.2s ease;
    }

    .bay-status-card[data-accretion="3"] {
      border-color: #10b981;
      background: rgba(16, 185, 129, 0.04);
      box-shadow: 0 0 10px rgba(16, 185, 129, 0.1);
    }

    .bay-name {
      font-size: 0.7rem;
      opacity: 0.7;
    }

    .bay-progress {
      display: flex;
      gap: 6px;
    }

    .progress-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid var(--color-border);
      transition: background 0.3s ease;
    }

    .bay-status-card[data-accretion="1"] .progress-dot:nth-child(1) { background: #06b6d4; box-shadow: 0 0 6px #06b6d4; }
    .bay-status-card[data-accretion="2"] .progress-dot:nth-child(-n+2) { background: #06b6d4; box-shadow: 0 0 6px #06b6d4; }
    .bay-status-card[data-accretion="3"] .progress-dot:nth-child(-n+3) { background: #10b981; box-shadow: 0 0 6px #10b981; }

    .bay-count {
      font-size: 0.8rem;
      font-weight: 700;
      text-align: right;
    }

    /* Sinking Debris Inventory */
    .inventory-section {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-2);
    }

    .inventory-list {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-2);
    }

    .debris-card {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: var(--spacing-2) var(--spacing-3);
      display: flex;
      align-items: center;
      gap: var(--spacing-3);
      cursor: grab;
      text-align: left;
      transition: all 0.2s ease;
    }

    .debris-card:active {
      cursor: grabbing;
    }

    .debris-card:hover, .debris-card:focus-visible {
      background: rgba(255, 255, 255, 0.08);
      border-color: var(--color-brass);
      outline: none;
    }

    .debris-icon {
      font-size: 1.5rem;
    }

    .debris-details {
      display: flex;
      flex-direction: column;
    }

    .debris-name {
      font-size: 0.85rem;
      font-weight: 700;
    }

    .debris-meta {
      font-size: 0.65rem;
      opacity: 0.6;
    }

    /* Custom Sliders */
    .sliders-section {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-3);
      background: rgba(0, 0, 0, 0.1);
      padding: var(--spacing-4);
      border-radius: var(--radius-md);
      border: 1px solid var(--color-border);
    }

    .slider-container {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .slider-labels {
      display: flex;
      justify-content: space-between;
      font-size: 0.75rem;
      font-weight: 700;
    }

    .custom-slider {
      -webkit-appearance: none;
      appearance: none;
      width: 100%;
      height: 6px;
      border-radius: 3px;
      background: rgba(255, 255, 255, 0.1);
      outline: none;
      border: 1px solid var(--color-border);
    }

    .custom-slider::-webkit-slider-thumb {
      -webkit-appearance: none;
      appearance: none;
      width: 16px;
      height: 16px;
      border-radius: 50%;
      background: var(--color-brass);
      cursor: pointer;
      border: 2px solid var(--color-bg);
      box-shadow: 0 0 8px var(--color-brass-light);
    }

    .custom-slider::-moz-range-thumb {
      width: 16px;
      height: 16px;
      border-radius: 50%;
      background: var(--color-brass);
      cursor: pointer;
      border: 2px solid var(--color-bg);
      box-shadow: 0 0 8px var(--color-brass-light);
    }

    /* Submission controls */
    .system-actions {
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-top: 1px solid var(--color-border);
      padding-top: var(--spacing-4);
    }

    .btn-danger {
      background: transparent;
      color: #ef4444;
      border-color: rgba(239, 68, 68, 0.3);
    }

    .btn-danger:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      border-color: rgba(239, 68, 68, 0.15);
    }

    .btn-gold {
      background: #f59e0b;
      color: #000;
      border-color: #f59e0b;
      box-shadow: 0 0 15px rgba(245, 158, 11, 0.4);
    }

    .btn-gold:hover {
      transform: scale(1.03);
      box-shadow: 0 0 25px rgba(245, 158, 11, 0.6);
    }

    .pulse-gold {
      animation: pulse-gold-anim 2s infinite;
    }

    @keyframes pulse-gold-anim {
      0%, 100% { opacity: 0.8; }
