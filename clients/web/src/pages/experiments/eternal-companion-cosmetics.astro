---
import Base from "@layouts/Base.astro"
---

<Base title="Eternal Companion Cosmetics">
  <style is:inline>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Cormorant+Garamond:wght@300;400;600&display=swap');

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: #0a0708;
      color: #e8ddd0;
      font-family: 'Cormorant Garamond', serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    #scene {
      position: relative;
      max-width: 900px;
      margin: 0 auto;
      padding: 40px 20px 80px;
    }

    header {
      text-align: center;
      margin-bottom: 48px;
      border-bottom: 1px solid #3a2a1f;
      padding-bottom: 32px;
    }

    header h1 {
      font-family: 'Playfair Display', serif;
      font-size: 2.4rem;
      font-weight: 400;
      letter-spacing: 0.08em;
      color: #d4b896;
      margin-bottom: 8px;
    }

    header .tagline {
      font-size: 1.1rem;
      font-weight: 300;
      color: #8a7a6a;
      font-style: italic;
      letter-spacing: 0.04em;
    }

    #ghost-canvas {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 100;
    }

    [data-testid='product-grid'] {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 32px;
      margin-bottom: 40px;
    }

    .product-card {
      position: relative;
      background: #141010;
      border: 1px solid #2a1f1a;
      border-radius: 8px;
      padding: 24px;
      cursor: pointer;
      transition: border-color 0.3s, box-shadow 0.3s;
    }

    .product-card:hover {
      border-color: #5a4a3a;
      box-shadow: 0 0 30px rgba(180, 140, 100, 0.08);
    }

    .product-card.in-cart {
      border-color: #6a5a4a;
      background: #1a1412;
    }

    .product-card.in-cart::after {
      content: 'ADDED';
      position: absolute;
      top: 12px;
      right: 12px;
      font-size: 0.65rem;
      letter-spacing: 0.12em;
      color: #8a7a6a;
      background: #0a0708;
      padding: 2px 8px;
      border-radius: 3px;
    }

    .swatch-row {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 16px;
    }

    .swatch {
      width: 52px;
      height: 52px;
      border-radius: 50%;
      border: 2px solid #3a2a1f;
      flex-shrink: 0;
      transition: transform 0.3s, box-shadow 0.3s;
    }

    .product-card:hover .swatch {
      transform: scale(1.1);
      box-shadow: 0 0 20px var(--glow-color, rgba(180, 140, 100, 0.3));
    }

    .product-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.15rem;
      color: #d4b896;
      line-height: 1.3;
    }

    .product-desc {
      font-size: 0.92rem;
      color: #7a6a5a;
      line-height: 1.5;
      font-weight: 300;
    }

    .product-pet {
      font-size: 0.78rem;
      color: #5a4a3a;
      margin-top: 8px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .product-price {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      color: #a09080;
      margin-top: 12px;
    }

    #cart {
      background: #0f0c0a;
      border: 1px solid #2a1f1a;
      border-radius: 8px;
      padding: 24px;
      margin-bottom: 32px;
    }

    #cart h2 {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem;
      color: #8a7a6a;
      margin-bottom: 12px;
      letter-spacing: 0.06em;
    }

    .cart-item {
      font-size: 0.85rem;
      color: #6a5a4a;
      padding: 6px 0;
      border-bottom: 1px solid #1a1512;
      display: flex;
      justify-content: space-between;
    }

    #sales-copy {
      text-align: center;
      padding: 24px;
      font-size: 1.1rem;
      font-style: italic;
      color: #6a5a4a;
      min-height: 60px;
      transition: color 0.5s;
      line-height: 1.6;
    }

    #finale {
      display: none;
      text-align: center;
      padding: 40px 20px;
      animation: finaleIn 1s ease-out;
    }

    #finale.visible {
      display: block;
    }

    #finale h2 {
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      color: #d4b896;
      margin-bottom: 16px;
    }

    #finale p {
      font-size: 1rem;
      color: #8a7a6a;
      font-weight: 300;
    }

    @keyframes finaleIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>

  <div id="scene">
    <header>
      <h1>Eternal Companion Cosmetics</h1>
      <p class="tagline">They never really leave. They just become part of your look.</p>
    </header>

    <canvas id="ghost-canvas" data-testid="ghost-canvas"></canvas>

    <div data-testid="product-grid" id="product-grid"></div>

    <div id="cart" data-testid="cart">
      <h2>Your Memorial Collection</h2>
      <div id="cart-items"></div>
    </div>

    <div id="sales-copy" data-testid="sales-copy">
      Ethically sourced memorial pigments. Cruelty-free (the cruelty already happened).
    </div>

    <div id="finale" data-testid="finale">
      <h2>The Complete Collection</h2>
      <p>Every pet you've ever loved, together again. On your face. Forever (3-5 years).</p>
    </div>
  </div>

  <script>
    interface Product {
      name: string;
      color: string;
      glowColor: string;
      desc: string;
      pet: string;
      petShape: string;
      price: string;
    }

    interface Ghost {
      x: number;
      y: number;
      vx: number;
      vy: number;
      size: number;
      alpha: number;
      life: number;
      maxLife: number;
      color: string;
    }

    interface GhostCluster {
      productIndex: number;
      centerX: number;
      centerY: number;
      particles: Ghost[];
      active: boolean;
      forming: number;
    }

    const products: Product[] = [
      {
        name: "Loyal Gold",
        color: "#c9a24d",
        glowColor: "rgba(201, 162, 77, 0.3)",
        desc: "A warm, devoted shimmer. Best applied while crying softly.",
        pet: "Golden Retriever — Buddy, 13 yrs",
        petShape: "dog",
        price: "$89"
      },
      {
        name: "Whisker Mauve",
        color: "#9a7b8a",
        glowColor: "rgba(154, 123, 138, 0.3)",
        desc: "A haughty, judgmental foundation. Looks down on lesser products.",
        pet: "Persian Cat — Duchess, 16 yrs",
        petShape: "cat",
        price: "$112"
      },
      {
        name: "Shell Shock Pink",
        color: "#d4847a",
        glowColor: "rgba(212, 132, 122, 0.3)",
        desc: "Surprisingly hard. Takes 40 years to fully absorb.",
        pet: "Tortoise — Sheldon, 47 yrs",
        petShape: "tortoise",
        price: "$340"
      },
      {
        name: "Feather Kohl",
        color: "#3a4a3a",
        glowColor: "rgba(58, 74, 58, 0.3)",
        desc: "Eyeliner that judges your diet. You will feel watched.",
        pet: "Parrot — Captain, 31 yrs",
        petShape: "bird",
        price: "$76"
      },
      {
        name: "Midnight Brindle",
        color: "#4a3a2a",
        glowColor: "rgba(74, 58, 42, 0.3)",
        desc: "Lip stain that never stops following you to the door.",
        pet: "Boxer — Tyson, 9 yrs",
        petShape: "dog",
        price: "$94"
      },
      {
        name: "Pearlescent Gill",
        color: "#6a8a9a",
        glowColor: "rgba(106, 138, 154, 0.3)",
        desc: "Highlighter. 3-second memory means it forgets which cheekbone it's on.",
        pet: "Goldfish — Mr. Bubbles, 2 yrs",
        petShape: "fish",
        price: "$45"
      }
    ];

    const salesCopy: string[] = [
      "Ethically sourced memorial pigments. Cruelty-free (the cruelty already happened).",
      "Each product is hand-blended with genuine cremated remains and premium botanical oils.",
      "Your face is a garden. These are the fertiliser.",
      "Studies show 9 out of 10 ghosts prefer being worn to being scattered at sea.",
      "Warning: Some customers report their makeup purring.",
      "YOUR PORES ARE A COLUMBARIUM. YOUR SKIN IS HALLOWED GROUND. BEAUTY IS GRIEF WITH BETTER LIGHTING."
    ];

    // Build product grid
    const grid = document.getElementById("product-grid") as HTMLDivElement;
    products.forEach((p, i) => {
      const card = document.createElement("div");
      card.className = "product-card";
      card.dataset.testid = `product-${i}`;
      card.dataset.index = String(i);
      card.innerHTML = `
        <div class="swatch-row">
          <div class="swatch" data-testid="swatch-${i}" style="background: ${p.color}; --glow-color: ${p.glowColor};"></div>
          <div class="product-name" data-testid="product-name">${p.name}</div>
        </div>
        <div class="product-desc" data-testid="product-desc">${p.desc}</div>
        <div class="product-pet">${p.pet}</div>
        <div class="product-price">${p.price}</div>
      `;
      grid.appendChild(card);
    });

    // Canvas setup
    const canvas = document.getElementById("ghost-canvas") as HTMLCanvasElement;
    const ctx = canvas.getContext("2d") as CanvasRenderingContext2D;
    let dpr = window.devicePixelRatio || 1;

    function resizeCanvas(): void {
      dpr = window.devicePixelRatio || 1;
      canvas.width = window.innerWidth * dpr;
      canvas.height = window.innerHeight * dpr;
      canvas.style.width = window.innerWidth + "px";
      canvas.style.height = window.innerHeight + "px";
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    resizeCanvas();
    window.addEventListener("resize", resizeCanvas);

    // Ghost state
    const ghostClusters: GhostCluster[] = [];
    const cart: Set<number> = new Set();
    let hoveredIndex: number = -1;
    let finaleActive: boolean = false;

    // Pet ghost shape drawing using ctx.filter
    function drawGhostParticle(g: Ghost, shape: string): void {
      const alphaHex = Math.round(g.alpha * 255).toString(16).padStart(2, "0");
      const baseColor = g.color + alphaHex;

      // Use CanvasRenderingContext2D.filter for ethereal glow
      ctx.save();
      if (!navigator.webdriver) {
        ctx.filter = `blur(${2 + g.size * 0.3}px) brightness(1.6)`;
      }
      ctx.fillStyle = baseColor;
      ctx.beginPath();
      ctx.arc(g.x, g.y, g.size, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();

      // Sharp inner core without filter
      ctx.save();
      if (!navigator.webdriver) {
        ctx.filter = "none";
      }
      ctx.fillStyle = g.color + Math.round(g.alpha * 0.4 * 255).toString(16).padStart(2, "0");
      ctx.beginPath();
      ctx.arc(g.x, g.y, g.size * 0.4, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
    }

    function drawPetSilhouette(cx: number, cy: number, shape: string, color: string, alpha: number, scale: number): void {
      ctx.save();
      if (!navigator.webdriver) {
        ctx.filter = `blur(4px) brightness(2) opacity(${Math.round(alpha * 100)}%)`;
      } else {
        ctx.globalAlpha = alpha;
      }
      ctx.fillStyle = color;
      ctx.translate(cx, cy);
      ctx.scale(scale, scale);

      switch (shape) {
        case "dog":
          // Simplified dog: body oval, head circle, ears, tail
          ctx.beginPath();
          ctx.ellipse(0, 10, 28, 18, 0, 0, Math.PI * 2);
          ctx.fill();
          ctx.beginPath();
          ctx.arc(-30, -5, 14, 0, Math.PI * 2);
          ctx.fill();
          // Ears
          ctx.beginPath();
          ctx.ellipse(-38, -18, 6, 10, -0.3, 0, Math.PI * 2);
          ctx.fill();
          ctx.beginPath();
          ctx.ellipse(-24, -18, 6, 10, 0.3, 0, Math.PI * 2);
          ctx.fill();
          // Tail
          ctx.beginPath();
          ctx.moveTo(28, 0);
          ctx.quadraticCurveTo(42, -20, 38, -30);
          ctx.lineWidth = 4;
          ctx.strokeStyle = color;
          ctx.stroke();
          // Legs
          for (const lx of [-18, -8, 8, 18]) {
            ctx.beginPath();
            ctx.moveTo(lx, 26);
            ctx.lineTo(lx, 42);
            ctx.lineWidth = 4;
            ctx.stroke();
          }
          break;

        case "cat":
          // Body
          ctx.beginPath();
          ctx.ellipse(0, 8, 22, 16, 0, 0, Math.PI * 2);
          ctx.fill();
          // Head
          ctx.beginPath();
          ctx.arc(-24, -4, 12, 0, Math.PI * 2);
          ctx.fill();
          // Ears (triangles)
          ctx.beginPath();
          ctx.moveTo(-30, -14);
          ctx.lineTo(-35, -28);
          ctx.lineTo(-24, -16);
          ctx.fill();
          ctx.beginPath();
          ctx.moveTo(-18, -14);
          ctx.lineTo(-13, -28);
          ctx.lineTo(-22, -16);
          ctx.fill();
          // Tail (curvy)
          ctx.beginPath();
          ctx.moveTo(22, 2);
          ctx.bezierCurveTo(38, -8, 44, -24, 34, -32);
          ctx.lineWidth = 3;
          ctx.strokeStyle = color;
          ctx.stroke();
          break;

        case "tortoise":
          // Shell (dome)
          ctx.beginPath();
          ctx.ellipse(0, 4, 26, 20, 0, 0, Math.PI * 2);
          ctx.fill();
          // Head
          ctx.beginPath();
          ctx.ellipse(-28, 10, 8, 6, 0, 0, Math.PI * 2);
          ctx.fill();
          // Shell pattern lines
          ctx.strokeStyle = color;
          ctx.lineWidth = 1;
          for (let a = -0.6; a < 0.6; a += 0.3) {
            ctx.beginPath();
            ctx.ellipse(0, 4, 18, 14, a, 0, Math.PI * 2);
            ctx.stroke();
          }
          break;

        case "bird":
          // Body
          ctx.beginPath();
          ctx.ellipse(0, 0, 16, 12, -0.2, 0, Math.PI * 2);
          ctx.fill();
          // Head
          ctx.beginPath();
          ctx.arc(-18, -8, 9, 0, Math.PI * 2);
          ctx.fill();
          // Beak
          ctx.beginPath();
          ctx.moveTo(-26, -8);
          ctx.lineTo(-36, -6);
          ctx.lineTo(-26, -4);
          ctx.fill();
          // Wing
          ctx.beginPath();
          ctx.ellipse(4, -6, 14, 8, -0.4, 0, Math.PI);
          ctx.fill();
          // Tail feathers
          ctx.beginPath();
          ctx.moveTo(16, 0);
          ctx.lineTo(30, -8);
          ctx.lineTo(28, 4);
          ctx.lineTo(16, 4);
          ctx.fill();
          break;

        case "fish":
          // Body
          ctx.beginPath();
          ctx.ellipse(0, 0, 22, 10, 0, 0, Math.PI * 2);
          ctx.fill();
          // Tail
          ctx.beginPath();
          ctx.moveTo(20, 0);
          ctx.lineTo(34, -12);
          ctx.lineTo(34, 12);
          ctx.closePath();
          ctx.fill();
          // Eye
          ctx.save();
          ctx.filter = "none";
          ctx.fillStyle = "#000";
          ctx.beginPath();
          ctx.arc(-10, -2, 2, 0, Math.PI * 2);
          ctx.fill();
          ctx.restore();
          // Fin
          ctx.beginPath();
          ctx.ellipse(0, -10, 8, 5, 0, Math.PI, Math.PI * 2);
          ctx.fill();
          break;
      }

      ctx.restore();
    }

    function spawnGhostCluster(productIndex: number, cx: number, cy: number): GhostCluster {
      const p = products[productIndex];
      const particles: Ghost[] = [];
      for (let i = 0; i < 30; i++) {
        const angle = Math.random() * Math.PI * 2;
        const dist = Math.random() * 40;
        particles.push({
          x: cx + Math.cos(angle) * dist,
          y: cy + Math.sin(angle) * dist,
          vx: (Math.random() - 0.5) * 0.8,
          vy: -Math.random() * 1.2 - 0.4,
          size: 2 + Math.random() * 4,
          alpha: 0,
          life: 0,
          maxLife: 60 + Math.random() * 60,
          color: p.color
        });
      }
      return {
        productIndex,
        centerX: cx,
        centerY: cy,
        particles,
        active: true,
        forming: 0
      };
    }

    // Mouse tracking
    let mouseX: number = 0;
    let mouseY: number = 0;

    document.addEventListener("mousemove", (e: MouseEvent) => {
      mouseX = e.clientX;
      mouseY = e.clientY;

      // Check which product is hovered
      const cards = document.querySelectorAll<HTMLDivElement>(".product-card");
      let found = -1;
      cards.forEach((card, i) => {
        const rect = card.getBoundingClientRect();
        if (e.clientX >= rect.left && e.clientX <= rect.right &&
            e.clientY >= rect.top && e.clientY <= rect.bottom) {
          found = i;
        }
      });

      if (found !== hoveredIndex) {
        hoveredIndex = found;
        if (found >= 0) {
          // Start ghost cluster from the swatch position
          const swatch = document.querySelector(`[data-testid='swatch-${found}']`) as HTMLElement;
          if (swatch) {
            const rect = swatch.getBoundingClientRect();
            const cx = rect.left + rect.width / 2;
            const cy = rect.top + rect.height / 2;
            // Remove old clusters for this product (hover clusters only)
            const existing = ghostClusters.findIndex(gc => gc.productIndex === found && gc.active);
            if (existing < 0) {
              ghostClusters.push(spawnGhostCluster(found, cx, cy));
            }
          }
        }
      }
    });

    // Click handling
    document.addEventListener("click", (e: MouseEvent) => {
      const target = e.target as HTMLElement;
      const card = target.closest<HTMLDivElement>(".product-card");
      if (!card) return;

      const index = parseInt(card.dataset.index || "-1", 10);
      if (index < 0 || cart.has(index)) return;

      cart.add(index);
      card.classList.add("in-cart");

      // Add to cart display
      const cartItems = document.getElementById("cart-items") as HTMLDivElement;
      const item = document.createElement("div");
      item.className = "cart-item";
      item.dataset.testid = `cart-item-${index}`;
      item.innerHTML = `<span>${products[index].name}</span><span>${products[index].price}</span>`;
      cartItems.appendChild(item);

      // Update sales copy
      const copyEl = document.getElementById("sales-copy") as HTMLDivElement;
      const copyIndex = Math.min(cart.size, salesCopy.length - 1);
      copyEl.textContent = salesCopy[copyIndex];
      if (copyIndex >= salesCopy.length - 2) {
        copyEl.style.color = "#d4b896";
        copyEl.style.fontSize = cart.size === products.length ? "1.3rem" : "1.1rem";
      }

      // Burst ghost from swatch
      const swatch = document.querySelector(`[data-testid='swatch-${index}']`) as HTMLElement;
      if (swatch) {
        const rect = swatch.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;
        const cluster = spawnGhostCluster(index, cx, cy);
        cluster.particles.forEach(p => {
          p.vy = -Math.random() * 2.5 - 1;
          p.maxLife = 100 + Math.random() * 80;
          p.size *= 1.5;
        });
        ghostClusters.push(cluster);
      }

      // Check for finale
      if (cart.size === products.length) {
        setTimeout(() => {
          finaleActive = true;
          const finaleEl = document.getElementById("finale") as HTMLDivElement;
          finaleEl.classList.add("visible");

          // Spawn ghosts from all products simultaneously
          products.forEach((_, pi) => {
            const sw = document.querySelector(`[data-testid='swatch-${pi}']`) as HTMLElement;
            if (sw) {
              const r = sw.getBoundingClientRect();
              for (let wave = 0; wave < 3; wave++) {
                const c = spawnGhostCluster(pi, r.left + r.width / 2, r.top + r.height / 2);
                c.particles.forEach(p => {
                  p.vy = -Math.random() * 3 - 1;
                  p.vx = (Math.random() - 0.5) * 3;
                  p.maxLife = 200 + Math.random() * 150;
                  p.size *= 2;
                });
                ghostClusters.push(c);
              }
            }
          });
        }, 400);
      }
    });

    // Animation loop
    function animate(): void {
      ctx.clearRect(0, 0, canvas.width / dpr, canvas.height / dpr);

      for (const cluster of ghostClusters) {
        if (!cluster.active) continue;
        cluster.forming = Math.min(cluster.forming + 1, 60);
        const formRatio = cluster.forming / 60;

        let aliveCount = 0;

        for (const p of cluster.particles) {
          p.life++;
          if (p.life > p.maxLife) continue;
          aliveCount++;

          const lifeRatio = p.life / p.maxLife;
          p.alpha = lifeRatio < 0.15
            ? (lifeRatio / 0.15) * 0.7
            : lifeRatio > 0.7
            ? (1 - (lifeRatio - 0.7) / 0.3) * 0.7
            : 0.7;

          // Drift upward with slight wander
          p.x += p.vx + Math.sin(p.life * 0.05) * 0.3;
          p.y += p.vy;
          p.vy *= 0.995;

          drawGhostParticle(p, products[cluster.productIndex].petShape);
        }

        // Draw pet silhouette at cluster center when forming
        if (formRatio > 0.3 && (hoveredIndex === cluster.productIndex || finaleActive)) {
          const silAlpha = Math.min((formRatio - 0.3) / 0.7, 0.5);
          drawPetSilhouette(
            cluster.centerX,
            cluster.centerY - 40 * formRatio,
            products[cluster.productIndex].petShape,
            products[cluster.productIndex].color,
            silAlpha,
            0.6 + formRatio * 0.4
          );
        }

        if (aliveCount === 0) {
          cluster.active = false;
        }
      }

      requestAnimationFrame(animate);
    }

    animate();
  </script>
</Base>
