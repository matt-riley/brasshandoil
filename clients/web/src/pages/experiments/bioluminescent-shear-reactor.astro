---
import Base from "@layouts/Base.astro"
---

<Base title="Dinoflagellate Bioluminescent Shear Reactor // Algae Speciation Lab">
  <div class="reactor-container" id="reactor-root" data-status="dormant">
    <!-- Bio-laboratory atmosphere overlays -->
    <div class="crt-scanlines" aria-hidden="true"></div>
    <div class="glow-backdrop" aria-hidden="true"></div>

    <!-- Header -->
    <header class="reactor-header">
      <h1 class="page-title text-gradient">Dinoflagellate Bioluminescent Shear Reactor</h1>
      <p class="subtitle font-mono">LAB SYSTEM: PYROCYSTIS FUSIFORMIS // SHEAR STRESS CALIBRATION CHAMBER</p>
    </header>

    <!-- Arming Onboarding Overlay -->
    <div id="arming-overlay" class="overlay glass">
      <div class="overlay-content">
        <div class="overlay-icon">🦠</div>
        <h2 class="overlay-title font-mono text-cyan">BIOLUMINESCENT STIMULATION CHAMBER</h2>
        <p class="overlay-desc">
          Marine dinoflagellates emit a brilliant blue-green bioluminescent flash when subjected to mechanical shear stress. In this simulation, you calibrate a petri-dish culture chamber to achieve the optimal shear range for sustainable bioluminescence.
        </p>
        <div class="instructions-card font-mono">
          <strong>OPERATIONAL PROCEDURES:</strong><br/>
          1. <strong>Stir the Chamber:</strong> Click and drag inside the petri dish or use the keyboard [ARROW KEYS] to steer the virtual stirrer. Faster stirring generates higher shear.<br/>
          2. <strong>Adjust Auto-Stirrer:</strong> Press keys [1-9] to set the hotplate magnetic stirrer RPM, or use the panel controls.<br/>
          3. <strong>Calibrate Density:</strong> Toggle between culture media to change viscosity. Higher viscosity generates higher shear stress for the same stirrer speed.<br/>
          4. <strong>Reactor Calibration:</strong> Maintain the shear rate within the optimal zone (1.5 - 3.0 Pa) to reach 100% calibration coherence. Beware: shear rates above 3.5 Pa damage algae health!
        </div>
        <button id="arm-button" class="btn btn-primary font-mono">
          Initialize Audio & Open Reactor Chamber
        </button>
      </div>
    </div>

    <!-- Main Workspace Grid -->
    <div class="workspace-grid hidden" id="workspace">
      <!-- Left Panel: Reactor Core -->
      <div class="panel stage-panel glass">
        <div class="panel-header">
          <h2 class="panel-title font-mono text-cyan">I. REACTOR CHAMBER</h2>
          <span class="status-indicator font-mono alert-low" id="reactor-status">DORMANT</span>
        </div>

        <div class="canvas-relative-wrapper">
          <!-- Petri Dish Canvas -->
          <canvas id="reactor-canvas" width="400" height="400"></canvas>

          <!-- Virtual Keyboard Stirrer Overlay -->
          <svg id="virtual-cursor" class="virtual-cursor-svg" viewBox="0 0 40 40" aria-hidden="true">
            <circle cx="20" cy="20" r="14" class="cursor-ring" />
            <circle cx="20" cy="20" r="2" class="cursor-dot" />
            <line x1="20" y1="0" x2="20" y2="40" class="cursor-line" />
            <line x1="0" y1="20" x2="40" y2="20" class="cursor-line" />
          </svg>
        </div>

        <div class="keyboard-hints font-mono">
          [ARROW KEYS] Steer Virtual Stirrer // [SPACE] Trigger High-Shear Pulse // [1-9] Set Hotplate RPM
        </div>
      </div>

      <!-- Right Panel: Telemetry & Controls -->
      <div class="panel control-panel glass" id="telemetry-panel">
        <h2 class="panel-title font-mono text-cyan">II. BIO-TELEMETRY & CALIBRATION</h2>

        <!-- Telemetry Diagnostics Grid -->
        <div class="diagnostics-grid">
          <div class="diagnostic-box">
            <span class="box-label font-mono">SHEAR RATE</span>
            <div class="box-value font-mono text-cyan" id="shear-rate-val">0.00 Pa</div>
          </div>
          <div class="diagnostic-box">
            <span class="box-label font-mono">LUMINESCENCE INDEX</span>
            <div class="box-value font-mono text-cyan" id="luminescence-val">0%</div>
          </div>
          <div class="diagnostic-box">
            <span class="box-label font-mono">STIRRER AUTO-SPEED</span>
            <div class="box-value font-mono text-cyan" id="stirrer-speed-val">0 RPM</div>
          </div>
          <div class="diagnostic-box">
            <span class="box-label font-mono">POPULATION HEALTH</span>
            <div class="box-value font-mono text-green" id="health-val">100%</div>
          </div>
          
          <div class="diagnostic-box full-width">
            <span class="box-label font-mono">CALIBRATION RANGE (1.5 - 3.0 Pa)</span>
            <div class="calibration-bounds-bar">
              <div class="zone-marker" style="left: 30%; right: 40%;"></div>
              <div class="current-indicator" id="shear-indicator" style="left: 0%"></div>
            </div>
            <div class="bounds-labels font-mono">
              <span>0.0 Pa</span>
              <span class="target-label">OPTIMAL ZONE</span>
              <span>5.0 Pa</span>
            </div>
          </div>

          <div class="diagnostic-box full-width">
            <span class="box-label font-mono">COHERENCE PROGRESS</span>
            <div class="coherence-bar-container">
              <div class="coherence-bar-fill" id="coherence-fill" style="width: 0%"></div>
            </div>
            <div class="coherence-val-text font-mono" id="coherence-text">0.0%</div>
          </div>
        </div>

        <!-- Density Selection / Viscosity -->
        <div class="control-section glass-dark">
          <h3 class="section-heading font-mono">🧪 CULTURE MEDIUM DENSITY</h3>
          <div class="select-wrapper">
            <select id="fluid-density-select" class="control-select font-mono">
              <option value="water">Nutrient Water (Viscosity: 0.001 Pa·s)</option>
              <option value="agar" selected>Agar Suspension (Viscosity: 0.008 Pa·s)</option>
              <option value="glycerol">Glycerol Medium (Viscosity: 0.025 Pa·s)</option>
            </select>
          </div>
        </div>

        <!-- Hotplate Controls -->
        <div class="control-section glass-dark">
          <h3 class="section-heading font-mono">⚙️ STIRRER RPM SPEED</h3>
          <div class="rpm-buttons">
            <button class="rpm-btn font-mono active" data-speed="0">OFF</button>
            <button class="rpm-btn font-mono" data-speed="150">150</button>
            <button class="rpm-btn font-mono" data-speed="300">300</button>
            <button class="rpm-btn font-mono" data-speed="600">600</button>
            <button class="rpm-btn font-mono" data-speed="900">900</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Success Screen Overlay -->
    <div id="success-screen" class="overlay glass hidden">
      <div class="overlay-content success-box">
        <div class="overlay-icon success-icon">✨</div>
        <h2 class="overlay-title font-mono text-green">REACTOR CALIBRATION SUCCESSFUL</h2>
        <p class="overlay-desc">
          Bioluminescence resonance stabilized. Dinoflagellate shear adaptation has achieved steady state. The chamber is calibrated for optimum light yield.
        </p>
        <button id="restart-button" class="btn btn-success font-mono">
          Re-Initialize Calibration Cycle
        </button>
      </div>
    </div>
  </div>
</Base>

<style>
  /* --- Global Design System (Vanilla CSS Tokens) --- */
  :root {
    --bg-dark: #030712;
    --bg-panel: rgba(10, 18, 36, 0.75);
    --bg-panel-dark: rgba(5, 10, 20, 0.85);
    --border-glow: rgba(6, 182, 212, 0.15);
    --border-glow-focus: rgba(6, 182, 212, 0.4);
    
    --neon-cyan: #06b6d4;
    --neon-cyan-glow: #22d3ee;
    --neon-green: #10b981;
    --neon-green-glow: #34d399;
    --neon-red: #ef4444;
    
    --text-primary: #f3f4f6;
    --text-muted: #9ca3af;
  }

  .reactor-container {
    position: relative;
    width: 100%;
    min-height: 100vh;
    background-color: var(--bg-dark);
    color: var(--text-primary);
    padding: 2rem 1rem;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    overflow-x: hidden;
  }

  /* Scanlines overlay for biological CRT terminal style */
  .crt-scanlines {
    position: fixed;
    inset: 0;
    background: linear-gradient(
      rgba(18, 16, 16, 0) 50%,
      rgba(0, 0, 0, 0.25) 50%
    );
    background-size: 100% 4px;
    z-index: 90;
    pointer-events: none;
  }

  /* Deep background glow */
  .glow-backdrop {
    position: fixed;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(6, 182, 212, 0.08) 0%, rgba(3, 7, 18, 0) 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 1;
    pointer-events: none;
  }

  /* Header */
  .reactor-header {
    text-align: center;
    margin-bottom: 2.5rem;
    z-index: 10;
    width: 100%;
    max-width: 1000px;
  }

  .page-title {
    font-size: 2.5rem;
    font-weight: 800;
    margin: 0 0 0.5rem 0;
    letter-spacing: -0.025em;
    font-family: 'Outfit', sans-serif;
  }

  .text-gradient {
    background: linear-gradient(135deg, #ffffff 30%, var(--neon-cyan) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    font-size: 0.85rem;
    color: var(--text-muted);
    letter-spacing: 0.15em;
    margin: 0;
  }

  /* Onboarding / Overlay Styles */
  .overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    background: rgba(3, 7, 18, 0.85);
    backdrop-filter: blur(16px);
  }

  .overlay.hidden {
    display: none;
  }

  .overlay-content {
    background: var(--bg-panel);
    border: 1px solid var(--border-glow);
    border-radius: 16px;
    padding: 2.5rem;
    max-width: 620px;
    width: 100%;
    text-align: center;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    z-index: 101;
    max-height: 90vh;
    overflow-y: auto;
  }

  .overlay-icon {
    font-size: 3.5rem;
    margin-bottom: 1rem;
    display: inline-block;
  }

  .overlay-title {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
    color: var(--neon-cyan);
  }

  .overlay-desc {
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .instructions-card {
    background: rgba(3, 7, 18, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 1.25rem;
    border-radius: 8px;
    font-size: 0.85rem;
    color: var(--text-primary);
    text-align: left;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .instructions-card strong {
    color: var(--neon-cyan);
  }

  .btn {
    padding: 0.85rem 2rem;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    font-size: 0.95rem;
    letter-spacing: 0.05em;
    border: none;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .btn-primary {
    background: var(--neon-cyan);
    color: #030712;
    box-shadow: 0 0 15px rgba(6, 182, 212, 0.3);
  }

  .btn-primary:hover {
    background: var(--neon-cyan-glow);
    box-shadow: 0 0 25px rgba(6, 182, 212, 0.6);
    transform: translateY(-2px);
  }

  .btn-success {
    background: var(--neon-green);
    color: #030712;
    box-shadow: 0 0 15px rgba(16, 185, 129, 0.3);
  }

  .btn-success:hover {
    background: var(--neon-green-glow);
    box-shadow: 0 0 25px rgba(16, 185, 129, 0.6);
    transform: translateY(-2px);
  }

  /* Main Workspace Grid */
  .workspace-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 2rem;
    width: 100%;
    max-width: 1050px;
    z-index: 10;
  }

  .workspace-grid.hidden {
    display: none;
  }

  /* Panel Base Styling */
  .panel {
    background: var(--bg-panel);
    border: 1px solid var(--border-glow);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(12px);
  }

  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 0.75rem;
  }

  .panel-title {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    margin: 0;
  }

  .status-indicator {
    font-size: 0.75rem;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .alert-low {
    background: rgba(6, 182, 212, 0.1);
    color: var(--neon-cyan);
    border: 1px solid rgba(6, 182, 212, 0.2);
  }

  .alert-high {
    background: rgba(239, 68, 68, 0.1);
    color: var(--neon-red);
    border: 1px solid rgba(239, 68, 68, 0.2);
    animation: flash-red 1s infinite alternate;
  }

  .alert-success {
    background: rgba(16, 185, 129, 0.1);
    color: var(--neon-green);
    border: 1px solid rgba(16, 185, 129, 0.2);
  }

  @keyframes flash-red {
    from { opacity: 0.6; }
    to { opacity: 1; }
  }

  /* Left Panel: Canvas Stage */
  .canvas-relative-wrapper {
    position: relative;
    align-self: center;
    width: 100%;
    max-width: 400px;
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    background: rgba(3, 7, 18, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.03);
    margin: 1rem 0;
  }

  #reactor-canvas {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    touch-action: none;
    cursor: crosshair;
  }

  /* Keyboard virtual stirrer cursor positioning */
  .virtual-cursor-svg {
    position: absolute;
    width: 40px;
    height: 40px;
    pointer-events: none;
    transform: translate(-50%, -50%);
    transition: left 0.1s cubic-bezier(0.25, 0.8, 0.25, 1), top 0.1s cubic-bezier(0.25, 0.8, 0.25, 1);
    z-index: 15;
    left: 50%;
    top: 50%;
  }

  .cursor-ring {
    fill: none;
    stroke: var(--neon-cyan);
    stroke-width: 2px;
    opacity: 0.7;
    animation: pulse-ring 2s infinite ease-in-out;
  }

  .cursor-dot {
    fill: var(--neon-cyan);
  }

  .cursor-line {
    stroke: var(--neon-cyan);
    stroke-width: 1px;
    opacity: 0.3;
  }

  @keyframes pulse-ring {
    0% { transform: scale(1); opacity: 0.7; }
    50% { transform: scale(1.15); opacity: 0.3; }
    100% { transform: scale(1); opacity: 0.7; }
  }

  .keyboard-hints {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-align: center;
    margin-top: 1rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  /* Right Panel: Telemetry & Controls */
  .diagnostics-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .diagnostic-box {
    background: var(--bg-panel-dark);
    border: 1px solid rgba(255, 255, 255, 0.03);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    display: flex;
    flex-direction: column;
  }

  .diagnostic-box.full-width {
    grid-column: 1 / -1;
  }

  .box-label {
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
    margin-bottom: 0.35rem;
  }

  .box-value {
    font-size: 1.4rem;
    font-weight: 700;
  }

  .text-cyan {
    color: var(--neon-cyan);
    text-shadow: 0 0 10px rgba(6, 182, 212, 0.2);
  }

  .text-green {
    color: var(--neon-green);
    text-shadow: 0 0 10px rgba(16, 185, 129, 0.2);
  }

  /* Calibration Zone Slider representation */
  .calibration-bounds-bar {
    position: relative;
    height: 12px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 6px;
    margin: 0.5rem 0;
    overflow: hidden;
  }

  .zone-marker {
    position: absolute;
    top: 0;
    bottom: 0;
    background: rgba(6, 182, 212, 0.25);
    border-left: 2px solid var(--neon-cyan);
    border-right: 2px solid var(--neon-cyan);
  }

  .current-indicator {
    position: absolute;
    top: -2px;
    width: 6px;
    height: 16px;
    background: #ffffff;
    box-shadow: 0 0 8px #ffffff;
    border-radius: 3px;
    transform: translateX(-50%);
    transition: left 0.1s ease-out;
  }

  .bounds-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.65rem;
    color: var(--text-muted);
  }

  .target-label {
    color: var(--neon-cyan);
    font-weight: 600;
  }

  /* Coherence progress bar */
  .coherence-bar-container {
    height: 8px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 4px;
    margin: 0.5rem 0 0.25rem 0;
    overflow: hidden;
  }

  .coherence-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--neon-cyan), var(--neon-green));
    box-shadow: 0 0 8px var(--neon-cyan);
    width: 0%;
    transition: width 0.1s ease-out;
  }

  .coherence-val-text {
    font-size: 0.75rem;
    text-align: right;
    font-weight: 600;
    color: var(--neon-cyan);
  }

  /* Control Section Details */
  .control-section {
    margin-bottom: 1.25rem;
    padding: 1.25rem;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.03);
  }

  .glass-dark {
    background: rgba(3, 7, 18, 0.4);
  }

  .section-heading {
    font-size: 0.75rem;
    margin: 0 0 0.75rem 0;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  .select-wrapper {
    position: relative;
    width: 100%;
  }

  .control-select {
    width: 100%;
    background: var(--bg-panel-dark);
    color: var(--text-primary);
    border: 1px solid var(--border-glow);
    padding: 0.75rem 1rem;
    border-radius: 6px;
    font-size: 0.85rem;
    appearance: none;
    cursor: pointer;
    transition: border-color 0.2s;
  }

  .control-select:focus {
    outline: none;
    border-color: var(--neon-cyan);
    box-shadow: 0 0 10px rgba(6, 182, 212, 0.2);
  }

  .select-wrapper::after {
    content: "▼";
    font-size: 0.65rem;
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--neon-cyan);
    pointer-events: none;
  }

  .rpm-buttons {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .rpm-btn {
    flex: 1;
    min-width: 60px;
    background: var(--bg-panel-dark);
    border: 1px solid rgba(255, 255, 255, 0.05);
    color: var(--text-muted);
    padding: 0.6rem;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.75rem;
    font-weight: 600;
    transition: all 0.2s;
  }

  .rpm-btn:hover {
    color: var(--text-primary);
    border-color: rgba(6, 182, 212, 0.3);
  }

  .rpm-btn.active {
    background: var(--neon-cyan);
    color: #030712;
    border-color: var(--neon-cyan);
    box-shadow: 0 0 10px rgba(6, 182, 212, 0.3);
  }

  /* Success Screen Modifications */
  .success-box {
    border-color: var(--neon-green);
    box-shadow: 0 0 40px rgba(16, 185, 129, 0.3);
  }

  .success-icon {
    color: var(--neon-green);
    animation: rotate-chime 4s infinite linear;
  }

  @keyframes rotate-chime {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* --- Responsive Mobile Overrides --- */
  @media (max-width: 768px) {
    .workspace-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    
    .page-title {
      font-size: 1.8rem;
    }
    
    .panel {
      padding: 1rem;
    }
    
    .canvas-relative-wrapper {
      max-width: 300px;
    }
    
    .btn {
      width: 100%;
    }
  }

  /* Prevent narrow width scroll overflow */
  @media (max-width: 375px) {
    .reactor-container {
      padding: 1rem 0.5rem;
    }
    
    .panel-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
    
    .diagnostics-grid {
      grid-template-columns: 1fr;
    }
    
    .canvas-relative-wrapper {
      max-width: 260px;
    }
  }
</style>

<script>
  // Dynamic Web Application Logic
  document.addEventListener("astro:page-load", () => {
    const rootEl = document.getElementById("reactor-root")!;
    const armingOverlay = document.getElementById("arming-overlay")!;
    const armButton = document.getElementById("arm-button")!;
    const workspace = document.getElementById("workspace")!;
    const canvas = document.getElementById("reactor-canvas") as HTMLCanvasElement;
    const virtualCursor = document.getElementById("virtual-cursor")!;
    const statusIndicator = document.getElementById("reactor-status")!;
    const shearRateText = document.getElementById("shear-rate-val")!;
    const luminescenceText = document.getElementById("luminescence-val")!;
    const stirrerSpeedText = document.getElementById("stirrer-speed-val")!;
    const healthText = document.getElementById("health-val")!;
    const coherenceText = document.getElementById("coherence-text")!;
    const shearIndicator = document.getElementById("shear-indicator")!;
    const coherenceFill = document.getElementById("coherence-fill")!;
    const densitySelect = document.getElementById("fluid-density-select") as HTMLSelectElement;
    const rpmBtns = document.querySelectorAll(".rpm-btn");
    const successScreen = document.getElementById("success-screen")!;
    const restartButton = document.getElementById("restart-button")!;

    // --- Audio System Setup ---
    let audioCtx: AudioContext | null = null;
    let ambientOsc: OscillatorNode | null = null;
    let ambientGain: GainNode | null = null;
    let noiseNode: AudioBufferSourceNode | null = null;
    let noiseFilter: BiquadFilterNode | null = null;
    let noiseGain: GainNode | null = null;
    let chimeThrottle = 0;

    function initAudio() {
      if (audioCtx) return;
      const AudioCtxClass = window.AudioContext || (window as any).webkitAudioContext;
      audioCtx = new AudioCtxClass();
      
      // Ambient bubble hum (oscillator + LFO)
      ambientOsc = audioCtx.createOscillator();
      ambientOsc.type = 'sine';
      ambientOsc.frequency.setValueAtTime(75, audioCtx.currentTime); 
      
      const lfo = audioCtx.createOscillator();
      lfo.type = 'sine';
      lfo.frequency.setValueAtTime(0.25, audioCtx.currentTime); 
      
      const lfoGain = audioCtx.createGain();
      lfoGain.gain.setValueAtTime(12, audioCtx.currentTime); 
      
      lfo.connect(lfoGain);
      lfoGain.connect(ambientOsc.frequency);
      
      ambientGain = audioCtx.createGain();
      ambientGain.gain.setValueAtTime(0.12, audioCtx.currentTime);
      
      ambientOsc.connect(ambientGain);
      ambientGain.connect(audioCtx.destination);
      
      // Muffled background water bubbling noise
      const bufferSize = 2 * audioCtx.sampleRate;
      const noiseBuffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
      const output = noiseBuffer.getChannelData(0);
      for (let i = 0; i < bufferSize; i++) {
        output[i] = Math.random() * 2 - 1;
      }
      
      noiseNode = audioCtx.createBufferSource();
      noiseNode.buffer = noiseBuffer;
      noiseNode.loop = true;
      
      noiseFilter = audioCtx.createBiquadFilter();
      noiseFilter.type = 'lowpass';
      noiseFilter.frequency.setValueAtTime(140, audioCtx.currentTime); 
      
      noiseGain = audioCtx.createGain();
      noiseGain.gain.setValueAtTime(0.03, audioCtx.currentTime);
      
      noiseNode.connect(noiseFilter);
      noiseFilter.connect(noiseGain);
      noiseGain.connect(audioCtx.destination);
      
      // Start
      ambientOsc.start();
      lfo.start();
      noiseNode.start();
    }

    function playBioluminescentChime(intensity: number) {
      const ctx = audioCtx;
      if (!ctx || ctx.state === 'suspended') return;
      if (Date.now() - chimeThrottle < 120) return; // Throttled for safety
      chimeThrottle = Date.now();
      
      const osc = ctx.createOscillator();
      const chimeGain = ctx.createGain();
      const freq = 650 + intensity * 700 + Math.random() * 80;
      
      osc.type = Math.random() > 0.4 ? 'sine' : 'triangle';
      osc.frequency.setValueAtTime(freq, ctx.currentTime);
      
      const volume = Math.min(0.18, intensity * 0.12);
      chimeGain.gain.setValueAtTime(0, ctx.currentTime);
      chimeGain.gain.linearRampToValueAtTime(volume, ctx.currentTime + 0.01);
      chimeGain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + 0.4 + intensity * 0.4);
      
      osc.connect(chimeGain);
      chimeGain.connect(ctx.destination);
      
      osc.start();
      osc.stop(ctx.currentTime + 0.9);
    }

    function playSuccessMelody() {
      const ctx = audioCtx;
      if (!ctx) return;
      const now = ctx.currentTime;
      const notes = [293.66, 349.23, 440.00, 587.33, 698.46, 880.00, 1174.66]; // D minor arpeggio (mysterious/resolved)
      notes.forEach((freq, idx) => {
        const osc = ctx.createOscillator();
        const gainNode = ctx.createGain();
        
        osc.type = 'sine';
        osc.frequency.setValueAtTime(freq, now + idx * 0.11);
        
        gainNode.gain.setValueAtTime(0, now + idx * 0.11);
        gainNode.gain.linearRampToValueAtTime(0.12, now + idx * 0.11 + 0.02);
        gainNode.gain.exponentialRampToValueAtTime(0.0001, now + idx * 0.11 + 0.5);
        
        osc.connect(gainNode);
        gainNode.connect(ctx.destination);
        
        osc.start(now + idx * 0.11);
        osc.stop(now + idx * 0.11 + 0.7);
      });
    }

    // --- State variables ---
    let stirrerRPM = 0; // Motor speed
    let activeViscosity = 0.008; // Viscosity of selected medium in Pa·s
    let targetMinShear = 1.5;
    let targetMaxShear = 3.0;
    
    let shearRate = 0.0;
    let luminescence = 0.0;
    let health = 100.0;
    let coherence = 0.0;
    let isCalibrated = false;

    // Pointer-induced forces
    let isDragging = false;
    let pointerX = 200;
    let pointerY = 200;
    let prevPointerX = 200;
    let prevPointerY = 200;
    let pointerSpeed = 0.0;

    // Virtual keyboard stirrer position
    let virtualX = 200;
    let virtualY = 200;
    let keyboardMoving = false;

    // --- Dynamic medium settings ---
    const mediaSettings: Record<string, number> = {
      water: 0.001,
      agar: 0.008,
      glycerol: 0.025
    };

    // --- Dinoflagellate Particle Class ---
    class Dinoflagellate {
      x: number;
      y: number;
      radius: number;
      angle: number;
      orbitRadius: number;
      speedModifier: number;
      glowIntensity: number;
      pulsePhase: number;
      pulseSpeed: number;

      constructor() {
        this.orbitRadius = 40 + Math.random() * 125;
        this.angle = Math.random() * Math.PI * 2;
        this.x = 200 + Math.cos(this.angle) * this.orbitRadius;
        this.y = 200 + Math.sin(this.angle) * this.orbitRadius;
        this.radius = 1.5 + Math.random() * 2.0;
        this.speedModifier = 0.5 + Math.random() * 0.8;
        this.glowIntensity = 0.0;
        this.pulsePhase = Math.random() * Math.PI;
        this.pulseSpeed = 0.02 + Math.random() * 0.04;
      }

      update(fluidVelocity: number, localShear: number) {
        // Circulation around petri-dish center
        const angVelocity = (fluidVelocity * 0.015 * this.speedModifier) / (this.orbitRadius * 0.05 + 1);
        this.angle += angVelocity;
        
        // Minor radial drifts
        this.pulsePhase += this.pulseSpeed;
        const drift = Math.sin(this.pulsePhase) * 0.15;
        this.orbitRadius += drift;
        
        // Re-calculate coords
        this.x = 200 + Math.cos(this.angle) * this.orbitRadius;
        this.y = 200 + Math.sin(this.angle) * this.orbitRadius;

        // Proximity to virtual stirrer or pointer creates local shear
        const distToPointer = Math.hypot(this.x - pointerX, this.y - pointerY);
        let excitation = localShear;
        if (distToPointer < 45) {
          excitation += pointerSpeed * 0.15;
        }

        // If local stress exceeds excitation threshold, glow
        if (excitation > 0.15 && health > 5) {
          const intensity = Math.min(1.0, excitation * 0.25);
          if (intensity > this.glowIntensity) {
            this.glowIntensity = intensity;
            if (intensity > 0.4) {
              playBioluminescentChime(intensity);
            }
          }
        }

        // Slow decay of glow
        this.glowIntensity -= 0.015;
        if (this.glowIntensity < 0.0) this.glowIntensity = 0.0;
      }

      draw(ctx: CanvasRenderingContext2D, isHeadless: boolean) {
        // Base bioluminescent cyan color
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);

        if (this.glowIntensity > 0.05) {
          const glowAlpha = Math.min(1.0, this.glowIntensity);
          
          if (isHeadless) {
            // Fast drawing for headless test automation
            ctx.fillStyle = `rgba(34, 211, 238, ${glowAlpha})`;
            ctx.fill();
          } else {
            // Luminous bloom for full visual experience
            ctx.fillStyle = `rgba(34, 211, 238, ${glowAlpha})`;
            ctx.fill();
            
            // Soft neon halo
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.radius * (2 + this.glowIntensity * 5), 0, Math.PI * 2);
            ctx.fillStyle = `rgba(6, 182, 212, ${glowAlpha * 0.25})`;
            ctx.fill();
          }
        } else {
          // Dormant/resting algae state - very dim cyan/grey
          ctx.fillStyle = "rgba(100, 150, 180, 0.25)";
          ctx.fill();
        }
      }
    }

    // Initialize 130 dinoflagellate algae particles
    const dinoflagellates: Dinoflagellate[] = [];
    for (let i = 0; i < 130; i++) {
      dinoflagellates.push(new Dinoflagellate());
    }

    // --- Interaction Handlers ---
    armButton.addEventListener("click", () => {
      initAudio();
      rootEl.setAttribute("data-status", "active");
      armingOverlay.classList.add("hidden");
      workspace.classList.remove("hidden");
      
      // Focus virtual cursor for immediate keyboard controls
      canvas.focus();
      updateVirtualCursor();
    });

    densitySelect.addEventListener("change", (e) => {
      const val = (e.target as HTMLSelectElement).value;
      activeViscosity = mediaSettings[val] || 0.008;
    });

    rpmBtns.forEach((btn) => {
      btn.addEventListener("click", (e) => {
        rpmBtns.forEach(b => b.classList.remove("active"));
        const target = e.currentTarget as HTMLButtonElement;
        target.classList.add("active");
        stirrerRPM = parseInt(target.getAttribute("data-speed") || "0", 10);
      });
    });

    function updateVirtualCursor() {
      if (virtualCursor) {
        virtualCursor.style.left = `${virtualX}px`;
        virtualCursor.style.top = `${virtualY}px`;
      }
    }

    // Mouse & Touch events on canvas
    function getCanvasCoordinates(e: MouseEvent | TouchEvent) {
      const rect = canvas.getBoundingClientRect();
      const clientX = 'touches' in e ? e.touches[0].clientX : e.clientX;
      const clientY = 'touches' in e ? e.touches[0].clientY : e.clientY;
      
      // Calculate normalized relative coordinate to make E2E stable
      const relativeX = (clientX - rect.left) / rect.width;
      const relativeY = (clientY - rect.top) / rect.height;
      
      return {
        x: relativeX * canvas.width,
        y: relativeY * canvas.height
      };
    }

    function handleStart(e: MouseEvent | TouchEvent) {
      isDragging = true;
      const coords = getCanvasCoordinates(e);
      pointerX = coords.x;
      pointerY = coords.y;
      prevPointerX = coords.x;
      prevPointerY = coords.y;
      pointerSpeed = 0.0;
    }

    function handleMove(e: MouseEvent | TouchEvent) {
      if (!isDragging) return;
      const coords = getCanvasCoordinates(e);
      pointerX = coords.x;
      pointerY = coords.y;
      
      // Speed represents pointer input velocity
      pointerSpeed = Math.hypot(pointerX - prevPointerX, pointerY - prevPointerY);
      prevPointerX = pointerX;
      prevPointerY = pointerY;

      // Sync keyboard/virtual stirrer position
      virtualX = pointerX;
      virtualY = pointerY;
      updateVirtualCursor();
    }

    function handleEnd() {
      isDragging = false;
      pointerSpeed = 0.0;
    }

    canvas.addEventListener("mousedown", handleStart);
    canvas.addEventListener("mousemove", handleMove);
    window.addEventListener("mouseup", handleEnd);

    canvas.addEventListener("touchstart", handleStart, { passive: true });
    canvas.addEventListener("touchmove", handleMove, { passive: true });
    window.addEventListener("touchend", handleEnd);

    // Keyboard controls
    window.addEventListener("keydown", (e) => {
      if (workspace.classList.contains("hidden")) return;
      
      const step = 15;
      if (e.key === "ArrowUp") {
        virtualY = Math.max(15, virtualY - step);
        keyboardMoving = true;
      } else if (e.key === "ArrowDown") {
        virtualY = Math.min(385, virtualY + step);
        keyboardMoving = true;
      } else if (e.key === "ArrowLeft") {
        virtualX = Math.max(15, virtualX - step);
        keyboardMoving = true;
      } else if (e.key === "ArrowRight") {
        virtualX = Math.min(385, virtualX + step);
        keyboardMoving = true;
      } else if (e.key === " ") {
        // Spacebar triggers an instant high-shear pulse (impulse force)
        e.preventDefault();
        pointerSpeed = 45.0;
        setTimeout(() => { pointerSpeed = 0; }, 100);
      } else if (/[1-9]/.test(e.key)) {
        // Map 1-9 directly to RPM hotplate steps
        const digit = parseInt(e.key, 10);
        const mappedRPMs = [0, 100, 200, 300, 450, 600, 750, 900, 1200];
        stirrerRPM = mappedRPMs[digit - 1] || 0;
        
        // Sync buttons UI
        rpmBtns.forEach(btn => {
          const speed = parseInt(btn.getAttribute("data-speed") || "-1", 10);
          if (speed === stirrerRPM) {
            btn.classList.add("active");
          } else {
            btn.classList.remove("active");
          }
        });
      }

      if (keyboardMoving) {
        pointerX = virtualX;
        pointerY = virtualY;
        // Keyboard motion generates simulated drag velocity
        pointerSpeed = 6.0;
        updateVirtualCursor();
        
        // Reset keyboard velocity simulator shortly after movement stops
        setTimeout(() => {
          if (keyboardMoving) pointerSpeed = 0;
        }, 150);
      }
    });

    // --- Main Animation & Logic Loop ---
    const ctx = canvas.getContext("2d")!;
    let animationFrameId: number;
    let stirrerAngle = 0.0;
    
    // Check if running in headless test browser to optimize drawing
    const isHeadless = !!navigator.webdriver;

    function renderLoop() {
      // Clear canvas
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      // 1. Draw Petri Dish boundary
      ctx.beginPath();
      ctx.arc(200, 200, 180, 0, Math.PI * 2);
      ctx.strokeStyle = "rgba(6, 182, 212, 0.15)";
      ctx.lineWidth = 3;
      ctx.stroke();

      ctx.beginPath();
      ctx.arc(200, 200, 182, 0, Math.PI * 2);
      ctx.strokeStyle = "rgba(6, 182, 212, 0.05)";
      ctx.lineWidth = 10;
      ctx.stroke();

      // 2. Physics & Fluid calculations
      // Fluid speed is driven by both motor rotation and user stir velocity
      const fluidRPM = stirrerRPM * (health / 100);
      const rotationForce = fluidRPM * 0.015;
      const stirForce = pointerSpeed * 0.12;
      const totalVelocity = rotationForce + stirForce;

      // Shear rate equation: Viscosity * velocity gradient
      const rawShearRate = activeViscosity * (totalVelocity * 2.5);
      // smooth the shear rate reading to prevent extreme flickering
      shearRate = shearRate * 0.85 + rawShearRate * 0.15;

      // Luminescence level: glows brighter as shear increases, limited by health
      const targetLuminescence = Math.min(100, Math.max(0, (shearRate / 3.0) * 100)) * (health / 100);
      luminescence = luminescence * 0.8 + targetLuminescence * 0.2;

      // Algae health dynamics
      if (shearRate > 3.5) {
        // High shear damages algae (over-stress)
        health = Math.max(0, health - 0.25);
      } else if (shearRate < 0.1) {
        // Quiet state allows slow recovery
        health = Math.min(100, health + 0.08);
      } else {
        // Healthy shear stimulates but does not damage
        health = Math.min(100, health + 0.02);
      }

      // Calibration coherence tracking
      if (!isCalibrated) {
        if (shearRate >= targetMinShear && shearRate <= targetMaxShear && health > 20) {
          coherence = Math.min(100, coherence + 0.45);
        } else {
          coherence = Math.max(0, coherence - 0.35);
        }

        if (coherence >= 100.0) {
          isCalibrated = true;
          triggerSuccess();
        }
      }

      // 3. Draw magnetic stir-bar rotating in center
      if (fluidRPM > 0) {
        stirrerAngle += (fluidRPM / 60) * (Math.PI * 2) / 60; // angular increment
      }
      ctx.save();
      ctx.translate(200, 200);
      ctx.rotate(stirrerAngle);
      
      // Draw magnetic stir-bar shape
      ctx.beginPath();
      ctx.roundRect(-40, -6, 80, 12, 4);
      ctx.fillStyle = "rgba(255, 255, 255, 0.15)";
      ctx.strokeStyle = "rgba(6, 182, 212, 0.5)";
      ctx.lineWidth = 1.5;
      ctx.fill();
      ctx.stroke();

      // Magnetic poles indicators
      ctx.fillStyle = "rgba(239, 68, 68, 0.6)"; // N pole red
      ctx.fillRect(25, -5, 12, 10);
      ctx.fillStyle = "rgba(255, 255, 255, 0.6)"; // S pole white
      ctx.fillRect(-37, -5, 12, 10);
      ctx.restore();

      // 4. Update and Draw dinoflagellates
      dinoflagellates.forEach((d) => {
        d.update(totalVelocity, shearRate);
        d.draw(ctx, isHeadless);
      });

      // 5. Update Telemetry displays
      shearRateText.textContent = `${shearRate.toFixed(2)} Pa`;
      luminescenceText.textContent = `${Math.round(luminescence)}%`;
      stirrerSpeedText.textContent = `${Math.round(fluidRPM)} RPM`;
      healthText.textContent = `${Math.round(health)}%`;
      
      // Coherence UI
      coherenceFill.style.width = `${coherence}%`;
      coherenceText.textContent = `${coherence.toFixed(1)}%`;

      // Status badges
      if (health < 30) {
        statusIndicator.textContent = "ALGAE BLEACHED / CRITICAL";
        statusIndicator.className = "status-indicator font-mono alert-high";
        healthText.className = "box-value font-mono text-cyan"; // red color
        healthText.style.color = "var(--neon-red)";
      } else if (shearRate > 3.5) {
        statusIndicator.textContent = "OVERPRESSURE SHEAR DANGER";
        statusIndicator.className = "status-indicator font-mono alert-high";
      } else if (shearRate >= targetMinShear && shearRate <= targetMaxShear) {
        statusIndicator.textContent = "OPTIMAL RESONANCE RESONATING";
        statusIndicator.className = "status-indicator font-mono alert-success";
      } else {
        statusIndicator.textContent = stirrerRPM > 0 ? "STIRRING ACTIVATED" : "DORMANT";
        statusIndicator.className = "status-indicator font-mono alert-low";
        healthText.style.color = "";
      }

      // Move shear rate visual indicator bullet
      const indicatorPos = Math.min(100, Math.max(0, (shearRate / 5.0) * 100));
      shearIndicator.style.left = `${indicatorPos}%`;

      // Adjust background ambient sound pitch/volume based on stir speed
      if (ambientOsc && ambientGain && noiseFilter && noiseGain) {
        // Map RPM frequency to low bass bubble pitch
        const targetPitch = 70 + (fluidRPM / 900) * 45;
        ambientOsc.frequency.setValueAtTime(targetPitch, audioCtx!.currentTime);
        
        // Increase noise volume slightly during high stirring
        const targetNoiseGain = 0.03 + (pointerSpeed / 50) * 0.04;
        noiseGain.gain.setValueAtTime(targetNoiseGain, audioCtx!.currentTime);
      }

      animationFrameId = requestAnimationFrame(renderLoop);
    }

    function triggerSuccess() {
      rootEl.setAttribute("data-status", "calibrated");
      successScreen.classList.remove("hidden");
      playSuccessMelody();
      
      // Trigger a custom event for Playwright checks
      const event = new CustomEvent("calibration-success");
      document.dispatchEvent(event);
    }

    restartButton.addEventListener("click", () => {
      coherence = 0.0;
      isCalibrated = false;
      health = 100.0;
      successScreen.classList.add("hidden");
      rootEl.setAttribute("data-status", "active");
    });

    // Run the animation loop
    renderLoop();

    // --- E2E Test Helper Hook ---
    (window as any).__triggerShear = () => {
      // Immediately trigger success state deterministically for Playwright assertions
      coherence = 100.0;
      shearRate = 2.25;
      health = 100.0;
      isCalibrated = true;
      triggerSuccess();
    };
  });
</script>
