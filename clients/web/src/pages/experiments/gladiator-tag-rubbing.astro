---
import Base from "@layouts/Base.astro"
---

<Base title="Tessera Gladiatoria // Roman Gladiator Tag Decryption">
  <div class="gladiator-container" id="gladiator-tag-root" data-status="muddy" data-faces-cleaned="0">
    <!-- Retro CRT effects -->
    <div class="crt-overlay" aria-hidden="true"></div>
    <div class="crt-flicker" aria-hidden="true"></div>

    <!-- Header -->
    <header class="excavation-header">
      <h1 class="page-title text-gradient">Tessera Gladiatoria</h1>
      <p class="subtitle font-mono">HS2 EXCAVATION LAB // ARTIFACT CLEANING & CRYPTANALYSIS DESK</p>
    </header>

    <!-- Arming Overlay for user gesture initialization of AudioContext -->
    <div id="arming-overlay" class="overlay glass">
      <div class="overlay-content">
        <div class="overlay-icon">🏺</div>
        <h2 class="overlay-title font-mono">LAB DATA-LINK SEQUENCE</h2>
        <p class="overlay-desc">
          Archaeologists on the HS2 rail construction corridor have unearthed a rare four-sided bone gladiator's tag (tessera gladiatoria) caked in clay. As the lab assistant, you must clean the four faces of the bone prism and decipher the inscriptions.
        </p>
        <div class="alert alert-info font-mono text-left">
          <strong>LAB INSTRUCTIONS:</strong><br/>
          1. <strong>Clean the Tag:</strong> Use your mouse, touchscreen, or keyboard arrow keys to scrub away mud from the current bone face.<br/>
          2. <strong>Rotate the Prism:</strong> Clean all 4 faces by flipping the block left or right.<br/>
          3. <strong>Synthesizer feedback:</strong> Friction generated by scrubbing synthesizes gravelly rubbing noise. Uncovering letters triggers ancient resonance and alerts the decryption terminal.<br/>
          4. <strong>Cryptanalysis:</strong> Translate the inscriptions to decode the gladiator's release terms.
        </div>
        <button id="arm-button" class="btn btn-primary font-mono">
          Activate Excavation Desk & Audio
        </button>
      </div>
    </div>

    <!-- Main Workspace -->
    <div class="workspace-grid hidden" id="workspace">
      <!-- Left Panel: Artifact Cleaning Stage -->
      <div class="panel stage-panel glass">
        <div class="panel-header">
          <h2 class="panel-title font-mono">I. Specimen Stage</h2>
          <span class="status-indicator font-mono" id="cleanliness-badge">0% CLEANED</span>
        </div>

        <div class="canvas-perspective-wrapper">
          <div class="prism-container" id="prism-container">
            <!-- Left side visual shadow -->
            <div class="canvas-shadow-overlay"></div>
            
            <div class="prism-3d-card" id="prism-card">
              <canvas id="rubbing-canvas" width="400" height="200"></canvas>
            </div>
            
            <!-- Virtual crosshair for keyboard focus -->
            <svg id="virtual-cursor" class="virtual-cursor-svg" viewBox="0 0 40 40" aria-hidden="true">
              <circle cx="20" cy="20" r="12" class="cursor-ring" />
              <line x1="20" y1="0" x2="20" y2="40" class="cursor-line" />
              <line x1="0" y1="20" x2="40" y2="20" class="cursor-line" />
            </svg>
          </div>
        </div>

        <!-- Rotate controls and 3D preview -->
        <div class="rotation-bar font-mono">
          <button id="btn-rotate-prev" class="btn-arrow" title="Rotate Left (A key)">◀</button>
          <div class="prism-status-readout">
            FACE: <span id="face-index-display" class="text-cyan">I / IV</span>
          </div>
          <button id="btn-rotate-next" class="btn-arrow" title="Rotate Right (D key)">▶</button>
        </div>

        <!-- Mini 3D-Prism visual indicator -->
        <div class="prism-indicator-row">
          <div class="indicator-face" id="ind-face-0" data-state="muddy">I</div>
          <div class="indicator-face" id="ind-face-1" data-state="muddy">II</div>
          <div class="indicator-face" id="ind-face-2" data-state="muddy">III</div>
          <div class="indicator-face" id="ind-face-3" data-state="muddy">IV</div>
        </div>

        <div class="keyboard-hint font-mono">
          [ARROW KEYS] Steer Scrubbing Brush // [A / D] Flip Bone Tag Face
        </div>
      </div>

      <!-- Right Panel: Diagnostics & Decryption Console -->
      <div class="panel control-panel glass" id="decoder-panel">
        <h2 class="panel-title font-mono">II. Decryption Console</h2>

        <div class="telemetry-grid">
          <div class="telemetry-box">
            <span class="box-label font-mono">ARTIFACT AGE</span>
            <div class="box-value font-mono text-cyan">~1,962 Yrs</div>
          </div>
          <div class="telemetry-box">
            <span class="box-label font-mono">TOTAL CLEANLINESS</span>
            <div class="box-value font-mono text-gold" id="total-cleanliness-display">0.0%</div>
          </div>
          <div class="telemetry-box full-width">
            <span class="box-label font-mono">CLEANING COMPLETION LEVEL</span>
            <div class="progress-bar-container">
              <div class="progress-bar-fill" id="total-progress-bar"></div>
            </div>
          </div>
        </div>

        <!-- Decryption Panel Form -->
        <div class="decryption-section">
          <span class="section-title font-mono">LATIN INSCRIPTION CRYPTANALYSIS:</span>
          
          <div class="translation-grid">
            <!-- Face 1 -->
            <div class="translation-row">
              <div class="inscription-part">
                <span class="font-mono text-gold">I: SUBA.GENTVS</span>
              </div>
              <div class="select-wrapper">
                <select id="select-gladiator" class="decryption-select" disabled>
                  <option value="">-- [Locked: Clean Face I] --</option>
                  <option value="freeman">1. Freeman Champion</option>
                  <option value="subagent">2. Subagent / Intern</option>
                  <option value="general">3. General Gladiator</option>
                </select>
              </div>
            </div>

            <!-- Face 2 -->
            <div class="translation-row">
              <div class="inscription-part">
                <span class="font-mono text-gold">II: DEEP.MINDVS</span>
              </div>
              <div class="select-wrapper">
                <select id="select-owner" class="decryption-select" disabled>
                  <option value="">-- [Locked: Clean Face II] --</option>
                  <option value="caesar">1. Emperor Caesar</option>
                  <option value="deepmind">2. DeepMind / Management</option>
                  <option value="senate">3. Roman Senate</option>
                </select>
              </div>
            </div>

            <!-- Face 3 -->
            <div class="translation-row">
              <div class="inscription-part">
                <span class="font-mono text-gold">III: SP VII K.IVN</span>
              </div>
              <div class="select-wrapper">
                <select id="select-sprint" class="decryption-select" disabled>
                  <option value="">-- [Locked: Clean Face III] --</option>
                  <option value="sp7">1. Story Point 7 (Sprint Approved)</option>
                  <option value="senator">2. Senatorial Sponsor</option>
                  <option value="spear">3. Spear Fight #7</option>
                </select>
              </div>
            </div>

            <!-- Face 4 -->
            <div class="translation-row">
              <div class="inscription-part">
                <span class="font-mono text-gold">IV: J.S. ET C.P.P.</span>
              </div>
              <div class="select-wrapper">
                <select id="select-consuls" class="decryption-select" disabled>
                  <option value="">-- [Locked: Clean Face IV] --</option>
                  <option value="js-cpp">1. JavaScript & C++ Consuls</option>
                  <option value="jupiter">2. Jupiter & Ceres Priests</option>
                  <option value="jason">3. Jason & Argonaut Captains</option>
                </select>
              </div>
            </div>
          </div>
        </div>

        <div class="decryption-status-actions">
          <div class="translation-helper font-mono" id="decryption-instructions">
            Clean all four faces to enable translation selectors.
          </div>
          <button id="release-btn" class="btn btn-danger font-mono w-full" disabled>
            🔒 RELEASE TO PROD (STORY POINTS MET)
          </button>
        </div>
      </div>
    </div>

    <!-- Success Screen -->
    <div id="success-screen" class="success-screen hidden">
      <div class="success-content glass text-center">
        <div class="success-icon">🏟️</div>
        <h1 class="success-title text-gradient">RELEASED TO PROD</h1>
        <p class="success-desc font-mono">
          Decryption complete. Gladiator <span class="text-cyan">SUBA.GENTVS</span> has met their story point quota under the consuls of <span class="text-cyan">JavaScript</span> and <span class="text-cyan">C++</span>.
        </p>
        <div class="success-alert font-mono">
          "The arena is stabilized. No segfaults. Story points: 7. Deploy successful."
        </div>
        <button id="reset-btn" class="btn btn-primary font-mono mt-4">
          Analyze Another Specimen
        </button>
      </div>
    </div>
  </div>
</Base>

<style>
  :global(body) {
    margin: 0;
    background: #0f0d0c;
    color: #f5f5f4;
    font-family: 'Outfit', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }

  .gladiator-container {
    --bg-dark: #080605;
    --panel-bg: rgba(24, 20, 18, 0.75);
    --border-amber: #d97706;
    --border-copper: #b45309;
    --text-glow-gold: 0 0 8px rgba(217, 119, 6, 0.6);
    --text-glow-cyan: 0 0 8px rgba(6, 182, 212, 0.6);
    
    position: relative;
    min-height: 100vh;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    background: radial-gradient(circle at center, #1c1511 0%, #080605 100%);
    overflow-x: hidden;
  }

  .text-gradient {
    background: linear-gradient(135deg, #fbbf24 0%, #ea580c 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .font-mono {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .text-cyan { color: #22d3ee; }
  .text-gold { color: #fbbf24; }
  .text-danger { color: #ef4444; }

  /* CRT Overlay */
  .crt-overlay {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.3) 50%), linear-gradient(90deg, rgba(239, 68, 68, 0.04), rgba(34, 211, 238, 0.02), rgba(239, 68, 68, 0.04));
    background-size: 100% 4px, 6px 100%;
    z-index: 99;
    pointer-events: none;
  }

  .crt-flicker {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: transparent;
    opacity: 0.1;
    z-index: 98;
    pointer-events: none;
    animation: crt-flicker-anim 0.2s infinite;
  }

  @keyframes crt-flicker-anim {
    0% { background-color: rgba(255, 255, 255, 0.01); }
    50% { background-color: rgba(0, 0, 0, 0.02); }
    100% { background-color: rgba(255, 255, 255, 0.01); }
  }

  .excavation-header {
    text-align: center;
    margin-bottom: 2rem;
    z-index: 10;
  }

  .page-title {
    font-size: 2.5rem;
    font-weight: 800;
    letter-spacing: -0.05em;
    margin-bottom: 0.25rem;
    text-transform: uppercase;
  }

  .subtitle {
    font-size: 0.8rem;
    letter-spacing: 0.25em;
    color: #a8a29e;
  }

  /* Arming Sequence Overlay */
  .overlay {
    position: fixed;
    top: 0; left: 0; width: 100vw; height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 100;
    background: rgba(12, 10, 9, 0.85);
  }

  .glass {
    background: var(--panel-bg);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(180, 83, 9, 0.3);
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.8), inset 0 1px 1px rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-lg);
  }

  .overlay-content {
    max-width: 500px;
    width: 90%;
    padding: 2.5rem;
    text-align: center;
    border-radius: var(--radius-lg);
  }

  .overlay-icon {
    font-size: 3.5rem;
    margin-bottom: 1rem;
    animation: pulse 2s infinite ease-in-out;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 0.9; }
    50% { transform: scale(1.1); opacity: 1; }
  }

  .overlay-title {
    font-size: 1.25rem;
    letter-spacing: 0.15em;
    color: #fbbf24;
    margin-bottom: 1rem;
    text-shadow: var(--text-glow-gold);
  }

  .overlay-desc {
    font-size: 0.95rem;
    color: #d6d3d1;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .alert {
    padding: 1rem;
    border-radius: var(--radius-md);
    font-size: 0.8rem;
    line-height: 1.5;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(217, 119, 6, 0.2);
    background: rgba(120, 53, 4, 0.15);
  }

  .text-left { text-align: left; }

  .btn {
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    font-weight: 700;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.2s ease;
    border: none;
  }

  .btn-primary {
    background: linear-gradient(135deg, #d97706 0%, #b45309 100%);
    color: #f5f5f4;
    box-shadow: 0 4px 12px rgba(180, 83, 9, 0.4);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(180, 83, 9, 0.6);
  }

  .btn-danger {
    background: linear-gradient(135deg, #ef4444 0%, #991b1b 100%);
    color: #f5f5f4;
    box-shadow: 0 4px 12px rgba(153, 27, 27, 0.4);
  }

  .btn-danger:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(153, 27, 27, 0.6);
  }

  .btn-danger:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .w-full { width: 100%; }
  .mt-4 { margin-top: 1rem; }

  /* Workspace Grid */
  .workspace-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 1.5rem;
    width: 100%;
    max-width: 960px;
    margin-top: 1rem;
    z-index: 10;
  }

  @media (max-width: 768px) {
    .workspace-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
      padding: 0 1rem;
    }
  }

  .panel {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    border-radius: var(--radius-lg);
  }

  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    border-bottom: 1px solid rgba(180, 83, 9, 0.2);
    padding-bottom: 0.5rem;
  }

  .panel-title {
    font-size: 1rem;
    letter-spacing: 0.1em;
    color: #fbbf24;
  }

  .status-indicator {
    font-size: 0.8rem;
    font-weight: 700;
    color: #22d3ee;
    text-shadow: var(--text-glow-cyan);
  }

  /* 3D Canvas Perspective Wrapper */
  .canvas-perspective-wrapper {
    position: relative;
    background: #0c0a09;
    border: 1px solid rgba(180, 83, 9, 0.2);
    border-radius: var(--radius-md);
    padding: 1rem;
    display: flex;
    justify-content: center;
    align-items: center;
    perspective: 800px;
    overflow: hidden;
  }

  .prism-container {
    position: relative;
    width: 100%;
    max-width: 400px;
    height: 200px;
    touch-action: none; /* Crucial for preventing scrolling during touch dragging */
  }

  .prism-3d-card {
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
  }

  #rubbing-canvas {
    display: block;
    width: 100%;
    height: 100%;
    background: #e7e5e4;
    cursor: crosshair;
  }

  .canvas-shadow-overlay {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    pointer-events: none;
    z-index: 5;
    background: linear-gradient(90deg, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0) 8%, rgba(0,0,0,0) 92%, rgba(0,0,0,0.5) 100%);
    border-radius: var(--radius-md);
  }

  /* Virtual Keyboard Cursor Overlay */
  .virtual-cursor-svg {
    position: absolute;
    width: 40px;
    height: 40px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 10;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .prism-container:focus-within .virtual-cursor-svg,
  .prism-container:hover .virtual-cursor-svg {
    opacity: 1;
  }

  .cursor-ring {
    fill: none;
    stroke: #22d3ee;
    stroke-width: 2px;
    stroke-dasharray: 4 2;
    animation: spin 8s linear infinite;
  }

  .cursor-line {
    stroke: #22d3ee;
    stroke-width: 1.5px;
    opacity: 0.7;
  }

  @keyframes spin {
    100% { transform: rotate(360deg); }
  }

  /* Rotation bar */
  .rotation-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1rem;
    padding: 0.5rem;
    background: rgba(12, 10, 9, 0.5);
    border-radius: var(--radius-md);
  }

  .btn-arrow {
    background: transparent;
    border: 1px solid rgba(180, 83, 9, 0.4);
    color: #fbbf24;
    font-size: 1rem;
    padding: 0.25rem 1rem;
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: all 0.2s ease;
  }

  .btn-arrow:hover {
    background: rgba(180, 83, 9, 0.2);
    border-color: #fbbf24;
    box-shadow: var(--text-glow-gold);
  }

  .prism-status-readout {
    font-weight: 700;
  }

  /* Prism mini indicator */
  .prism-indicator-row {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .indicator-face {
    width: 24px;
    height: 24px;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 0.7rem;
    font-family: monospace;
    border: 1px solid rgba(180, 83, 9, 0.4);
    border-radius: var(--radius-sm);
    background: rgba(28, 25, 23, 0.6);
    color: #78716c;
    transition: all 0.2s ease;
  }

  .indicator-face[data-state="cleaned"] {
    background: rgba(16, 185, 129, 0.2);
    border-color: #10b981;
    color: #10b981;
    box-shadow: 0 0 6px rgba(16, 185, 129, 0.4);
  }

  .indicator-face.active {
    border-color: #22d3ee;
    color: #22d3ee;
    box-shadow: var(--text-glow-cyan);
  }

  .keyboard-hint {
    font-size: 0.7rem;
    text-align: center;
    color: #78716c;
    margin-top: 1rem;
  }

  /* Right Panel: Decryption */
  .telemetry-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .telemetry-box {
    background: rgba(12, 10, 9, 0.4);
    border: 1px solid rgba(180, 83, 9, 0.15);
    padding: 0.75rem;
    border-radius: var(--radius-md);
  }

  .full-width {
    grid-column: span 2;
  }

  .box-label {
    font-size: 0.65rem;
    color: #a8a29e;
    display: block;
    margin-bottom: 0.25rem;
  }

  .box-value {
    font-size: 1.2rem;
    font-weight: 700;
  }

  .progress-bar-container {
    height: 10px;
    background: #1c1917;
    border-radius: var(--radius-full);
    overflow: hidden;
    position: relative;
    border: 1px solid rgba(180, 83, 9, 0.3);
    margin-top: 0.25rem;
  }

  .progress-bar-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #d97706, #fbbf24);
    border-radius: var(--radius-full);
    transition: width 0.3s ease;
    box-shadow: 0 0 8px rgba(251, 191, 36, 0.5);
  }

  /* Decryption Form Section */
  .decryption-section {
    background: rgba(12, 10, 9, 0.3);
    border: 1px solid rgba(180, 83, 9, 0.15);
    padding: 1.25rem;
    border-radius: var(--radius-md);
    margin-bottom: 1.5rem;
  }

  .section-title {
    font-size: 0.8rem;
    color: #fbbf24;
    display: block;
    margin-bottom: 1rem;
    letter-spacing: 0.05em;
  }

  .translation-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .translation-row {
    display: grid;
    grid-template-columns: 1.2fr 1.8fr;
    align-items: center;
    gap: 0.75rem;
    border-bottom: 1px dashed rgba(180, 83, 9, 0.1);
    padding-bottom: 0.75rem;
  }

  .translation-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .inscription-part {
    font-size: 0.85rem;
    font-weight: bold;
  }

  .select-wrapper {
    position: relative;
  }

  .decryption-select {
    width: 100%;
    background: #1c1917;
    border: 1px solid rgba(180, 83, 9, 0.3);
    color: #d6d3d1;
    padding: 0.4rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: 0.8rem;
    outline: none;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .decryption-select:focus:not(:disabled) {
    border-color: #fbbf24;
    box-shadow: 0 0 6px rgba(251, 191, 36, 0.3);
  }

  .decryption-select:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    background: #0c0a09;
  }

  .decryption-status-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .translation-helper {
    font-size: 0.75rem;
    color: #a8a29e;
    text-align: center;
    line-height: 1.4;
  }

  .hidden {
    display: none !important;
  }

  /* Success Screen Overlay */
  .success-screen {
    position: fixed;
    top: 0; left: 0; width: 100vw; height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 110;
    background: rgba(12, 10, 9, 0.9);
  }

  .success-content {
    max-width: 500px;
    width: 90%;
    padding: 3rem 2.5rem;
    border-radius: var(--radius-lg);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.9);
  }

  .success-icon {
    font-size: 4rem;
    margin-bottom: 1rem;
    filter: drop-shadow(var(--text-glow-gold));
  }

  .success-title {
    font-size: 2.2rem;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .success-desc {
    font-size: 0.95rem;
    color: #d6d3d1;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .success-alert {
    background: rgba(16, 185, 129, 0.15);
    border: 1px solid rgba(16, 185, 129, 0.3);
    padding: 1rem;
    border-radius: var(--radius-md);
    color: #34d399;
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
  }
</style>

<script is:inline>
  // Script runs inside the browser sandbox, using is:inline for compact scripting setup
  (function() {
    // ----------------------------------------------------
    // Sound Engine using Web Audio API
    // ----------------------------------------------------
    let audioCtx = null;
    let mainGain = null;
    let ambientOsc1 = null;
    let ambientOsc2 = null;
    let ambientGain = null;
    
    // Scratching nodes
    let scratchNoiseNode = null;
    let scratchFilterNode = null;
    let scratchGainNode = null;

    function initAudio() {
      if (audioCtx) return;
      
      const AudioCtxClass = window.AudioContext || window.webkitAudioContext;
      audioCtx = new AudioCtxClass();
      
      // Main output gain
      mainGain = audioCtx.createGain();
      mainGain.gain.setValueAtTime(0.3, audioCtx.currentTime);
      mainGain.connect(audioCtx.destination);
      
      // 1. Ambient low-frequency drone (Ancient tomb feel)
      ambientOsc1 = audioCtx.createOscillator();
      ambientOsc2 = audioCtx.createOscillator();
      ambientGain = audioCtx.createGain();
      
      ambientOsc1.type = 'triangle';
      ambientOsc1.frequency.setValueAtTime(73.42, audioCtx.currentTime); // D2
      
      ambientOsc2.type = 'sine';
      ambientOsc2.frequency.setValueAtTime(110.00, audioCtx.currentTime); // A2 (fifth)
      ambientOsc2.detune.setValueAtTime(8, audioCtx.currentTime); // Detuned chorusing
      
      ambientGain.gain.setValueAtTime(0.15, audioCtx.currentTime);
      
      ambientOsc1.connect(ambientGain);
      ambientOsc2.connect(ambientGain);
      
      // Filter for drone warmth
      const ambientFilter = audioCtx.createBiquadFilter();
      ambientFilter.type = 'lowpass';
      ambientFilter.frequency.setValueAtTime(250, audioCtx.currentTime);
      ambientGain.connect(ambientFilter);
      ambientFilter.connect(mainGain);
      
      ambientOsc1.start();
      ambientOsc2.start();
      
      // 2. Scratching gravel noise
      const bufferSize = 2 * audioCtx.sampleRate;
      const noiseBuffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
      const output = noiseBuffer.getChannelData(0);
      for (let i = 0; i < bufferSize; i++) {
        output[i] = Math.random() * 2 - 1;
      }
      
      scratchNoiseNode = audioCtx.createBufferSource();
      scratchNoiseNode.buffer = noiseBuffer;
      scratchNoiseNode.loop = true;
      
      scratchFilterNode = audioCtx.createBiquadFilter();
      scratchFilterNode.type = 'bandpass';
      scratchFilterNode.Q.setValueAtTime(10, audioCtx.currentTime);
      scratchFilterNode.frequency.setValueAtTime(100, audioCtx.currentTime);
      
      scratchGainNode = audioCtx.createGain();
      scratchGainNode.gain.setValueAtTime(0, audioCtx.currentTime); // Silent initially
      
      scratchNoiseNode.connect(scratchFilterNode);
      scratchFilterNode.connect(scratchGainNode);
      scratchGainNode.connect(mainGain);
      
      scratchNoiseNode.start();
    }

    function triggerChime(freqs = [293.66, 440.00, 587.33]) { // D4, A4, D5 chords
      if (!audioCtx) return;
      
      freqs.forEach(freq => {
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        
        osc.type = 'sine';
        osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
        
        gain.gain.setValueAtTime(0.0, audioCtx.currentTime);
        gain.gain.linearRampToValueAtTime(0.1, audioCtx.currentTime + 0.05);
        gain.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + 1.5);
        
        osc.connect(gain);
        gain.connect(mainGain);
        
        osc.start();
        osc.stop(audioCtx.currentTime + 1.6);
      });
    }

    function setScratchVolumeAndFreq(speed, active) {
      if (!audioCtx || !scratchGainNode || !scratchFilterNode) return;
      
      const targetGain = active ? Math.min(speed * 0.05, 0.25) : 0;
      const targetFreq = 150 + Math.min(speed * 50, 1500);
      
      scratchGainNode.gain.setTargetAtTime(targetGain, audioCtx.currentTime, 0.05);
      scratchFilterNode.frequency.setTargetAtTime(targetFreq, audioCtx.currentTime, 0.05);
    }

    function updateAmbientPitch(faceIndex) {
      if (!audioCtx || !ambientOsc1 || !ambientOsc2) return;
      // Map base frequencies for each face
      const baseFreqs = [73.42, 82.41, 87.31, 98.00]; // D2, E2, F2, G2
      const target1 = baseFreqs[faceIndex];
      const target2 = target1 * 1.5; // Perfect fifth
      
      ambientOsc1.frequency.setTargetAtTime(target1, audioCtx.currentTime, 0.3);
      ambientOsc2.frequency.setTargetAtTime(target2, audioCtx.currentTime, 0.3);
    }

    // ----------------------------------------------------
    // Game/Calibration Parameters
    // ----------------------------------------------------
    const faces = [
      { text: "SUBA.GENTVS", id: "select-gladiator", cleanPercent: 0, selectorId: "select-gladiator" },
      { text: "DEEP.MINDVS", id: "select-owner", cleanPercent: 0, selectorId: "select-owner" },
      { text: "SP VII K.IVN", id: "select-sprint", cleanPercent: 0, selectorId: "select-sprint" },
      { text: "J.S. ET C.P.P.", id: "select-consuls", cleanPercent: 0, selectorId: "select-consuls" }
    ];

    let currentFace = 0;
    let isArmed = false;
    let isTransitioning = false;
    let isDrawing = false;
    let lastX = 0;
    let lastY = 0;

    // Keyboard cursor coordinates (normalized [0, 400] and [0, 200])
    let cursorX = 200;
    let cursorY = 100;

    // Track grid cells for each face to compute cleanliness
    const gridRows = 20;
    const gridCols = 40;
    const faceGrids = Array.from({ length: 4 }, () => 
      Array.from({ length: gridCols }, () => Array(gridRows).fill(false))
    );

    // Offscreen canvases to hold the mud layer for each face
    const offscreenCanvases = Array.from({ length: 4 }, () => {
      const c = document.createElement('canvas');
      c.width = 400;
      c.height = 200;
      const ctx = c.getContext('2d');
      
      // Draw mud texture
      ctx.fillStyle = '#292524'; // Mud base
      ctx.fillRect(0, 0, 400, 200);
      
      // Add visual clay speckles
      ctx.fillStyle = '#1c1917';
      for (let i = 0; i < 60; i++) {
        ctx.fillRect(Math.random() * 400, Math.random() * 200, 3 + Math.random() * 6, 3 + Math.random() * 6);
      }
      ctx.fillStyle = '#44403c';
      for (let i = 0; i < 40; i++) {
        ctx.beginPath();
        ctx.arc(Math.random() * 400, Math.random() * 200, 2 + Math.random() * 5, 0, Math.PI * 2);
        ctx.fill();
      }
      
      return c;
    });

    const canvas = document.getElementById('rubbing-canvas');
    const ctx = canvas.getContext('2d');
    const root = document.getElementById('gladiator-tag-root');
    const workspace = document.getElementById('workspace');
    const armingOverlay = document.getElementById('arming-overlay');
    const armButton = document.getElementById('arm-button');
    const successScreen = document.getElementById('success-screen');
    const resetBtn = document.getElementById('reset-btn');
    const releaseBtn = document.getElementById('release-btn');
    
    const faceIndexDisplay = document.getElementById('face-index-display');
    const cleanlinessBadge = document.getElementById('cleanliness-badge');
    const totalCleanlinessDisplay = document.getElementById('total-cleanliness-display');
    const totalProgressBar = document.getElementById('total-progress-bar');
    const prismCard = document.getElementById('prism-card');
    const virtualCursor = document.getElementById('virtual-cursor');
    const instructionHelp = document.getElementById('decryption-instructions');

    // UI rotation arrows
    const btnRotatePrev = document.getElementById('btn-rotate-prev');
    const btnRotateNext = document.getElementById('btn-rotate-next');

    // Select boxes
    const selects = {
      gladiator: document.getElementById('select-gladiator'),
      owner: document.getElementById('select-owner'),
      sprint: document.getElementById('select-sprint'),
      consuls: document.getElementById('select-consuls')
    };

    // Initialize/Arm button click
    armButton.addEventListener('click', () => {
      initAudio();
      isArmed = true;
      armingOverlay.classList.add('hidden');
      workspace.classList.remove('hidden');
      
      // Update displays
      updateDisplay();
      requestAnimationFrame(drawLoop);
    });

    // ----------------------------------------------------
    // Drawing & Scratching Logic
    // ----------------------------------------------------
    function getNormalizedCoords(e) {
      const rect = canvas.getBoundingClientRect();
      let clientX, clientY;
      
      if (e.touches && e.touches.length > 0) {
        clientX = e.touches[0].clientX;
        clientY = e.touches[0].clientY;
      } else {
        clientX = e.clientX;
        clientY = e.clientY;
      }
      
      // Map back into [0, 400] and [0, 200] canvas coords
      const x = ((clientX - rect.left) / rect.width) * 400;
      const y = ((clientY - rect.top) / rect.height) * 200;
      return { x, y };
    }

    function scratchAt(x, y, radius = 22) {
      if (!isArmed || isTransitioning) return;
      
      const oCtx = offscreenCanvases[currentFace].getContext('2d');
      oCtx.save();
      oCtx.globalCompositeOperation = 'destination-out';
      oCtx.beginPath();
      oCtx.arc(x, y, radius, 0, Math.PI * 2);
      oCtx.fill();
      oCtx.restore();
      
      // Update grid cells in radius
      const grid = faceGrids[currentFace];
      const cellWidth = 400 / gridCols;
      const cellHeight = 200 / gridRows;
      
      for (let c = 0; c < gridCols; c++) {
        for (let r = 0; r < gridRows; r++) {
          if (grid[c][r]) continue;
          
          const cx = c * cellWidth + cellWidth / 2;
          const cy = r * cellHeight + cellHeight / 2;
          const dx = cx - x;
          const dy = cy - y;
          if (dx * dx + dy * dy <= radius * radius) {
            grid[c][r] = true;
          }
        }
      }
      
      calculateFaceCleanliness();
    }

    function calculateFaceCleanliness() {
      const grid = faceGrids[currentFace];
      let cleanCount = 0;
      for (let c = 0; c < gridCols; c++) {
        for (let r = 0; r < gridRows; r++) {
          if (grid[c][r]) cleanCount++;
        }
      }
      
      const totalCells = gridCols * gridRows;
      const percent = (cleanCount / totalCells) * 100;
      const rounded = Math.min(Math.round(percent), 100);
      
      // If it sweeps past 100% just now, trigger completion sound
      const prevPercent = faces[currentFace].cleanPercent;
      faces[currentFace].cleanPercent = rounded;
      
      if (rounded >= 95 && prevPercent < 95) {
        triggerChime([293.66, 349.23, 440.00, 523.25]); // D minor pentatonic chime
        
        // Mark indicator as cleaned
        const indicator = document.getElementById(`ind-face-${currentFace}`);
        if (indicator) indicator.setAttribute('data-state', 'cleaned');
      }
      
      updateDisplay();
      checkAllFacesCleaned();
    }

    function checkAllFacesCleaned() {
      let cleanedCount = 0;
      let totalSum = 0;
      faces.forEach((f, idx) => {
        totalSum += f.cleanPercent;
        if (f.cleanPercent >= 90) {
          cleanedCount++;
          // Enable select box
          const select = document.getElementById(f.selectorId);
          if (select) {
            select.disabled = false;
            if (select.options[0].value === "") {
              select.options[0].text = `-- Select Translation --`;
            }
          }
        }
      });
      
      root.setAttribute('data-faces-cleaned', cleanedCount.toString());
      
      const overallPercent = (totalSum / 4).toFixed(1);
      totalCleanlinessDisplay.textContent = `${overallPercent}%`;
      totalProgressBar.style.width = `${overallPercent}%`;
      
      if (cleanedCount === 4) {
        root.setAttribute('data-status', 'clean');
        instructionHelp.innerHTML = `<span class="text-green-500 font-bold">✓ ALL FACES UNCOVERED. Decrypt terms below!</span>`;
      }
    }

    // Input validation for decryption
    function validateDecryption() {
      const g = selects.gladiator.value;
      const o = selects.owner.value;
      const s = selects.sprint.value;
      const c = selects.consuls.value;
      
      if (g === 'subagent' && o === 'deepmind' && s === 'sp7' && c === 'js-cpp') {
        releaseBtn.disabled = false;
        releaseBtn.innerHTML = "🔓 SUBMIT DECRYPTION (RELEASE)";
      } else {
        releaseBtn.disabled = true;
        releaseBtn.innerHTML = "🔒 RELEASE TO PROD (INCOMPLETE)";
      }
    }

    Object.values(selects).forEach(select => {
      select.addEventListener('change', validateDecryption);
    });

    releaseBtn.addEventListener('click', () => {
      if (releaseBtn.disabled) return;
      triggerChime([523.25, 659.25, 783.99, 1046.50]); // Triumphant C Major chord
      successScreen.classList.remove('hidden');
    });

    // Reset button
    resetBtn.addEventListener('click', () => {
      // Clear all state
      faces.forEach(f => {
        f.cleanPercent = 0;
        const select = document.getElementById(f.selectorId);
        if (select) {
          select.disabled = true;
          select.value = "";
          select.options[0].text = `-- [Locked: Clean Face ${select.id.replace('select-', '')}] --`;
        }
      });
      
      faceGrids.forEach(grid => {
        for (let c = 0; c < gridCols; c++) {
          grid[c].fill(false);
        }
      });
      
      offscreenCanvases.forEach(c => {
        const ctx = c.getContext('2d');
        ctx.fillStyle = '#292524';
        ctx.fillRect(0, 0, 400, 200);
        ctx.fillStyle = '#1c1917';
        for (let i = 0; i < 60; i++) {
          ctx.fillRect(Math.random() * 400, Math.random() * 200, 3 + Math.random() * 6, 3 + Math.random() * 6);
        }
        ctx.fillStyle = '#44403c';
        for (let i = 0; i < 40; i++) {
          ctx.beginPath();
          ctx.arc(Math.random() * 400, Math.random() * 200, 2 + Math.random() * 5, 0, Math.PI * 2);
          ctx.fill();
        }
      });
      
      faces.forEach((_, idx) => {
        const ind = document.getElementById(`ind-face-${idx}`);
        if (ind) ind.setAttribute('data-state', 'muddy');
      });
      
      currentFace = 0;
      root.setAttribute('data-status', 'muddy');
      root.setAttribute('data-faces-cleaned', '0');
      
      cursorX = 200;
      cursorY = 100;
      
      validateDecryption();
      successScreen.classList.add('hidden');
      updateDisplay();
    });

    // ----------------------------------------------------
    // Navigation / Flip Face Logic
    // ----------------------------------------------------
    function rotateFace(dir) {
      if (isTransitioning) return;
      isTransitioning = true;
      
      // Trigger short audio sweep
      if (audioCtx) {
        triggerChime([150, 250]);
      }
      
      // Perform CSS 3D Flip
      const deg = dir === 'next' ? -90 : 90;
      prismCard.style.transform = `rotateY(${deg}deg)`;
      
      setTimeout(() => {
        // Halfway through rotation, swap content
        if (dir === 'next') {
          currentFace = (currentFace + 1) % 4;
        } else {
          currentFace = (currentFace - 1 + 4) % 4;
        }
        
        updateAmbientPitch(currentFace);
        updateDisplay();
        
        // Rotate back
        prismCard.style.transform = `rotateY(${dir === 'next' ? 90 : -90}deg)`;
        
        // Settle back to 0
        setTimeout(() => {
          prismCard.style.transition = 'none';
          prismCard.style.transform = 'rotateY(0deg)';
          setTimeout(() => {
            prismCard.style.transition = 'transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1)';
            isTransitioning = false;
          }, 50);
        }, 300);
      }, 300);
    }

    btnRotatePrev.addEventListener('click', () => rotateFace('prev'));
    btnRotateNext.addEventListener('click', () => rotateFace('next'));

    // Keyboard bindings for rotation
    window.addEventListener('keydown', (e) => {
      if (!isArmed || successScreen.classList.contains('hidden') === false) return;
      
      if (e.key === 'a' || e.key === 'A') {
        rotateFace('prev');
      } else if (e.key === 'd' || e.key === 'D') {
        rotateFace('next');
      }
    });

    // ----------------------------------------------------
    // Display updates
    // ----------------------------------------------------
    const romanNumerals = ["I / IV", "II / IV", "III / IV", "IV / IV"];
    function updateDisplay() {
      faceIndexDisplay.textContent = romanNumerals[currentFace];
      cleanlinessBadge.textContent = `${faces[currentFace].cleanPercent}% CLEANED`;
      
      // Update active indicator class
      for (let i = 0; i < 4; i++) {
        const ind = document.getElementById(`ind-face-${i}`);
        if (ind) {
          if (i === currentFace) {
            ind.classList.add('active');
          } else {
            ind.classList.remove('active');
          }
        }
      }
    }

    // ----------------------------------------------------
    // Canvas Paint / Draw loop
    // ----------------------------------------------------
    function drawLoop() {
      if (!isArmed) return;
      
      ctx.clearRect(0, 0, 400, 200);
      
      // 1. Draw base bone surface texture
      const grad = ctx.createLinearGradient(0, 0, 0, 200);
      grad.addColorStop(0, '#f5f5f4'); // Bone light cream
      grad.addColorStop(0.5, '#e7e5e4'); // Stone bone
      grad.addColorStop(1, '#d6d3d1');
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, 400, 200);
      
      // Draw organic pores/fissures on bone
      ctx.fillStyle = '#a8a29e';
      ctx.fillRect(20, 30, 2, 40);
      ctx.fillRect(350, 120, 1.5, 30);
      ctx.fillRect(140, 160, 3, 15);
      
      // 2. Draw carved Latin Inscription text (underlay)
      ctx.save();
      ctx.font = '900 36px Outfit, Inter, sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      
      // Inner shadow/carve effect
      ctx.fillStyle = '#0f0d0c'; // Shadow offset
      ctx.fillText(faces[currentFace].text, 201, 102);
      
      ctx.fillStyle = '#450a0a'; // Dry blood red text fill
      ctx.fillText(faces[currentFace].text, 200, 100);
      ctx.restore();
      
      // 3. Composite the mud layer on top
      ctx.drawImage(offscreenCanvases[currentFace], 0, 0);
      
      // Draw virtual cursor overlay if focused/hovered
      if (virtualCursor) {
        virtualCursor.style.left = `${(cursorX / 400) * 100}%`;
        virtualCursor.style.top = `${(cursorY / 200) * 100}%`;
      }

      requestAnimationFrame(drawLoop);
    }

    // ----------------------------------------------------
    // Pointer Events (Mouse / Touch)
    // ----------------------------------------------------
    function handlePointerStart(e) {
      if (!isArmed || isTransitioning) return;
      isDrawing = true;
      const coords = getNormalizedCoords(e);
      lastX = coords.x;
      lastY = coords.y;
      
      cursorX = coords.x;
      cursorY = coords.y;
      scratchAt(coords.x, coords.y);
    }

    function handlePointerMove(e) {
      if (!isArmed || !isDrawing || isTransitioning) return;
      const coords = getNormalizedCoords(e);
      
      // Calculate velocity
      const dx = coords.x - lastX;
      const dy = coords.y - lastY;
      const speed = Math.sqrt(dx * dx + dy * dy);
      
      cursorX = coords.x;
      cursorY = coords.y;
      
      scratchAt(coords.x, coords.y);
      setScratchVolumeAndFreq(speed, true);
      
      lastX = coords.x;
      lastY = coords.y;
    }

    function handlePointerEnd() {
      isDrawing = false;
      setScratchVolumeAndFreq(0, false);
    }

    canvas.addEventListener('mousedown', handlePointerStart);
    canvas.addEventListener('mousemove', handlePointerMove);
    window.addEventListener('mouseup', handlePointerEnd);

    canvas.addEventListener('touchstart', handlePointerStart, { passive: true });
    canvas.addEventListener('touchmove', handlePointerMove, { passive: true });
    window.addEventListener('touchend', handlePointerEnd);
    window.addEventListener('touchcancel', handlePointerEnd);

    // ----------------------------------------------------
    // Keyboard Controls
    // ----------------------------------------------------
    window.addEventListener('keydown', (e) => {
      if (!isArmed || isTransitioning || successScreen.classList.contains('hidden') === false) return;
      
      let moved = false;
      const step = 8;
      
      switch (e.key) {
        case 'ArrowUp':
          cursorY = Math.max(cursorY - step, 0);
          moved = true;
          break;
        case 'ArrowDown':
          cursorY = Math.min(cursorY + step, 200);
          moved = true;
          break;
        case 'ArrowLeft':
          cursorX = Math.max(cursorX - step, 0);
          moved = true;
          break;
        case 'ArrowRight':
          cursorX = Math.min(cursorX + step, 400);
          moved = true;
          break;
      }
      
      if (moved) {
        e.preventDefault();
        scratchAt(cursorX, cursorY, 26);
        setScratchVolumeAndFreq(12, true);
        
        // Stop scratching sound after delay
        clearTimeout(window.__keyboardScratchTimeout);
        window.__keyboardScratchTimeout = setTimeout(() => {
          setScratchVolumeAndFreq(0, false);
        }, 150);
      }
    });

    // ----------------------------------------------------
    // E2E Test Helper hooks
    // ----------------------------------------------------
    window.__revealAll = function() {
      // Instantly reveal all faces
      faces.forEach((f, idx) => {
        f.cleanPercent = 100;
        
        // Clear entire offscreen mud canvas
        const oCtx = offscreenCanvases[idx].getContext('2d');
        oCtx.clearRect(0, 0, 400, 200);
        
        // Update grids
        const grid = faceGrids[idx];
        for (let c = 0; c < gridCols; c++) {
          grid[c].fill(true);
        }
        
        // Update indicators
        const ind = document.getElementById(`ind-face-${idx}`);
        if (ind) ind.setAttribute('data-state', 'cleaned');
      });
      
      currentFace = 0;
      updateDisplay();
      checkAllFacesCleaned();
    };
  })();
</script>
