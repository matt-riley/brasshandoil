      cursor: pointer;
    }

    .hud-val {
      font-family: var(--font-mono);
      font-size: 0.85rem;
      font-weight: 700;
      color: #ffffff;
      min-width: 50px;
      text-align: right;
    }

    .control-actions {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: var(--spacing-4);
      margin-top: 4px;
    }

    .hud-btn {
      background: transparent;
      border: 1px solid rgba(255, 255, 255, 0.15);
      color: #ffffff;
      border-radius: var(--radius-full);
      padding: var(--spacing-2) var(--spacing-6);
      font-weight: 700;
      font-size: 0.8rem;
      cursor: pointer;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      transition: background-color 0.2s, border-color 0.2s, transform 0.1s;
    }

    .hud-btn:hover {
      background: rgba(255, 255, 255, 0.05);
      border-color: rgba(255, 255, 255, 0.3);
    }

    .hud-btn:active {
      transform: scale(0.97);
    }

    .glow-btn {
      background: #ffffff;
      color: #000000;
      border: none;
      box-shadow: 0 4px 15px rgba(255, 255, 255, 0.2);
    }

    .glow-btn:hover {
      background: #eaeaea;
      box-shadow: 0 4px 20px rgba(255, 255, 255, 0.35);
    }

    .glow-btn.loading {
      background: rgba(255, 255, 255, 0.25);
      color: rgba(255, 255, 255, 0.7);
      cursor: not-allowed;
      box-shadow: none;
    }

    .toggle-btn {
      padding: var(--spacing-2);
      display: flex;
      align-items: center;
      justify-content: center;
      aspect-ratio: 1;
    }

    .sound-icon {
      width: 1.15rem;
      height: 1.15rem;
    }

    .toggle-btn.muted {
      color: rgba(255, 255, 255, 0.35);
      border-color: rgba(255, 255, 255, 0.05);
    }

    .toggle-btn.muted .waves {
      display: none;
    }

    /* Polyfill Fallback and Default Overlay position for CSS Anchor Positioning */
    .chrono-popover {
      /* Native Popover resets */
      border: none;
      background: transparent;
      padding: 0;
      margin: 0;
      overflow: visible;
      
      /* Fallback/Centering layout when anchor is unsupported */
      position: fixed;
      inset: auto;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      
      /* Visual styling of HUD panel */
      width: 280px;
      border: 1px solid rgba(255, 255, 255, 0.15);
      background: var(--panel-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-radius: var(--radius-lg);
      box-shadow: 
        0 15px 35px rgba(0, 0, 0, 0.7),
        0 0 25px rgba(0, 240, 255, 0.1);
      pointer-events: none;
      z-index: 100;
    }

    /* Native CSS Anchor Positioning Bindings */
    @supports (anchor-name: --foo) {
      .chrono-popover {
        position: absolute;
        position-anchor: var(--active-anchor, --anchor-tl-902);
        top: anchor(bottom);
        left: anchor(center);
        transform: translate(-50%, 10px);
        margin: 0;
        
        /* Transition properties */
        transition: display 0.25s allow-discrete, overlay 0.25s allow-discrete, transform 0.25s, opacity 0.25s;
        opacity: 0;
        transform: translate(-50%, 15px);
      }

      /* Native Entry Transitions on Popover Open */
      .chrono-popover:popover-open {
        opacity: 1;
        transform: translate(-50%, 10px);
      }

      @starting-style {
        .chrono-popover:popover-open {
          opacity: 0;
          transform: translate(-50%, 15px);
        }
      }
    }

    .popover-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: var(--spacing-3) var(--spacing-4) var(--spacing-2);
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .popover-title {
      font-size: 0.75rem;
      font-weight: 900;
      letter-spacing: 0.05em;
      color: rgba(255, 255, 255, 0.9);
    }

    .popover-status {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      font-weight: 800;
      padding: 1px 5px;
      border-radius: var(--radius-sm);
    }

    .popover-status.drifting {
      background: rgba(244, 63, 94, 0.1);
