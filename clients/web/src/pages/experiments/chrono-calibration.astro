      color: rgba(255, 255, 255, 0.5);
    }

    .popover-drift strong {
      color: #ffffff;
      font-family: var(--font-mono);
    }

    /* Web Audio Initialization Permission Overlay */
    .audio-overlay {
      position: absolute;
      inset: 0;
