    .control-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-4);
    }

    @media (max-width: 480px) {
      .control-row {
        grid-template-columns: 1fr;
        gap: var(--spacing-2);
      }
    }

    .control-group {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .control-group label {
      font-size: 0.8rem;
      font-weight: 700;
