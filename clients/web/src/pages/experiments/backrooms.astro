---
import Base from "@layouts/Base.astro"
---

<Base>
  <div id="backrooms-shell">
    <canvas id="corridor" width="960" height="640"></canvas>

    <div id="hud">
      <h1 id="title">The Backrooms</h1>
      <div id="step-counter">0</div>
      <div id="hint">Arrow keys to move. There is no exit.</div>
    </div>

    <div id="mobile-controls">
      <button id="btn-left" class="mobile-btn" type="button">◀ LOOK L</button>
      <button id="btn-up" class="mobile-btn" type="button">▲ WALK FORWARD</button>
      <button id="btn-right" class="mobile-btn" type="button">LOOK R ▶</button>
    </div>

    <div id="notes-overlay"></div>
    <div id="vignette" aria-hidden="true"></div>
  </div>
</Base>

<style>
  @import url('https://fonts.googleapis.com/css2?family=VT323&display=swap');

  #backrooms-shell {
    position: fixed;
    inset: 0;
    overflow: hidden;
    background: #4a4228;
    font-family: 'VT323', monospace;
    cursor: none;
    user-select: none;
  }

  #corridor {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .fluorescent-light {
    /* marker class for test — lights are drawn on canvas */
    position: absolute;
    top: 10px;
    left: 10px;
    width: 10px;
    height: 10px;
    background: transparent;
    pointer-events: none;
    z-index: 10;
  }

  #hud {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    padding: 20px;
    z-index: 10;
    pointer-events: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  #title {
    font-family: 'VT323', monospace;
    font-size: 24px;
    color: rgba(60, 50, 20, 0.5);
    letter-spacing: 8px;
    text-transform: uppercase;
    margin: 0;
    text-shadow: 0 0 10px rgba(0, 0, 0, 0.2);
  }

  #step-counter {
    font-family: 'VT323', monospace;
    font-size: 48px;
    color: rgba(60, 50, 20, 0.4);
    text-shadow: 0 0 8px rgba(0, 0, 0, 0.15);
  }

  #hint {
    font-family: 'VT323', monospace;
    font-size: 16px;
    color: rgba(60, 50, 20, 0.35);
    letter-spacing: 2px;
  }

  #notes-overlay {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 6;
  }

  .wall-note {
    position: absolute;
    padding: 6px 10px;
    color: rgba(180, 160, 100, 0.7);
    font-size: 15px;
    font-family: 'VT323', monospace;
    pointer-events: none;
    text-shadow: 0 0 4px rgba(180, 160, 100, 0.3);
    white-space: nowrap;
  }

  #vignette {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 5;
    background: radial-gradient(
      ellipse at center,
      transparent 50%,
      rgba(0, 0, 0, 0.4) 100%
    );
  }

  #mobile-controls {
    display: none;
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 20;
    gap: 12px;
    width: calc(100% - 32px);
    max-width: 420px;
    justify-content: center;
  }

  .mobile-btn {
    flex: 1;
    font-family: 'VT323', monospace;
    font-size: 18px;
    color: rgba(60, 50, 20, 0.7);
    background: rgba(220, 205, 150, 0.25);
    border: 2px solid rgba(60, 50, 20, 0.3);
    border-radius: 6px;
    padding: 12px 6px;
    cursor: pointer;
    text-shadow: 0 0 4px rgba(0, 0, 0, 0.15);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    transition: background 0.15s, transform 0.1s;
    user-select: none;
    -webkit-user-select: none;
    touch-action: manipulation;
  }

  .mobile-btn:active {
    background: rgba(220, 205, 150, 0.45);
    transform: scale(0.95);
  }

  @media (max-width: 768px) {
    #mobile-controls {
      display: flex;
    }
    #hint {
      display: none;
    }
    #hud {
      padding: 12px;
    }
    #title {
      font-size: 20px;
      letter-spacing: 4px;
    }
    #step-counter {
      font-size: 36px;
    }
  }
</style>

<script>
  const NOTES: string[] = [
    "if you're reading this, don't turn around",
    "level 0 ████████ level 1",
    "the hum is getting louder",
    "I've been walking for 3 days",
    "the lights weren't flickering before",
    "DO NOT TRUST THE CARPET",
    "has the ceiling always been this low?",
    "I found another note. it was mine.",
    "the walls are damp =(",
    "which way is out? there is no out.",
    "I can hear breathing but I'm alone",
    "the fluorescents know something",
    "exit → (there is no exit)",
    "DAY 7: the wallpaper is peeling upward",
    "someone was here before me. or after me.",
  ];

  const canvas = document.getElementById("corridor") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d") as CanvasRenderingContext2D;
  const stepCounter = document.getElementById("step-counter") as HTMLDivElement;
  const notesOverlay = document.getElementById("notes-overlay") as HTMLDivElement;
  const shell = document.getElementById("backrooms-shell") as HTMLDivElement;

  let steps = 0;
  let animating = false;
  let offset = 0; // 0..1 interpolation within a step
  let targetOffset = 0;
  let lookX = 0; // -1..1 horizontal look
  let lookTarget = 0;
  let noteCount = 0;

  // Add marker elements for fluorescent lights (for test selector)
  for (let i = 0; i < 4; i++) {
    const marker = document.createElement("div");
    marker.className = "fluorescent-light";
    marker.style.cssText = "position: absolute; top: 10px; left: 10px; width: 10px; height: 10px; background: transparent; pointer-events: none; z-index: 10;";
    shell.appendChild(marker);
  }

  function resize(): void {
    canvas.width = window.innerWidth * window.devicePixelRatio;
    canvas.height = window.innerHeight * window.devicePixelRatio;
    canvas.style.width = window.innerWidth + "px";
    canvas.style.height = window.innerHeight + "px";
    ctx.setTransform(window.devicePixelRatio, 0, 0, window.devicePixelRatio, 0, 0);
  }
  resize();
  window.addEventListener("resize", resize);

  const W = (): number => window.innerWidth;
  const H = (): number => window.innerHeight;

  function rgb(r: number, g: number, b: number): string {
    return `rgb(${Math.floor(r)}, ${Math.floor(g)}, ${Math.floor(b)})`;
  }

  interface Ring {
    left: number;
    right: number;
    top: number;
    bottom: number;
    bright: number;
  }

  function quad(
    x0: number, y0: number,
    x1: number, y1: number,
    x2: number, y2: number,
    x3: number, y3: number,
    color: string
  ): void {
    ctx.fillStyle = color;
    ctx.beginPath();
    ctx.moveTo(x0, y0);
    ctx.lineTo(x1, y1);
    ctx.lineTo(x2, y2);
    ctx.lineTo(x3, y3);
    ctx.closePath();
    ctx.fill();
  }

  function ringAt(i: number, cx: number, cy: number, w: number, h: number, rings: number): Ring {
    const t = (i - offset) / rings;
    const depth = Math.pow(Math.max(0, t), 1.4);
    const rw = 6 + (w / 2 - 6) * (1 - depth);
    const rh = 6 + (h / 2 - 6) * (1 - depth);
    const brightness = 0.35 + 0.65 * (1 - depth);
    const flickerSeed = (i + steps) * 7.3;
    const flicker = Math.sin(flickerSeed + performance.now() * 0.003) > 0.93 ? 0.4 : 1;
    return {
      left: cx - rw,
      right: cx + rw,
      top: cy - rh,
      bottom: cy + rh,
      bright: brightness * flicker,
    };
  }

  function drawCorridor(): void {
    const w = W();
    const h = H();
    ctx.clearRect(0, 0, w, h);

    // Fill background — the vanishing point color
    ctx.fillStyle = "#4a4228";
    ctx.fillRect(0, 0, w, h);

    const cx = w / 2 + lookX * 80;
    const cy = h / 2 + 10; // slightly below center for more floor
    const rings = 16;

    // Draw from back to front
    for (let i = rings; i >= 0; i--) {
      const outer = ringAt(i, cx, cy, w, h, rings);
      const inner = ringAt(i + 1, cx, cy, w, h, rings);
      const b = outer.bright;

      // Back wall fill
      ctx.fillStyle = rgb(180 * b, 165 * b, 90 * b);
      ctx.fillRect(inner.left, inner.top, inner.right - inner.left, inner.bottom - inner.top);

      // Ceiling — lighter yellow
      quad(
        outer.left, outer.top,
        outer.right, outer.top,
        inner.right, inner.top,
        inner.left, inner.top,
        rgb(200 * b, 190 * b, 140 * b)
      );

      // Floor — darker brown carpet
      quad(
        outer.left, outer.bottom,
        outer.right, outer.bottom,
        inner.right, inner.bottom,
        inner.left, inner.bottom,
        rgb(120 * b, 100 * b, 60 * b)
      );

      // Left wall — warm yellow
      quad(
        outer.left, outer.top,
        inner.left, inner.top,
        inner.left, inner.bottom,
        outer.left, outer.bottom,
        rgb(215 * b, 195 * b, 110 * b)
      );

      // Right wall — slightly darker yellow
      quad(
        outer.right, outer.top,
        inner.right, inner.top,
        inner.right, inner.bottom,
        outer.right, outer.bottom,
        rgb(195 * b, 178 * b, 100 * b)
      );

      // Ring edges — dark lines at each section boundary
      ctx.strokeStyle = `rgba(40, 30, 10, ${0.3 * b})`;
      ctx.lineWidth = 1.5;
      // Top edge
      ctx.beginPath();
      ctx.moveTo(outer.left, outer.top);
      ctx.lineTo(outer.right, outer.top);
      ctx.stroke();
      // Bottom edge
      ctx.beginPath();
      ctx.moveTo(outer.left, outer.bottom);
      ctx.lineTo(outer.right, outer.bottom);
      ctx.stroke();
      // Left edge
      ctx.beginPath();
      ctx.moveTo(outer.left, outer.top);
      ctx.lineTo(outer.left, outer.bottom);
      ctx.stroke();
      // Right edge
      ctx.beginPath();
      ctx.moveTo(outer.right, outer.top);
      ctx.lineTo(outer.right, outer.bottom);
      ctx.stroke();

      // Wall trim — dark horizontal line across walls at ~1/3 height
      const trimFrac = 0.4;
      const oTrimY = outer.top + (outer.bottom - outer.top) * trimFrac;
      const iTrimY = inner.top + (inner.bottom - inner.top) * trimFrac;
      ctx.strokeStyle = `rgba(80, 65, 25, ${0.5 * b})`;
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.moveTo(outer.left, oTrimY);
      ctx.lineTo(inner.left, iTrimY);
      ctx.stroke();
      ctx.beginPath();
      ctx.moveTo(outer.right, oTrimY);
      ctx.lineTo(inner.right, iTrimY);
      ctx.stroke();

      // Fluorescent light
      if (i % 3 === 0 && i < rings - 1) {
        const lx = cx;
        const ceilMidY = (outer.top + inner.top) / 2;
        const lightW = (outer.right - outer.left) * 0.25;
        const lightH = Math.max(3, (outer.bottom - outer.top) * 0.012);

        // Big glow
        const glow = ctx.createRadialGradient(lx, ceilMidY, 0, lx, ceilMidY, lightW * 3);
        glow.addColorStop(0, `rgba(255, 255, 220, ${0.25 * b})`);
        glow.addColorStop(0.5, `rgba(255, 255, 200, ${0.08 * b})`);
        glow.addColorStop(1, "rgba(255, 255, 200, 0)");
        ctx.fillStyle = glow;
        ctx.fillRect(lx - lightW * 3, ceilMidY - lightW * 2, lightW * 6, lightW * 4);

        // Light tube — bright white-yellow
        ctx.fillStyle = `rgba(255, 255, 235, ${0.95 * b})`;
        ctx.fillRect(lx - lightW / 2, ceilMidY - lightH / 2, lightW, lightH);
        // Tube border
        ctx.strokeStyle = `rgba(200, 200, 180, ${0.5 * b})`;
        ctx.lineWidth = 1;
        ctx.strokeRect(lx - lightW / 2, ceilMidY - lightH / 2, lightW, lightH);
      }
    }
  }

  function addWallNote(): void {
    if (noteCount >= NOTES.length) return;
    const note = document.createElement("div");
    note.className = "wall-note";
    note.textContent = NOTES[noteCount] ?? "";
    noteCount++;

    const side = Math.random() > 0.5;
    note.style.top = `${25 + Math.random() * 40}%`;
    if (side) {
      note.style.left = `${3 + Math.random() * 15}%`;
    } else {
      note.style.right = `${3 + Math.random() * 15}%`;
    }
    note.style.opacity = "0";
    notesOverlay.appendChild(note);

    // Fade in
    requestAnimationFrame(() => {
      note.style.transition = "opacity 1s";
      note.style.opacity = "0.7";
    });

    // Fade out after a while
    setTimeout(() => {
      note.style.opacity = "0";
      setTimeout(() => note.remove(), 1000);
    }, 6000);
  }

  function step(): void {
    if (animating) return;
    animating = true;
    steps++;
    stepCounter.textContent = String(steps);

    if (steps % 5 === 0) {
      addWallNote();
    }

    // Animate offset from 0 to 1, then reset
    const startTime = performance.now();
    const duration = 450;

    function anim(now: number): void {
      const t = Math.min((now - startTime) / duration, 1);
      // Ease in-out
      const eased = t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2;
      offset = eased;

      if (t < 1) {
        requestAnimationFrame(anim);
      } else {
        offset = 0;
        animating = false;
      }
    }
    requestAnimationFrame(anim);
  }

  // Audio
  let audioCtx: AudioContext | null = null;
  function initAudio(): void {
    try {
      audioCtx = new AudioContext();
      // Deep electrical hum
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.type = "sine";
      osc.frequency.value = 60;
      gain.gain.value = 0.05;
      osc.connect(gain).connect(audioCtx.destination);
      osc.start();

      // Fluorescent buzz
      const osc2 = audioCtx.createOscillator();
      const gain2 = audioCtx.createGain();
      osc2.type = "sawtooth";
      osc2.frequency.value = 120;
      gain2.gain.value = 0.01;
      osc2.connect(gain2).connect(audioCtx.destination);
      osc2.start();

      // Very low throb
      const osc3 = audioCtx.createOscillator();
      const gain3 = audioCtx.createGain();
      osc3.type = "sine";
      osc3.frequency.value = 30;
      gain3.gain.value = 0.03;
      osc3.connect(gain3).connect(audioCtx.destination);
      osc3.start();
    } catch {
      // no audio
    }
  }

  let audioStarted = false;

  const btnUp = document.getElementById("btn-up");
  const btnLeft = document.getElementById("btn-left");
  const btnRight = document.getElementById("btn-right");

  function triggerAudio(): void {
    if (!audioStarted) {
      initAudio();
      audioStarted = true;
    }
  }

  btnUp?.addEventListener("pointerdown", (e) => {
    e.preventDefault();
    triggerAudio();
    step();
  });
  btnLeft?.addEventListener("pointerdown", (e) => {
    e.preventDefault();
    triggerAudio();
    lookTarget = -1;
    setTimeout(() => { lookTarget = 0; }, 300);
  });
  btnRight?.addEventListener("pointerdown", (e) => {
    e.preventDefault();
    triggerAudio();
    lookTarget = 1;
    setTimeout(() => { lookTarget = 0; }, 300);
  });

  document.addEventListener("keydown", (e: KeyboardEvent) => {
    if (!audioStarted) {
      initAudio();
      audioStarted = true;
    }

    if (e.key === "ArrowUp" || e.key === "w" || e.key === "W") {
      e.preventDefault();
      step();
    }
    if (e.key === "ArrowLeft" || e.key === "a" || e.key === "A") {
      e.preventDefault();
      lookTarget = -1;
      setTimeout(() => { lookTarget = 0; }, 300);
    }
    if (e.key === "ArrowRight" || e.key === "d" || e.key === "D") {
      e.preventDefault();
      lookTarget = 1;
      setTimeout(() => { lookTarget = 0; }, 300);
    }
    if (e.key === "ArrowDown" || e.key === "s" || e.key === "S") {
      e.preventDefault();
      // Look behind briefly — unsettling
      lookTarget = 0;
    }
  });

  // Render loop
  function frame(): void {
    lookX += (lookTarget - lookX) * 0.1;
    drawCorridor();
    requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);
</script>
