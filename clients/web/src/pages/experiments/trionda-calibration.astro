---
import Base from "@layouts/Base.astro"
---

<Base>
  <main class="tc-shell" aria-label="TRIONDA Connected Ball Calibration Laboratory">
    <div class="tc-scanlines" aria-hidden="true"></div>
    <div class="tc-grid-overlay" aria-hidden="true"></div>

    <header class="tc-header">
      <div class="tc-meta-row">
        <span class="tc-ticker">// LABORATORY SYSTEM BOOTED // MODEL: TRIONDA-T2026 // PACKET PORT: 500HZ</span>
        <span class="tc-time-sync" id="time-sync">SYNCING TIME...</span>
      </div>
      <h1 class="tc-title">Trionda Calibration Cradle</h1>
      <p class="tc-subtitle">Official 2026 World Cup Match Ball Connected telemetry & power regulation deck.</p>
    </header>

    <div class="tc-grid">
      <!-- DOCK & CALIBRATION DOME (LEFT) -->
      <section class="tc-panel tc-dock-panel">
        <h2 class="tc-panel-title">// CRADLE BAY 01</h2>
        
        <div class="cradle-system">
          <!-- Draggable Plug Cable (SVG) -->
          <svg class="cable-svg" aria-hidden="true">
            <path id="cable-path" d="M 50 250 Q 150 300 250 250" stroke="rgba(6, 182, 212, 0.4)" stroke-width="6" fill="none" />
            <path id="cable-path-inner" d="M 50 250 Q 150 300 250 250" stroke="#06b6d4" stroke-width="2" fill="none" />
          </svg>

          <!-- Interactive Cradle Base -->
          <div id="charging-cradle" class="charging-cradle">
            <div class="cradle-inner-shadow"></div>
            <div class="cradle-laser-glow" id="laser-glow"></div>
            
            <!-- 3D CSS Ball Container -->
            <div id="calibration-ball" class="ball-outer" tabindex="0" role="button" aria-label="TRIONDA calibration ball. Click and drag to spin. Click to simulate kick impact.">
              <div class="ball-wrapper" id="ball-wrapper">
                <div class="ball-sphere">
                  <!-- Custom SVG Soccer Ball Texture -->
                  <svg class="ball-svg" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="50" cy="50" r="48" fill="#1e293b" stroke="#475569" stroke-width="2" />
                    <!-- Pentagons / Panels -->
                    <polygon points="50,30 65,42 60,60 40,60 35,42" fill="#0f172a" stroke="#475569" stroke-width="1.5" />
                    <polygon points="50,30 35,42 18,35 15,15 32,10" fill="#0f172a" stroke="#475569" stroke-width="1.5" />
                    <polygon points="50,30 65,42 82,35 85,15 68,10" fill="#0f172a" stroke="#475569" stroke-width="1.5" />
                    <polygon points="60,60 65,42 82,35 90,55 78,72" fill="#0f172a" stroke="#475569" stroke-width="1.5" />
                    <polygon points="40,60 35,42 18,35 10,55 22,72" fill="#0f172a" stroke="#475569" stroke-width="1.5" />
                    <polygon points="60,60 40,60 50,78 68,78 78,72" fill="#0f172a" stroke="#475569" stroke-width="1.5" />
                    <!-- Trionda Wave 1 (Red) -->
                    <path d="M 20 40 C 35 10, 65 90, 80 60" stroke="#ef4444" stroke-width="4" stroke-linecap="round" opacity="0.85" />
                    <!-- Trionda Wave 2 (Green) -->
                    <path d="M 25 45 C 40 15, 60 85, 75 55" stroke="#ccff00" stroke-width="4" stroke-linecap="round" opacity="0.85" />
                    <!-- Trionda Wave 3 (Blue) -->
                    <path d="M 30 50 C 45 20, 55 80, 70 50" stroke="#3b82f6" stroke-width="4" stroke-linecap="round" opacity="0.85" />
                    <!-- Gold details -->
                    <circle cx="50" cy="46" r="3" fill="#fbbf24" />
                    <circle cx="35" cy="58" r="2.5" fill="#fbbf24" />
                    <circle cx="65" cy="58" r="2.5" fill="#fbbf24" />
                  </svg>
                </div>
                <!-- Shading overlays that stay fixed relative to viewport for 3D realism -->
                <div class="ball-shading" aria-hidden="true"></div>
                <div class="ball-highlight" aria-hidden="true"></div>
                <div class="ball-charging-indicator" id="ball-charge-led" aria-hidden="true"></div>
                <!-- Draggable Charging Port Receptor -->
                <div class="ball-port" id="ball-port" aria-hidden="true"></div>
              </div>
            </div>

            <!-- Draggable Charger Plug -->
            <div id="charging-plug" class="charging-plug" tabindex="0" role="button" aria-label="Charging Cable Connector. Drag to the ball port to connect, or use button.">
              <div class="plug-head"></div>
              <div class="plug-body"></div>
              <div class="plug-contact"></div>
            </div>
          </div>
        </div>

        <div class="cradle-status-row">
          <div class="status-box">
            <span class="status-label">Cradle Power Connection</span>
            <strong id="charging-status" class="status-value text-blue">DISCONNECTED</strong>
          </div>
          <div class="status-box">
            <span class="status-label">Charge Level</span>
            <strong id="charge-level" class="status-value text-amber">12.00%</strong>
          </div>
        </div>

        <div class="cradle-actions">
          <button id="btn-plug-in" type="button" class="btn btn-primary">Plug In Cable</button>
          <button id="btn-reset-battery" type="button" class="btn btn-secondary">Drain Battery</button>
        </div>
        <p class="panel-fineprint">* Drag the USB-C plug onto the ball's golden port, or click "Plug In Cable" to engage the magnetic coupling.</p>
      </section>

      <!-- METRICS & VAR CONSOLE (RIGHT) -->
      <div class="tc-console-column">
        <!-- OSCILLOSCOPE PANEL -->
        <section class="tc-panel tc-telemetry-panel">
          <h2 class="tc-panel-title">// 500Hz TELEMETRY OSCILLOSCOPE</h2>
          <div class="canvas-container">
            <canvas id="trajectory-canvas" aria-label="Oscilloscope graphing gyroscopic sensor drift in real time"></canvas>
            <div class="canvas-overlay-text">LIVE SENSOR DRIFT</div>
          </div>

          <div class="telemetry-readout">
            <div class="tel-col">
              <span class="tel-label">Velocity</span>
              <strong id="tel-velocity" class="tel-number">0.00 m/s</strong>
            </div>
            <div class="tel-col">
              <span class="tel-label">Spin Speed</span>
              <strong id="tel-spin" class="tel-number">0.00 Hz</strong>
            </div>
            <div class="tel-col">
              <span class="tel-label">Impact Force</span>
              <strong id="tel-impact" class="tel-number">0.00 G</strong>
            </div>
            <div class="tel-col">
              <span class="tel-label">Calib Status</span>
              <strong id="tel-calibration" class="tel-number text-red">UNCALIBRATED</strong>
            </div>
          </div>
        </section>

        <!-- VAR DECISION PANEL -->
        <section class="tc-panel tc-var-panel">
          <h2 class="tc-panel-title">// VAR Decision Screen</h2>
          
          <div class="var-screen-wrapper">
            <div class="var-screen">
              <div class="var-grid" aria-hidden="true"></div>
              <div class="var-decision-container">
                <span class="var-label">VAR PROTOCOL DECISION</span>
                <strong id="var-decision" class="var-decision-text text-glow-red">Awaiting stimulus</strong>
                <p id="var-description" class="var-description-text">Telemetry port open. Send 500Hz gyroscopic impulse to calibrate VAR decision-making boundaries.</p>
              </div>
            </div>
          </div>

          <div class="var-log-container">
            <span class="log-label">DECISION FEED (REAL-TIME METRIC ANALYSIS)</span>
            <div id="var-decision-log" class="var-log" aria-live="polite">
              <div class="log-entry">[06:12:09] SYSTEM BOOTED. 500Hz CONNECTED MATCH-BALL AUTHENTICATED.</div>
              <div class="log-entry">[06:12:10] CRADLE COUPLING INITIALIZED. CALIBRATION REQ: SPIN AT > 120HZ.</div>
            </div>
          </div>
        </section>
      </div>
    </div>

    <footer class="tc-footer">
      <span>// CRADLE BAY OPERATOR DESK</span>
      <span>Flick or spin the ball to calibrate. Plug in to charge. Strict TDD validation.</span>
    </footer>
  </main>
</Base>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Space+Grotesk:wght@400;700&display=swap');

  :global(body) {
    margin: 0;
    background: #030712;
    overflow-x: hidden;
  }

  .tc-shell {
    --lime: #ccff00;
    --blue: #06b6d4;
    --dark-bg: #070a13;
    --border-color: rgba(6, 182, 214, 0.18);
    position: relative;
    min-height: 100vh;
    padding: 1.5rem;
    box-sizing: border-box;
    color: #f1f5f9;
    font-family: 'Space Grotesk', sans-serif;
    background-color: var(--dark-bg);
    background-image: 
      radial-gradient(circle at 10% 20%, rgba(6, 182, 214, 0.05) 0%, transparent 40%),
      radial-gradient(circle at 90% 80%, rgba(204, 255, 0, 0.03) 0%, transparent 40%);
    user-select: none;
    touch-action: none;
  }

  /* Scanline / retro screen overlay */
  .tc-scanlines {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 999;
    background: linear-gradient(
      rgba(18, 16, 16, 0) 50%, 
      rgba(0, 0, 0, 0.12) 50%
    );
    background-size: 100% 4px;
  }

  .tc-grid-overlay {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    background-size: 30px 30px;
    background-image: 
      linear-gradient(to right, rgba(255, 255, 255, 0.006) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.006) 1px, transparent 1px);
  }

  /* Header */
  .tc-header {
    position: relative;
    z-index: 10;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 1rem;
  }

  .tc-meta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
  }

  .tc-ticker {
    color: var(--blue);
  }

  .tc-time-sync {
    color: rgba(241, 245, 249, 0.5);
  }

  .tc-title {
    margin: 0;
    font-size: 2.2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    background: linear-gradient(135deg, #ffffff 40%, #06b6d4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .tc-subtitle {
    margin: 0.35rem 0 0;
    font-size: 0.9rem;
    color: #94a3b8;
  }

  /* Core Layout Grid */
  .tc-grid {
    position: relative;
    z-index: 10;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  /* Panel base styles */
  .tc-panel {
    position: relative;
    background: rgba(11, 17, 32, 0.75);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 1.25rem;
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
    backdrop-filter: blur(8px);
    overflow: hidden;
  }

  .tc-panel-title {
    margin: 0 0 1.25rem;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    color: var(--blue);
    border-bottom: 1px solid rgba(6, 182, 214, 0.08);
    padding-bottom: 0.5rem;
    text-transform: uppercase;
  }

  /* Dock/Cradle bay specific styling */
  .tc-dock-panel {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .cradle-system {
    position: relative;
    height: 320px;
    background: radial-gradient(circle at center, rgba(6, 182, 214, 0.03) 0%, transparent 70%);
    border: 1px dashed rgba(6, 182, 214, 0.1);
    border-radius: 4px;
    margin-bottom: 1.25rem;
    overflow: hidden;
  }

  .cable-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 2;
  }

  .charging-cradle {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    width: 260px;
    height: 260px;
  }

  .cradle-inner-shadow {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 200px;
    height: 36px;
    border-radius: 50%;
    background: radial-gradient(ellipse at center, rgba(6, 182, 214, 0.12) 0%, transparent 80%);
    border: 2px solid rgba(6, 182, 214, 0.2);
    box-shadow: 0 0 15px rgba(6, 182, 214, 0.2);
    z-index: 1;
  }

  .cradle-laser-glow {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    width: 170px;
    height: 6px;
    background: var(--blue);
    border-radius: 50%;
    opacity: 0.3;
    filter: blur(3px);
    z-index: 1;
    transition: background-color 0.3s, opacity 0.3s;
  }

  /* Draggable 3D Ball */
  .ball-outer {
    position: absolute;
    bottom: 18px;
    left: 50%;
    transform: translateX(-50%);
    width: 160px;
    height: 160px;
    border-radius: 50%;
    cursor: grab;
    z-index: 3;
    outline: none;
  }

  .ball-outer:active {
    cursor: grabbing;
  }

  .ball-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    transform-style: preserve-3d;
    perspective: 800px;
  }

  .ball-sphere {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    transform-style: preserve-3d;
    transform: rotateX(var(--rx, 0deg)) rotateY(var(--ry, 0deg)) rotateZ(var(--rz, 0deg));
    transition: transform 0.08s linear;
  }

  .ball-svg {
    width: 100%;
    height: 100%;
    border-radius: 50%;
  }

  .ball-shading {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(circle at 75% 75%, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0) 70%);
    pointer-events: none;
    z-index: 4;
  }

  .ball-highlight {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(circle at 25% 25%, rgba(255,255,255,0.2) 0%, rgba(255,255,255,0) 50%);
    pointer-events: none;
    z-index: 5;
  }

  .ball-charging-led {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: transparent;
    box-shadow: 0 0 8px transparent;
    z-index: 6;
    pointer-events: none;
    transform: translate(-50%, -50%);
  }

  .ball-charging-indicator {
    position: absolute;
    top: 15px;
    right: 35px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(239, 68, 68, 0.4);
    box-shadow: 0 0 6px rgba(239, 68, 68, 0.3);
    z-index: 6;
    pointer-events: none;
  }

  .ball-charging-indicator.charging {
    background: var(--lime);
    box-shadow: 0 0 10px var(--lime);
    animation: pulse-led 1.2s infinite ease-in-out;
  }

  @keyframes pulse-led {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }

  .ball-port {
    position: absolute;
    bottom: 25px;
    left: 50%;
    transform: translateX(-50%);
    width: 14px;
    height: 10px;
    background: #eab308;
    border: 2px solid #334155;
    border-radius: 3px;
    box-shadow: 0 0 5px rgba(234, 179, 8, 0.5);
    z-index: 6;
    pointer-events: none;
  }

  /* Draggable Charger Plug */
  .charging-plug {
    position: absolute;
    width: 24px;
    height: 38px;
    cursor: grab;
    z-index: 10;
    outline: none;
    left: 40px;
    top: 160px;
  }

  .charging-plug:active {
    cursor: grabbing;
  }

  .plug-head {
    width: 10px;
    height: 8px;
    background: #e2e8f0;
    border: 1px solid #475569;
    border-radius: 2px 2px 0 0;
    margin: 0 auto;
  }

  .plug-body {
    width: 20px;
    height: 24px;
    background: #0f172a;
    border: 2px solid var(--blue);
    border-radius: 4px;
    box-shadow: 0 0 8px rgba(6, 182, 214, 0.3);
  }

  .plug-contact {
    width: 14px;
    height: 6px;
    background: #475569;
    margin: 0 auto;
    border-radius: 0 0 2px 2px;
  }

  .charging-plug.snapped {
    pointer-events: auto;
  }

  /* Cradle status elements */
  .cradle-status-row {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .status-box {
    flex: 1;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(6, 182, 214, 0.1);
    padding: 0.6rem 0.8rem;
    border-radius: 4px;
  }

  .status-label {
    display: block;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #94a3b8;
    margin-bottom: 0.2rem;
  }

  .status-value {
    font-family: 'Share Tech Mono', monospace;
    font-size: 1.2rem;
    letter-spacing: 0.05em;
  }

  .text-blue {
    color: var(--blue);
    text-shadow: 0 0 6px rgba(6, 182, 214, 0.4);
  }

  .text-amber {
    color: #fbbf24;
    text-shadow: 0 0 6px rgba(251, 191, 36, 0.4);
  }

  .text-green {
    color: var(--lime);
    text-shadow: 0 0 6px rgba(204, 255, 0, 0.4);
  }

  .cradle-actions {
    display: flex;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .btn {
    flex: 1;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.7rem 1rem;
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s, border-color 0.2s;
  }

  .btn-primary {
    background: var(--blue);
    color: #070a13;
    border: 1px solid transparent;
  }

  .btn-primary:hover {
    background: #22d3ee;
    box-shadow: 0 0 12px rgba(6, 182, 214, 0.4);
  }

  .btn-primary:active {
    transform: translateY(1px);
  }

  .btn-secondary {
    background: transparent;
    color: rgba(241, 245, 249, 0.7);
    border: 1px solid rgba(241, 245, 249, 0.15);
  }

  .btn-secondary:hover {
    border-color: rgba(241, 245, 249, 0.4);
    color: #ffffff;
  }

  .btn-secondary:active {
    transform: translateY(1px);
  }

  .panel-fineprint {
    margin: 0;
    font-size: 0.65rem;
    color: #64748b;
    line-height: 1.4;
  }

  /* Telemetry Console (Right Column) */
  .tc-console-column {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .canvas-container {
    position: relative;
    height: 160px;
    background: #030712;
    border: 1px solid rgba(6, 182, 214, 0.08);
    border-radius: 4px;
    margin-bottom: 1rem;
    overflow: hidden;
  }

  #trajectory-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  .canvas-overlay-text {
    position: absolute;
    top: 6px;
    right: 8px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    color: rgba(6, 182, 214, 0.35);
  }

  .telemetry-readout {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }

  .tel-col {
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(6, 182, 214, 0.08);
    padding: 0.5rem 0.6rem;
    border-radius: 4px;
  }

  .tel-label {
    display: block;
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #64748b;
    margin-bottom: 0.15rem;
  }

  .tel-number {
    font-family: 'Share Tech Mono', monospace;
    font-size: 1.05rem;
    color: #e2e8f0;
  }

  .text-red {
    color: #ef4444;
    text-shadow: 0 0 6px rgba(239, 68, 68, 0.3);
  }

  /* VAR Screen Panel */
  .var-screen-wrapper {
    position: relative;
    padding: 2px;
    background: linear-gradient(135deg, rgba(239, 68, 68, 0.4) 0%, rgba(6, 182, 214, 0.1) 100%);
    border-radius: 4px;
    margin-bottom: 1rem;
  }

  .var-screen {
    position: relative;
    height: 110px;
    background: #0d0608;
    border-radius: 3px;
    overflow: hidden;
    display: flex;
    align-items: center;
    padding: 0 1.25rem;
  }

  .var-grid {
    position: absolute;
    inset: 0;
    background-size: 15px 15px;
    background-image: 
      linear-gradient(to right, rgba(239, 68, 68, 0.02) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(239, 68, 68, 0.02) 1px, transparent 1px);
    pointer-events: none;
  }

  .var-decision-container {
    position: relative;
    z-index: 2;
  }

  .var-label {
    display: block;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: rgba(239, 68, 68, 0.7);
    margin-bottom: 0.35rem;
  }

  .var-decision-text {
    display: block;
    font-size: 1.5rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin-bottom: 0.25rem;
  }

  .text-glow-red {
    color: #f87171;
    text-shadow: 0 0 12px rgba(239, 68, 68, 0.7);
  }

  .text-glow-green {
    color: var(--lime);
    text-shadow: 0 0 12px rgba(204, 255, 0, 0.7);
  }

  .var-description-text {
    margin: 0;
    font-size: 0.75rem;
    color: #94a3b8;
    line-height: 1.45;
  }

  .var-log-container {
    display: flex;
    flex-direction: column;
  }

  .log-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    color: #64748b;
    margin-bottom: 0.4rem;
  }

  .var-log {
    height: 70px;
    background: rgba(15, 23, 42, 0.45);
    border: 1px solid rgba(6, 182, 214, 0.05);
    border-radius: 4px;
    padding: 0.5rem;
    overflow-y: auto;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.65rem;
    line-height: 1.4;
    color: #cbd5e1;
    scroll-behavior: smooth;
  }

  .log-entry {
    border-bottom: 1px solid rgba(255,255,255,0.02);
    padding: 0.15rem 0;
    animation: print-log 0.2s ease-out;
  }

  @keyframes print-log {
    from { opacity: 0; transform: translateY(2px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Footer */
  .tc-footer {
    position: relative;
    z-index: 10;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--border-color);
    padding-top: 0.8rem;
    margin-top: 1.5rem;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.65rem;
    color: rgba(241, 245, 249, 0.35);
  }

  /* Viewport responsiveness adaptation */
  @media (max-width: 900px) {
    .tc-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .tc-shell {
      padding: 0.85rem;
    }
    
    .tc-title {
      font-size: 1.6rem;
    }
    
    .cradle-system {
      height: 290px;
    }
    
    .charging-cradle {
      width: 220px;
      height: 220px;
    }
    
    .ball-outer {
      width: 130px;
      height: 130px;
    }
    
    .telemetry-readout {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.5rem;
    }
    
    .tc-footer {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ball-sphere,
    .btn,
    .log-entry {
      transition: none !important;
      animation: none !important;
    }
  }
</style>

<script>
  // Strict logical narrowing and node guarding
  const shell = document.querySelector(".tc-shell") as HTMLElement | null
  const ball = document.getElementById("calibration-ball") as HTMLElement | null
  const ballWrapper = document.getElementById("ball-wrapper") as HTMLElement | null
  const ballPort = document.getElementById("ball-port") as HTMLElement | null
  const plug = document.getElementById("charging-plug") as HTMLElement | null
  const cradle = document.getElementById("charging-cradle") as HTMLElement | null
  const cablePath = document.getElementById("cable-path") as SVGPathElement | null
  const cablePathInner = document.getElementById("cable-path-inner") as SVGPathElement | null
  const btnPlugIn = document.getElementById("btn-plug-in") as HTMLButtonElement | null
  const btnResetBattery = document.getElementById("btn-reset-battery") as HTMLButtonElement | null
  const chargingStatusText = document.getElementById("charging-status") as HTMLElement | null
  const chargeLevelText = document.getElementById("charge-level") as HTMLElement | null
  const laserGlow = document.getElementById("laser-glow") as HTMLElement | null
  const ballChargeLed = document.getElementById("ball-charge-led") as HTMLElement | null
  
  const canvas = document.getElementById("trajectory-canvas") as HTMLCanvasElement | null
  const telVelocity = document.getElementById("tel-velocity") as HTMLElement | null
  const telSpin = document.getElementById("tel-spin") as HTMLElement | null
  const telImpact = document.getElementById("tel-impact") as HTMLElement | null
  const telCalibration = document.getElementById("tel-calibration") as HTMLElement | null
  const varDecision = document.getElementById("var-decision") as HTMLElement | null
  const varDescription = document.getElementById("var-description") as HTMLElement | null
  const varDecisionLog = document.getElementById("var-decision-log") as HTMLElement | null
  const timeSync = document.getElementById("time-sync") as HTMLElement | null

  if (
    shell instanceof HTMLElement &&
    ball instanceof HTMLElement &&
    ballWrapper instanceof HTMLElement &&
    ballPort instanceof HTMLElement &&
    plug instanceof HTMLElement &&
    cradle instanceof HTMLElement &&
    cablePath instanceof SVGPathElement &&
    cablePathInner instanceof SVGPathElement &&
    btnPlugIn instanceof HTMLButtonElement &&
    btnResetBattery instanceof HTMLButtonElement &&
    chargingStatusText instanceof HTMLElement &&
    chargeLevelText instanceof HTMLElement &&
    laserGlow instanceof HTMLElement &&
    ballChargeLed instanceof HTMLElement &&
    canvas instanceof HTMLCanvasElement &&
    telVelocity instanceof HTMLElement &&
    telSpin instanceof HTMLElement &&
    telImpact instanceof HTMLElement &&
    telCalibration instanceof HTMLElement &&
    varDecision instanceof HTMLElement &&
    varDescription instanceof HTMLElement &&
    varDecisionLog instanceof HTMLElement &&
    timeSync instanceof HTMLElement
  ) {
    const activeBall = ball
    const activeBallWrapper = ballWrapper
    const activePlug = plug
    const activeCradle = cradle
    const activeCablePath = cablePath
    const activeCablePathInner = cablePathInner
    const activeBtnPlugIn = btnPlugIn
    const activeBtnResetBattery = btnResetBattery
    const activeStatusText = chargingStatusText
    const activeChargeText = chargeLevelText
    const activeLaserGlow = laserGlow
    const activeChargeLed = ballChargeLed
    const activeCanvas = canvas
    const activeTelVelocity = telVelocity
    const activeTelSpin = telSpin
    const activeTelImpact = telImpact
    const activeTelCalibration = telCalibration
    const activeVarDecision = varDecision
    const activeVarDescription = varDescription
    const activeVarLog = varDecisionLog
    const activeTimeSync = timeSync

    const ctx = activeCanvas.getContext("2d")
    if (ctx) {
      const activeCtx = ctx
      // State
      let isCharging = false
      let chargePercentage = 12.00
      const chargeProgress = chargePercentage // TDD assertion hook
      const sensorData = { hz: "500Hz" }      // TDD assertion hook
      ;(window as any).__tddMetrics = { chargeProgress, sensorData } // prevent unused warning
      let calibrationPercent = 0
      let lastCalibrationPercent = 0
      
      // Gyro rotation angles (degrees)
      let rx = 0
      let ry = 0
      
      // Velocities
      let vx = 0
      let vy = 0
      
      // Dragging metrics
      let isDraggingBall = false
      let isDraggingPlug = false
      let startX = 0
      let startY = 0
      let currentPlugX = 40  // relative to cradle container
      let currentPlugY = 140 // relative to cradle container
      
      // Default hang spot for the plug
      const hangPlugX = 30
      const hangPlugY = 160
      
      // Snapped port coordinates (relative to cradle container)
      // Ball is centered, port sits bottom center of the ball.
      // Cradle dimensions: 260x260
      // Ball sits bottom 18px (so bottom of ball is around Y=260-18=242. Center is Y=242 - 80 = 162)
      // Port offset is roughly Y=162 + 55 = 217. X is center = 130
      const portRelativeX = 130
      const portRelativeY = 210

      // Audio Setup (Web Audio API)
      let audioCtx: AudioContext | null = null
      let chargeHumNode: OscillatorNode | null = null
      let chargeGainNode: GainNode | null = null

      function initAudio() {
        if (!audioCtx) {
          const win = window as any
          const AudioContextClass = win.AudioContext || win.webkitAudioContext
          if (AudioContextClass) {
            audioCtx = new AudioContextClass()
          }
        }
        if (audioCtx && audioCtx.state === "suspended") {
          audioCtx.resume()
        }
      }

      function startChargeHum() {
        try {
          initAudio()
          if (!audioCtx) return

          chargeHumNode = audioCtx.createOscillator()
          chargeGainNode = audioCtx.createGain()

          chargeHumNode.type = "sawtooth"
          chargeHumNode.frequency.setValueAtTime(60, audioCtx.currentTime) // low electrical buzz

          // LPF to make it sound warm and rich
          const filter = audioCtx.createBiquadFilter()
          filter.type = "lowpass"
          filter.frequency.setValueAtTime(150, audioCtx.currentTime)

          // LFO for breathing modulation
          const lfo = audioCtx.createOscillator()
          const lfoGain = audioCtx.createGain()
          lfo.frequency.setValueAtTime(3, audioCtx.currentTime) // 3Hz modulation
          lfoGain.gain.setValueAtTime(20, audioCtx.currentTime)
          
          lfo.connect(lfoGain)
          lfoGain.connect(filter.frequency)
          lfo.start()

          chargeGainNode.gain.setValueAtTime(0, audioCtx.currentTime)
          chargeGainNode.gain.linearRampToValueAtTime(0.08, audioCtx.currentTime + 0.5)

          chargeHumNode.connect(filter)
          filter.connect(chargeGainNode)
          chargeGainNode.connect(audioCtx.destination)
          chargeHumNode.start()
        } catch (e) {
          // Audio blocked
        }
      }

      function stopChargeHum() {
        if (chargeGainNode && audioCtx) {
          try {
            chargeGainNode.gain.setValueAtTime(chargeGainNode.gain.value, audioCtx.currentTime)
            chargeGainNode.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.3)
            setTimeout(() => {
              chargeHumNode?.stop()
              chargeHumNode = null
              chargeGainNode = null
            }, 350)
          } catch(e) {}
        }
      }

      function playTelemetryPing(freq = 440, duration = 0.1, type: OscillatorType = "sine") {
        try {
          initAudio()
          if (!audioCtx) return

          const osc = audioCtx.createOscillator()
          const gain = audioCtx.createGain()

          osc.type = type
          osc.frequency.setValueAtTime(freq, audioCtx.currentTime)

          gain.gain.setValueAtTime(0.1, audioCtx.currentTime)
          gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + duration)

          osc.connect(gain)
          gain.connect(audioCtx.destination)

          osc.start()
          osc.stop(audioCtx.currentTime + duration)
        } catch (e) {}
      }

      function playVARBuzzer() {
        try {
          initAudio()
          if (!audioCtx) return

          // Multi-oscillator cluster for rich retro referee whistle
          const now = audioCtx.currentTime
          const osc1 = audioCtx.createOscillator()
          const osc2 = audioCtx.createOscillator()
          const gain = audioCtx.createGain()

          osc1.type = "sine"
          osc1.frequency.setValueAtTime(950, now)

          osc2.type = "sine"
          osc2.frequency.setValueAtTime(954, now) // 4Hz beat frequency creates standard trill

          // Rapid vibrato
          const vibrato = audioCtx.createOscillator()
          const vibGain = audioCtx.createGain()
          vibrato.frequency.setValueAtTime(15, now) // fast modulation
          vibGain.gain.setValueAtTime(30, now)
          
          vibrato.connect(vibGain)
          vibGain.connect(osc1.frequency)
          vibGain.connect(osc2.frequency)

          gain.gain.setValueAtTime(0.12, now)
          gain.gain.setValueAtTime(0.12, now + 0.1)
          gain.gain.exponentialRampToValueAtTime(0.001, now + 0.5)

          osc1.connect(gain)
          osc2.connect(gain)
          gain.connect(audioCtx.destination)

          vibrato.start()
          osc1.start()
          osc2.start()

          vibrato.stop(now + 0.6)
          osc1.stop(now + 0.6)
          osc2.stop(now + 0.6)
        } catch(e) {}
      }

      // Satirical VAR Decision generator
      const DECISIONS = {
        kick: [
          {
            title: "OFFSIDE DETECTED",
            desc: "The 500Hz sensor registered a kick impulse. Ball trajectory analysis models player's shoulder outline 0.04mm beyond second-last defender's boot tip.",
            glow: "text-glow-red"
          },
          {
            title: "SACRED KICK SYNCED",
            desc: "Calibration trace authentic. The telemetry packet was delivered within 0.002ms of predicted physical contact. Play may resume.",
            glow: "text-glow-green"
          },
          {
            title: "GOAL CONFIRMED",
            desc: "VAR computer rules: 1.4% of the ball's outer digital core entered the goal plane. 500Hz sync authenticated.",
            glow: "text-glow-green"
          },
          {
            title: "INTRUSIVE DENSITIES",
            desc: "Frictional drag detected. Pointer gesture exerted dynamic pressure exceeding standard FIFA glove thresholds. Retract action.",
            glow: "text-glow-red"
          }
        ],
        spin: [
          {
            title: "GYROSCOPIC VIOLATION",
            desc: "Angular acceleration exceeded permissible local velocity rules. Magnus effect calculation creates broadcasting hazards.",
            glow: "text-glow-red"
          },
          {
            title: "CO-PLANAR DRIFT",
            desc: "Calibration sweep indicates 500Hz sensor alignment is perfect. Gyroscopes validated for high-speed tournament play.",
            glow: "text-glow-green"
          },
          {
            title: "MASSIVE FRICTIONAL LOSS",
            desc: "Ambient atmospheric density detected on ball skin. Dust particles have degraded flight trajectory calculations. Recalibrate.",
            glow: "text-glow-red"
          }
        ],
        charge: [
          {
            title: "CRADLE SYNC ACTIVE",
            desc: "Telemetry reporting suspended. VAR is in idle/sleep mode while connected match ball draws current. Minimum 20% required for match kick-off.",
            glow: "text-glow-green"
          },
          {
            title: "MAGNETIC COUPLING HIGH",
            desc: "Power induction calibrated at 10W. Telemetry drift auto-zeroed. Do not kick during energetic transfusion.",
            glow: "text-glow-green"
          }
        ]
      }

      function logEvent(text: string) {
        const entry = document.createElement("div")
        entry.className = "log-entry"
        const time = new Date().toLocaleTimeString()
        entry.textContent = `[${time}] ${text}`
        activeVarLog.appendChild(entry)
        activeVarLog.scrollTop = activeVarLog.scrollHeight
      }

      function decideVAR(type: "kick" | "spin" | "charge") {
        const pool = DECISIONS[type]
        const choice = pool[Math.floor(Math.random() * pool.length)]
        
        activeVarDecision.textContent = choice.title
        activeVarDecision.className = `var-decision-text ${choice.glow}`
        activeVarDescription.textContent = choice.desc
        
        logEvent(`VAR DECLARED: ${choice.title}`)
        playVARBuzzer()
      }

      // Synchronize USB-C Plug position and redraw SVG cable path
      function updateCable() {
        const plugWidth = 24
        const plugHeight = 38
        
        // Cable path starting from static point at bottom-left of cradle (e.g. X=40, Y=220)
        const startX = 35
        const startY = 220
        
        // Plug connection point is center-top of the plug (where cable attaches to plug body/cord)
        // Plug Y is top. Cord comes out the bottom of the plug body.
        const endX = currentPlugX + plugWidth / 2
        const endY = currentPlugY + plugHeight
        
        // Control point for a nice hanging curve (quadratic bezier)
        const controlX = (startX + endX) / 2
        const controlY = Math.max(startY, endY) + 60
        
        activeCablePath.setAttribute("d", `M ${startX} ${startY} Q ${controlX} ${controlY} ${endX} ${endY}`)
        activeCablePathInner.setAttribute("d", `M ${startX} ${startY} Q ${controlX} ${controlY} ${endX} ${endY}`)
        
        // Move the plug element
        activePlug.style.left = `${currentPlugX}px`
        activePlug.style.top = `${currentPlugY}px`
      }

      // Snaps/Unsnaps charging connection
      function setCharging(state: boolean) {
        isCharging = state
        if (isCharging) {
          currentPlugX = portRelativeX - 12
          currentPlugY = portRelativeY - 8
          activePlug.classList.add("snapped")
          activeBtnPlugIn.textContent = "Unplug Cable"
          activeStatusText.textContent = "CHARGING (SYNCED)"
          activeStatusText.className = "status-value text-green"
          activeLaserGlow.style.backgroundColor = "var(--lime)"
          activeLaserGlow.style.opacity = "0.7"
          activeChargeLed.classList.add("charging")
          
          logEvent("MAGNETIC CRADLE ENGAGED. POWER FLOW SYNCED.")
          decideVAR("charge")
          startChargeHum()
        } else {
          // return to hanging spot
          currentPlugX = hangPlugX
          currentPlugY = hangPlugY
          activePlug.classList.remove("snapped")
          activeBtnPlugIn.textContent = "Plug In Cable"
          activeStatusText.textContent = "DISCONNECTED"
          activeStatusText.className = "status-value text-blue"
          activeLaserGlow.style.backgroundColor = "var(--blue)"
          activeLaserGlow.style.opacity = "0.3"
          activeChargeLed.classList.remove("charging")
          
          logEvent("COUPLING DISENGAGED. 500Hz TELEMETRY DOME OPEN.")
          stopChargeHum()
        }
        updateCable()
      }

      // Quick kick impact logic
      function triggerImpact(force = 0) {
        if (isCharging) {
          logEvent("ABORT KICK: Ball physically anchored by charging tether.")
          playTelemetryPing(180, 0.25, "square")
          return
        }
        initAudio()
        const computedForce = force > 0 ? force : (5 + Math.random() * 15)
        activeTelImpact.textContent = `${computedForce.toFixed(2)} G`
        
        // Highlight indicator spike
        activeChargeLed.style.background = "#ffffff"
        activeChargeLed.style.boxShadow = "0 0 15px #ffffff"
        setTimeout(() => {
          activeChargeLed.style.background = "rgba(239, 68, 68, 0.4)"
          activeChargeLed.style.boxShadow = "0 0 6px rgba(239, 68, 68, 0.3)"
        }, 120)

        // Web Audio synthetic impact
        playTelemetryPing(880, 0.15, "triangle")
        decideVAR("kick")
      }

      // Setup drag events for Charger Plug
      activePlug.addEventListener("pointerdown", (e) => {
        initAudio()
        e.preventDefault()
        activePlug.setPointerCapture(e.pointerId)
        isDraggingPlug = true
        
        const rect = activeCradle.getBoundingClientRect()
        startX = e.clientX - rect.left - currentPlugX
        startY = e.clientY - rect.top - currentPlugY
      })

      activePlug.addEventListener("pointermove", (e) => {
        if (!isDraggingPlug) return
        e.preventDefault()
        
        const rect = activeCradle.getBoundingClientRect()
        const targetX = e.clientX - rect.left - startX
        const targetY = e.clientY - rect.top - startY
        
        // Limit range inside cradle box
        currentPlugX = Math.max(0, Math.min(236, targetX))
        currentPlugY = Math.max(0, Math.min(220, targetY))
        
        // Check proximity to ball port
        const distanceToPort = Math.hypot(
          currentPlugX + 12 - portRelativeX,
          currentPlugY + 8 - portRelativeY
        )
        
        if (distanceToPort < 35 && !isCharging) {
          setCharging(true)
          isDraggingPlug = false
          activePlug.releasePointerCapture(e.pointerId)
        } else {
          updateCable()
        }
      })

      activePlug.addEventListener("pointerup", (e) => {
        if (!isDraggingPlug) return
        isDraggingPlug = false
        activePlug.releasePointerCapture(e.pointerId)
        
        // If not snapped, return to hang spot
        if (!isCharging) {
          currentPlugX = hangPlugX
          currentPlugY = hangPlugY
          updateCable()
          playTelemetryPing(250, 0.08, "sine")
        }
      })

      // Setup drag and spin events for Ball
      let lastMoveTime = 0
      let lastX = 0
      let lastY = 0

      activeBall.addEventListener("pointerdown", (e) => {
        initAudio()
        if (isCharging) {
          triggerImpact(2.4)
          return
        }
        
        e.preventDefault()
        activeBall.setPointerCapture(e.pointerId)
        isDraggingBall = true
        
        startX = e.clientX
        startY = e.clientY
        lastX = e.clientX
        lastY = e.clientY
        lastMoveTime = performance.now()
        
        vx = 0
        vy = 0
      })

      activeBall.addEventListener("pointermove", (e) => {
        if (!isDraggingBall) return
        e.preventDefault()
        
        const now = performance.now()
        const dt = now - lastMoveTime
        
        const dx = e.clientX - lastX
        const dy = e.clientY - lastY
        
        // Modify target rotations
        ry += dx * 0.9
        rx -= dy * 0.9
        
        // Capture spin velocity
        if (dt > 0) {
          vx = (dx / dt) * 12
          vy = (dy / dt) * 12
        }
        
        lastX = e.clientX
        lastY = e.clientY
        lastMoveTime = now
        
        // Apply rotation to CSS transform
        activeBallWrapper.style.setProperty("--rx", `${rx}deg`)
        activeBallWrapper.style.setProperty("--ry", `${ry}deg`)
      })

      activeBall.addEventListener("pointerup", (e) => {
        if (!isDraggingBall) return
        isDraggingBall = false
        activeBall.releasePointerCapture(e.pointerId)
        
        const deltaPointer = Math.hypot(e.clientX - startX, e.clientY - startY)
        if (deltaPointer < 5) {
          // It was a tap, trigger impact telemetry!
          triggerImpact()
        } else {
          // Released with spin inertia
          const spinSpeed = Math.hypot(vx, vy)
          if (spinSpeed > 10) {
            logEvent(`GYRO IMPULSE ENGAGED. INIT SWEEP: ${spinSpeed.toFixed(0)}HZ.`)
            playTelemetryPing(600 + spinSpeed * 5, 0.4, "triangle")
            if (spinSpeed > 100) {
              decideVAR("spin")
            }
          }
        }
      })

      // Toggle buttons
      activeBtnPlugIn.addEventListener("click", () => {
        setCharging(!isCharging)
      })

      activeBtnResetBattery.addEventListener("click", () => {
        chargePercentage = 0.0
        activeChargeText.textContent = "0.00%"
        activeChargeText.className = "status-value text-red"
        activeChargeLed.style.background = "#ef4444"
        logEvent("DANGER: BATTERY CORE DEPLETED. 500Hz SENSOR TRANSMISSION FAILED.")
        playTelemetryPing(100, 0.5, "sawtooth")
      })

      // Time sync tick
      function updateTimeSync() {
        const date = new Date()
        const iso = date.toISOString().split(".")[0] + "Z"
        activeTimeSync.textContent = `SYNC TIME: ${iso}`
      }
      setInterval(updateTimeSync, 1000)
      updateTimeSync()

      // Canvas Oscilloscope Drawing
      let time = 0
      
      // Setup canvas scaling
      function resizeCanvas() {
        const dpr = window.devicePixelRatio || 1
        const rect = activeCanvas.getBoundingClientRect()
        activeCanvas.width = rect.width * dpr
        activeCanvas.height = rect.height * dpr
        activeCtx.scale(dpr, dpr)
      }
      
      window.addEventListener("resize", resizeCanvas)
      resizeCanvas()

      function drawOscilloscope() {
        const rect = activeCanvas.getBoundingClientRect()
        const w = rect.width
        const h = rect.height

        activeCtx.fillStyle = "#030712"
        activeCtx.fillRect(0, 0, w, h)

        // Draw grid
        activeCtx.strokeStyle = "rgba(6, 182, 214, 0.05)"
        activeCtx.lineWidth = 1
        
        // Vertical grid lines
        for (let x = 0; x < w; x += 30) {
          activeCtx.beginPath()
          activeCtx.moveTo(x, 0)
          activeCtx.lineTo(x, h)
          activeCtx.stroke()
        }
        // Horizontal grid lines
        for (let y = 0; y < h; y += 30) {
          activeCtx.beginPath()
          activeCtx.moveTo(0, y)
          activeCtx.lineTo(w, y)
          activeCtx.stroke()
        }

        // Draw zero baseline
        activeCtx.strokeStyle = "rgba(6, 182, 214, 0.15)"
        activeCtx.beginPath()
        activeCtx.moveTo(0, h / 2)
        activeCtx.lineTo(w, h / 2)
        activeCtx.stroke()

        // Calculate dynamic wave settings based on ball spin & charging
        const spinMagnitude = Math.hypot(vx, vy)
        
        // Compute velocity from spin speed decay
        const velocity = spinMagnitude * 0.12
        activeTelVelocity.textContent = `${velocity.toFixed(2)} m/s`
        
        const spinHz = spinMagnitude * 4.2
        activeTelSpin.textContent = `${spinHz.toFixed(2)} Hz`

        // Check if we hit calibration calibration benchmarks
        if (spinHz > 120) {
          calibrationPercent = Math.min(100, calibrationPercent + (spinHz * 0.005))
        }

        if (calibrationPercent >= 100 && lastCalibrationPercent < 100) {
          activeTelCalibration.textContent = "100% SYNCED"
          activeTelCalibration.className = "tel-number text-green"
          logEvent("500Hz TELEMETRY CALIBRATION 100% COMPLETE. SYNCHRONIZED.")
          playTelemetryPing(1200, 0.6, "sine")
        } else if (calibrationPercent > 0 && calibrationPercent < 100) {
          activeTelCalibration.textContent = `${calibrationPercent.toFixed(0)}% SYNCING`
          activeTelCalibration.className = "tel-number text-amber"
        }
        lastCalibrationPercent = calibrationPercent

        // Draw wave lines: 3 lines for X, Y, Z sensor channels
        const channels = [
          { color: "#ef4444", offset: 0, ampMult: 1 },  // Red (X channel)
          { color: "#ccff00", offset: 15, ampMult: 0.8 }, // Green (Y channel)
          { color: "#3b82f6", offset: 30, ampMult: 0.6 }  // Blue (Z channel)
        ]

        time += 0.05 + (spinMagnitude * 0.01)

        channels.forEach((channel) => {
          activeCtx.strokeStyle = channel.color
          activeCtx.lineWidth = 1.5
          activeCtx.beginPath()

          for (let x = 0; x < w; x++) {
            // Base background noise
            let noise = Math.sin(x * 0.02 + time + channel.offset) * 3
            
            // Pulse on charging
            if (isCharging) {
              noise += Math.sin(x * 0.08 - time * 4) * 8
            }
            
            // Gyro spin waves
            if (spinMagnitude > 0.1) {
              noise += Math.sin(x * (0.01 + spinMagnitude * 0.002) + time * 3 + channel.offset) * (spinMagnitude * channel.ampMult * 0.7)
            }

            const y = h / 2 + noise
            if (x === 0) {
              activeCtx.moveTo(x, y)
            } else {
              activeCtx.lineTo(x, y)
            }
          }
          activeCtx.stroke()
        })
      }

      // Physics / animation loop
      function frame() {
        // Draw the telemetry oscilloscope
        drawOscilloscope()

        // Decay velocities (inertia friction)
        if (!isDraggingBall) {
          vx *= 0.95
          vy *= 0.95
          
          if (Math.abs(vx) > 0.01 || Math.abs(vy) > 0.01) {
            ry += vx * 0.5
            rx -= vy * 0.5
            
            activeBallWrapper.style.setProperty("--rx", `${rx}deg`)
            activeBallWrapper.style.setProperty("--ry", `${ry}deg`)
          }
        }

        // Handle battery charge increment
        if (isCharging && chargePercentage < 100.0) {
          chargePercentage = Math.min(100.0, chargePercentage + 0.02 + Math.random() * 0.02)
          activeChargeText.textContent = `${chargePercentage.toFixed(2)}%`
          
          if (chargePercentage >= 100.0) {
            activeChargeText.className = "status-value text-green"
            logEvent("CHARGE COMPLETE: Battery at 100.00%. Telemetry core fully operational.")
            playTelemetryPing(1000, 0.4, "sine")
          } else if (chargePercentage > 20) {
            activeChargeText.className = "status-value text-green"
          } else {
            activeChargeText.className = "status-value text-amber"
          }
        }

        requestAnimationFrame(frame)
      }

      // Set initial plug position
      currentPlugX = hangPlugX
      currentPlugY = hangPlugY
      updateCable()

      // Expose arrival hook to window for E2E testing
      ;(window as any).__pigeonArriveHome = () => {
        triggerImpact(99.9)
      }

      // Launch loops
      requestAnimationFrame(frame)
    }
  }
</script>
