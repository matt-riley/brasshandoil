---
import Base from "@layouts/Base.astro"

const routes = [
  { name: "Sunroom Annex", code: "SA", color: "#f97316", note: "warm lint" },
  { name: "Marigold Window", code: "MW", color: "#eab308", note: "gold dust" },
  { name: "Blue Ledger", code: "BL", color: "#2563eb", note: "cool ink" },
  { name: "Mint Courtyard", code: "MC", color: "#10b981", note: "wet tile" },
  { name: "Rose Attic", code: "RA", color: "#e11d48", note: "paper blush" },
  { name: "Blackcurrant Lift", code: "BK", color: "#7c3aed", note: "violet rope" },
]
---

<Base title="Pollen Parcel Bureau">
  <main id="pollen-bureau" class="bureau-shell">
    <section class="bureau-brief" aria-label="Pollen parcel routing counter">
      <p class="bureau-kicker">Day desk / botanical post</p>
      <h1>Pollen Parcel Bureau</h1>
      <p class="bureau-copy">
        Stamp airborne parcels into impossible civic routes before the whole
        counter sneezes its paperwork into the sun.
      </p>

      <div class="bureau-readouts" aria-live="polite">
        <div>
          <span>Delivered</span>
          <strong id="delivery-count">0</strong>
        </div>
        <div>
          <span>Route</span>
          <strong id="current-route">unclaimed</strong>
        </div>
        <div>
          <span>Nectar</span>
          <strong id="nectar-index">0</strong>
        </div>
        <div>
          <span>Counter</span>
          <strong id="counter-state">unstamped</strong>
        </div>
      </div>

      <div class="bureau-actions">
        <button id="dispatch-button" type="button">Dispatch</button>
        <button id="recall-button" type="button">Recall</button>
      </div>
    </section>

    <section
      id="sorting-field"
      class="sorting-field"
      data-awake="false"
      data-deliveries="0"
      aria-label="Interactive pollen parcel sorting field"
    >
      <canvas id="postal-canvas" aria-label="Airborne pollen parcels"></canvas>

      <div class="counter-map" aria-hidden="true">
        <span class="counter-sun"></span>
        <span class="counter-stamp"></span>
        <span class="counter-path path-a"></span>
        <span class="counter-path path-b"></span>
        <span class="counter-path path-c"></span>
      </div>

      <div id="route-ribbon" class="route-ribbon" aria-label="Stamped parcel route">
        <span>awaiting parcel</span>
      </div>

      <div class="parcel-trays" aria-label="Parcel route trays">
        {routes.map((route, index) => (
          <button
            class="parcel-tray"
            type="button"
            data-route={route.name}
            data-code={route.code}
            data-note={route.note}
            data-index={index}
            style={`--tray-color: ${route.color}; --tray-index: ${index};`}
            aria-pressed="false"
          >
            <b>{route.code}</b>
            <span>{route.name}</span>
          </button>
        ))}
      </div>
    </section>
  </main>
</Base>

<style>
  :global(body) {
    margin: 0;
    background: #fff7dc;
  }

  :global(.container) {
    max-inline-size: none;
    padding-inline: 0;
  }

  .bureau-shell {
    --paper: #fff7dc;
    --ink: #222015;
    --green: #0f7a55;
    --blue: #2563eb;
    --rose: #e11d48;
    --amber: #f59e0b;
    --line: rgba(34, 32, 21, 0.16);
    --cursor-x: 50%;
    --cursor-y: 46%;
    display: grid;
    grid-template-columns: minmax(17rem, 24rem) minmax(0, 1fr);
    gap: clamp(1rem, 2.6vw, 2rem);
    min-height: calc(100vh - 6rem);
    overflow: hidden;
    padding: clamp(1rem, 2.4vw, 1.8rem);
    color: var(--ink);
    background:
      linear-gradient(115deg, rgba(255, 247, 220, 0.92), rgba(255, 247, 220, 0.72)),
      repeating-linear-gradient(90deg, rgba(37, 99, 235, 0.08) 0 1px, transparent 1px 58px),
      linear-gradient(160deg, #fff1a8 0%, #d8f7cf 38%, #f4dcff 72%, #ffd6b1 100%);
    font-family: Inter, ui-sans-serif, system-ui, sans-serif;
    isolation: isolate;
  }

  .bureau-brief {
    align-self: center;
    display: grid;
    gap: 1rem;
    min-width: 0;
    padding-block: 1rem;
  }

  .bureau-kicker,
  .bureau-readouts span {
    margin: 0;
    color: var(--green);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 9ch;
    margin: 0;
    color: #1f2937;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2.5rem, 5.8vw, 5.25rem);
    font-weight: 900;
    letter-spacing: 0;
    line-height: 0.88;
    text-shadow:
      0.035em 0.045em 0 rgba(234, 179, 8, 0.42),
      -0.035em 0.028em 0 rgba(16, 185, 129, 0.28);
  }

  .bureau-copy {
    max-width: 33rem;
    margin: 0;
    color: rgba(34, 32, 21, 0.76);
    font-size: clamp(1rem, 1.35vw, 1.12rem);
    line-height: 1.58;
  }

  .bureau-readouts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.72rem;
  }

  .bureau-readouts div {
    min-width: 0;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 0.78rem;
    background: rgba(255, 255, 255, 0.52);
    box-shadow: 0 0.9rem 2rem rgba(45, 38, 12, 0.08);
  }

  .bureau-readouts strong {
    display: block;
    min-height: 1.45rem;
    margin-top: 0.4rem;
    color: #18170f;
    font-size: clamp(1rem, 1.8vw, 1.34rem);
    line-height: 1.08;
    overflow-wrap: anywhere;
  }

  .bureau-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.72rem;
  }

  .bureau-actions button {
    min-height: 3.1rem;
    border: 1px solid rgba(34, 32, 21, 0.2);
    border-radius: 8px;
    color: #18170f;
    background: var(--amber);
    font: 850 0.82rem/1 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      transform 160ms ease,
      filter 160ms ease;
  }

  .bureau-actions button:hover {
    filter: brightness(1.04);
    transform: translateY(-1px);
  }

  #recall-button {
    color: #f8fafc;
    background: #334155;
  }

  .sorting-field {
    position: relative;
    align-self: stretch;
    min-width: 0;
    min-height: min(43rem, calc(100vh - 8rem));
    overflow: hidden;
    border: 1px solid rgba(34, 32, 21, 0.14);
    border-radius: 8px;
    background:
      radial-gradient(circle at var(--cursor-x) var(--cursor-y), rgba(255, 255, 255, 0.78), transparent 9rem),
      linear-gradient(180deg, rgba(255, 255, 255, 0.52), rgba(255, 247, 220, 0.22));
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.32);
    touch-action: none;
  }

  .sorting-field::before {
    content: "";
    position: absolute;
    inset: 1rem;
    border: 1px dashed rgba(34, 32, 21, 0.18);
    border-radius: 8px;
    pointer-events: none;
  }

  #postal-canvas {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
  }

  .counter-map {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .counter-sun {
    position: absolute;
    top: 7%;
    right: 8%;
    width: clamp(5.5rem, 12vw, 9rem);
    aspect-ratio: 1;
    border-radius: 999px;
    background:
      radial-gradient(circle, #fff8b8 0 35%, #facc15 36% 61%, rgba(250, 204, 21, 0.16) 62%);
    box-shadow: 0 0 4rem rgba(250, 204, 21, 0.45);
  }

  .counter-stamp {
    position: absolute;
    left: var(--cursor-x);
    top: var(--cursor-y);
    width: 5.2rem;
    height: 5.2rem;
    border: 2px solid rgba(15, 122, 85, 0.62);
    border-radius: 999px;
    background:
      linear-gradient(45deg, transparent 46%, rgba(15, 122, 85, 0.45) 47% 53%, transparent 54%),
      linear-gradient(-45deg, transparent 46%, rgba(225, 29, 72, 0.36) 47% 53%, transparent 54%),
      rgba(255, 255, 255, 0.3);
    transform: translate(-50%, -50%);
    box-shadow:
      0 0 0 0.65rem rgba(255, 255, 255, 0.16),
      0 0.5rem 2rem rgba(15, 23, 42, 0.08);
  }

  .counter-path {
    position: absolute;
    left: 12%;
    right: 12%;
    height: 0.42rem;
    border-radius: 999px;
    opacity: 0.54;
    transform-origin: center;
  }

  .path-a {
    top: 29%;
    background: repeating-linear-gradient(90deg, #e11d48 0 1.2rem, transparent 1.2rem 2rem);
    rotate: -7deg;
  }

  .path-b {
    top: 47%;
    background: repeating-linear-gradient(90deg, #2563eb 0 0.8rem, transparent 0.8rem 1.55rem);
    rotate: 4deg;
  }

  .path-c {
    top: 66%;
    background: repeating-linear-gradient(90deg, #10b981 0 1rem, transparent 1rem 1.7rem);
    rotate: -3deg;
  }

  .route-ribbon {
    position: absolute;
    left: clamp(1rem, 3vw, 2rem);
    right: clamp(1rem, 3vw, 2rem);
    top: clamp(1rem, 3vw, 2rem);
    z-index: 2;
    display: flex;
    align-items: center;
    min-height: 3.4rem;
    border: 1px solid rgba(34, 32, 21, 0.18);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    color: #18170f;
    background: rgba(255, 255, 255, 0.68);
    font: 850 clamp(0.84rem, 1.7vw, 1.2rem)/1.2 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    text-transform: uppercase;
    box-shadow: 0 1rem 2.5rem rgba(34, 32, 21, 0.08);
  }

  .route-ribbon span {
    overflow-wrap: anywhere;
  }

  .parcel-trays {
    position: absolute;
    inset-inline: clamp(1rem, 3vw, 2rem);
    bottom: clamp(1rem, 3vw, 2rem);
    z-index: 3;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.68rem;
  }

  .parcel-tray {
    position: relative;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    gap: 0.64rem;
    min-width: 0;
    min-height: 4.1rem;
    border: 1px solid rgba(34, 32, 21, 0.2);
    border-radius: 8px;
    padding: 0.62rem;
    color: #18170f;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 0.8rem 1.6rem rgba(34, 32, 21, 0.09);
    cursor: pointer;
    transition:
      border-color 160ms ease,
      transform 160ms ease,
      background 160ms ease;
  }

  .parcel-tray:hover,
  .parcel-tray:focus-visible,
  .parcel-tray[aria-pressed="true"] {
    border-color: var(--tray-color);
    background: color-mix(in srgb, var(--tray-color) 16%, white);
    transform: translateY(-2px);
  }

  .parcel-tray b {
    display: grid;
    place-items: center;
    width: 2.35rem;
    aspect-ratio: 1;
    border-radius: 999px;
    color: #fff;
    background: var(--tray-color);
    font-size: 0.82rem;
  }

  .parcel-tray span {
    min-width: 0;
    font-size: clamp(0.78rem, 1.3vw, 0.96rem);
    font-weight: 850;
    line-height: 1.12;
    overflow-wrap: anywhere;
    text-align: left;
  }

  .sorting-field[data-awake="true"] .counter-stamp {
    animation: stamp-pulse 1.8s ease-in-out infinite;
  }

  .sorting-field[data-dispatched="true"] .route-ribbon {
    background: #18170f;
    color: #fff7dc;
  }

  @keyframes stamp-pulse {
    0%,
    100% {
      scale: 1;
    }

    50% {
      scale: 1.08;
    }
  }

  @media (max-width: 860px) {
    .bureau-shell {
      grid-template-columns: 1fr;
      min-height: auto;
      overflow-x: hidden;
    }

    .bureau-brief {
      align-self: start;
      padding-block: 0;
    }

    h1 {
      max-width: 12ch;
      font-size: clamp(2.35rem, 14vw, 4.2rem);
    }

    .sorting-field {
      min-height: 42rem;
    }

    .parcel-trays {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 520px) {
    .bureau-shell {
      padding: 0.82rem;
    }

    .bureau-readouts,
    .bureau-actions {
      grid-template-columns: 1fr;
    }

    .sorting-field {
      min-height: 45rem;
    }

    .route-ribbon {
      top: 0.82rem;
      left: 0.82rem;
      right: 0.82rem;
    }

    .parcel-trays {
      inset-inline: 0.82rem;
      bottom: 0.82rem;
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 1ms !important;
      scroll-behavior: auto !important;
      transition-duration: 1ms !important;
    }
  }
</style>

<script is:inline>
  const field = document.querySelector("#sorting-field")
  const canvas = document.querySelector("#postal-canvas")
  const ribbon = document.querySelector("#route-ribbon span")
  const deliveryCount = document.querySelector("#delivery-count")
  const currentRoute = document.querySelector("#current-route")
  const nectarIndex = document.querySelector("#nectar-index")
  const counterState = document.querySelector("#counter-state")
  const dispatchButton = document.querySelector("#dispatch-button")
  const recallButton = document.querySelector("#recall-button")
  const trays = Array.from(document.querySelectorAll(".parcel-tray"))
  const ctx = canvas.getContext("2d")
  const normalizedCursor = { x: 0.5, y: 0.46 }
  const parcels = Array.from({ length: 74 }, (_, index) => ({
    x: ((index * 37) % 100) / 100,
    y: ((index * 53) % 100) / 100,
    size: 2.8 + (index % 7) * 0.55,
    speed: 0.00045 + (index % 9) * 0.00008,
    spin: (index % 13) * 0.31,
    hue: ["#f97316", "#eab308", "#10b981", "#2563eb", "#e11d48", "#7c3aed"][index % 6],
  }))
  const state = {
    deliveries: 0,
    nectar: 0,
    route: "unclaimed",
    code: "",
    note: "",
    tick: 0,
    awake: false,
  }

  function clamp(value, min, max) {
    return Math.min(max, Math.max(min, value))
  }

  function updateCursor(clientX, clientY) {
    const rect = field.getBoundingClientRect()
    normalizedCursor.x = clamp((clientX - rect.left) / rect.width, 0, 1)
    normalizedCursor.y = clamp((clientY - rect.top) / rect.height, 0, 1)
    field.style.setProperty("--cursor-x", `${normalizedCursor.x * 100}%`)
    field.style.setProperty("--cursor-y", `${normalizedCursor.y * 100}%`)
    field.dataset.awake = "true"
    state.awake = true
  }

  function setPressed(activeTray) {
    trays.forEach((tray) => {
      tray.setAttribute("aria-pressed", tray === activeTray ? "true" : "false")
    })
  }

  function renderReadouts(status = "routing") {
    field.dataset.deliveries = String(state.deliveries)
    deliveryCount.textContent = String(state.deliveries)
    currentRoute.textContent = state.route
    nectarIndex.textContent = String(state.nectar)
    counterState.textContent = status
    ribbon.textContent =
      state.deliveries === 0
        ? "awaiting parcel"
        : `${state.code} parcel to ${state.route}: ${state.note}`
  }

  function stampParcel(tray) {
    const index = Number(tray.dataset.index || 0)
    state.deliveries += 1
    state.nectar = Math.min(99, state.nectar + 9 + index)
    state.route = tray.dataset.route || "unlisted route"
    state.code = tray.dataset.code || "??"
    state.note = tray.dataset.note || "postal shimmer"
    field.dataset.dispatched = "false"
    setPressed(tray)
    renderReadouts("stamped")
  }

  function recallParcels() {
    state.deliveries = 0
    state.nectar = 0
    state.route = "unclaimed"
    state.code = ""
    state.note = ""
    field.dataset.dispatched = "false"
    setPressed(null)
    renderReadouts("unstamped")
  }

  function resizeCanvas() {
    const rect = field.getBoundingClientRect()
    const scale = Math.min(2, window.devicePixelRatio || 1)
    canvas.width = Math.max(1, Math.floor(rect.width * scale))
    canvas.height = Math.max(1, Math.floor(rect.height * scale))
    ctx.setTransform(scale, 0, 0, scale, 0, 0)
  }

  function draw() {
    const rect = field.getBoundingClientRect()
    ctx.clearRect(0, 0, rect.width, rect.height)
    state.tick += state.awake ? 1 : 0.35

    for (const parcel of parcels) {
      const pullX = (normalizedCursor.x - parcel.x) * 0.0015
      const pullY = (normalizedCursor.y - parcel.y) * 0.0012
      parcel.x = (parcel.x + parcel.speed + pullX + 1) % 1
      parcel.y = (parcel.y + Math.sin(state.tick * 0.012 + parcel.spin) * 0.0008 + pullY + 1) % 1

      const x = parcel.x * rect.width
      const y = parcel.y * rect.height
      ctx.save()
      ctx.translate(x, y)
      ctx.rotate(state.tick * 0.008 + parcel.spin)
      ctx.fillStyle = parcel.hue
      ctx.globalAlpha = state.awake ? 0.74 : 0.48
      ctx.beginPath()
      ctx.ellipse(0, 0, parcel.size * 1.6, parcel.size, 0, 0, Math.PI * 2)
      ctx.fill()
      ctx.globalAlpha = 0.24
      ctx.fillStyle = "#ffffff"
      ctx.fillRect(-parcel.size * 0.6, -parcel.size * 0.16, parcel.size * 1.2, parcel.size * 0.32)
      ctx.restore()
    }

    requestAnimationFrame(draw)
  }

  trays.forEach((tray) => {
    tray.addEventListener("click", () => stampParcel(tray))
  })

  dispatchButton.addEventListener("click", () => {
    field.dataset.dispatched = "true"
    renderReadouts(state.deliveries > 0 ? "dispatched" : "needs parcel")
  })

  recallButton.addEventListener("click", recallParcels)

  field.addEventListener("pointermove", (event) => {
    updateCursor(event.clientX, event.clientY)
  })

  field.addEventListener("touchstart", (event) => {
    const touch = event.touches[0]
    if (touch) {
      updateCursor(touch.clientX, touch.clientY)
    }
  })

  field.addEventListener("touchmove", (event) => {
    const touch = event.touches[0]
    if (touch) {
      updateCursor(touch.clientX, touch.clientY)
    }
  })

  field.addEventListener("touchend", () => {
    field.dataset.awake = state.awake ? "true" : "false"
  })

  window.addEventListener("keydown", (event) => {
    const keyIndex = Number(event.key) - 1
    if (keyIndex >= 0 && keyIndex < trays.length) {
      stampParcel(trays[keyIndex])
      return
    }

    const step = event.shiftKey ? 0.035 : 0.07
    if (event.key === "ArrowLeft") normalizedCursor.x -= step
    if (event.key === "ArrowRight") normalizedCursor.x += step
    if (event.key === "ArrowUp") normalizedCursor.y -= step
    if (event.key === "ArrowDown") normalizedCursor.y += step
    if (event.key === " ") {
      event.preventDefault()
      stampParcel(trays[state.deliveries % trays.length])
    }

    normalizedCursor.x = clamp(normalizedCursor.x, 0, 1)
    normalizedCursor.y = clamp(normalizedCursor.y, 0, 1)
    field.style.setProperty("--cursor-x", `${normalizedCursor.x * 100}%`)
    field.style.setProperty("--cursor-y", `${normalizedCursor.y * 100}%`)
    field.dataset.awake = "true"
    state.awake = true
  })

  window.addEventListener("resize", resizeCanvas)
  resizeCanvas()
  renderReadouts("unstamped")
  requestAnimationFrame(draw)
</script>
