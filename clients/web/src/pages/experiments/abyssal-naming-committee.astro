---
import Base from "@layouts/Base.astro"
---

<Base>
  <main class="anc-shell">
    <canvas id="abyss-canvas" aria-label="A dim ocean floor surrounding one golden specimen"></canvas>
    <div class="anc-spotlight" aria-hidden="true"></div>
    <div class="anc-vignette" aria-hidden="true"></div>

    <header class="anc-header">
      <p class="anc-kicker">Unscheduled Deep-Sea Review &middot; Dive 08</p>
      <h1>Abyssal Naming Committee</h1>
      <p class="anc-intro">A golden specimen has declined to become more identifiable.</p>
    </header>

    <section class="anc-specimen-zone" aria-label="Golden specimen observation area">
      <div class="anc-orbital-ring" aria-hidden="true"></div>
      <div id="sibling-field" class="anc-sibling-field" aria-hidden="true"></div>
      <div id="golden-specimen" class="anc-specimen" aria-hidden="true">
        <span class="anc-specimen-sheen"></span>
        <span class="anc-specimen-pore pore-one"></span>
        <span class="anc-specimen-pore pore-two"></span>
        <span class="anc-specimen-pore pore-three"></span>
      </div>
      <p class="anc-depth-tag">3,302 m &middot; politely unresolved</p>
    </section>

    <section class="anc-panel anc-readout" aria-live="polite">
      <p class="anc-panel-label">Committee confidence</p>
      <div class="anc-meter" aria-hidden="true"><span id="certainty-bar"></span></div>
      <strong id="certainty-value" class="anc-big-number">92%</strong>
      <div class="anc-rule"></div>
      <p class="anc-panel-label">Inconvenient siblings</p>
      <strong id="sibling-count" class="anc-big-number anc-small-number">0</strong>
    </section>

    <section class="anc-panel anc-actions">
      <p class="anc-panel-label">Provisional taxonomy terminal</p>
      <p id="classification-line" class="anc-classification" aria-live="polite">
        Classification pending. The specimen is maintaining eye contact.
      </p>
      <button id="classify-specimen" type="button">Apply Confident Taxonomy</button>
      <p class="anc-fineprint">Repeated certainty may reveal additional paperwork-shaped life.</p>
    </section>

    <footer class="anc-footer">
      Move through the water to direct the research light.
    </footer>
  </main>
</Base>

<style>
  :global(body) {
    margin: 0;
    background: #020f16;
  }

  .anc-shell {
    --spot-x: 52%;
    --spot-y: 50%;
    position: relative;
    min-height: calc(100vh - 4rem);
    overflow: hidden;
    isolation: isolate;
    color: #e4f4ef;
    background:
      radial-gradient(circle at 50% 78%, rgba(16, 92, 98, 0.42), transparent 34rem),
      linear-gradient(180deg, #031d29 0%, #02151e 47%, #020b10 100%);
    font-family: "Courier New", Courier, monospace;
    touch-action: none;
  }

  #abyss-canvas,
  .anc-spotlight,
  .anc-vignette {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  #abyss-canvas {
    display: block;
  }

  .anc-spotlight {
    z-index: 1;
    background:
      radial-gradient(circle 11rem at var(--spot-x) var(--spot-y), rgba(255, 227, 151, 0.17), transparent 72%),
      radial-gradient(ellipse 26rem 38rem at var(--spot-x) -8%, rgba(133, 231, 224, 0.09), transparent 75%);
    mix-blend-mode: screen;
  }

  .anc-vignette {
    z-index: 5;
    background: radial-gradient(ellipse at center, transparent 44%, rgba(0, 0, 0, 0.66) 100%);
  }

  .anc-header,
  .anc-panel,
  .anc-footer {
    position: absolute;
    z-index: 8;
  }

  .anc-header {
    top: clamp(1rem, 3vw, 2rem);
    left: clamp(1rem, 4vw, 3rem);
    max-width: 34rem;
    text-shadow: 0 0 1rem rgba(0, 0, 0, 0.9);
  }

  .anc-kicker,
  .anc-panel-label,
  .anc-fineprint,
  .anc-depth-tag,
  .anc-footer {
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .anc-kicker {
    margin: 0 0 0.45rem;
    color: #93cbc7;
    font-size: 0.6rem;
  }

  h1 {
    margin: 0;
    color: #f7d87b;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2rem, 6vw, 4.8rem);
    font-weight: 400;
    letter-spacing: -0.05em;
    line-height: 0.92;
    text-shadow: 0 0 1.8rem rgba(227, 177, 69, 0.36);
  }

  .anc-intro {
    max-width: 28rem;
    margin: 0.75rem 0 0;
    color: rgba(228, 244, 239, 0.8);
    font-size: clamp(0.7rem, 1.6vw, 0.86rem);
    line-height: 1.5;
  }

  .anc-specimen-zone {
    position: absolute;
    z-index: 4;
    left: 50%;
    top: 57%;
    width: min(58vw, 34rem);
    aspect-ratio: 1;
    transform: translate(-50%, -50%);
  }

  .anc-orbital-ring {
    position: absolute;
    inset: 9%;
    border: 1px solid rgba(242, 208, 119, 0.21);
    border-radius: 50%;
    box-shadow:
      0 0 0 1.4rem rgba(159, 213, 202, 0.025),
      0 0 0 4.4rem rgba(159, 213, 202, 0.018);
    animation: breathe 5s ease-in-out infinite;
  }

  .anc-specimen {
    position: absolute;
    left: 50%;
    top: 50%;
    width: min(38vw, 13rem);
    aspect-ratio: 1;
    transform: translate(-50%, -50%) scale(var(--orb-scale, 1));
    border-radius: 48% 52% 45% 55% / 52% 43% 57% 48%;
    background:
      radial-gradient(circle at 33% 27%, #fff6bd 0 3%, transparent 16%),
      radial-gradient(circle at 34% 30%, #efd478 0 18%, #b77a28 53%, #563517 100%);
    box-shadow:
      inset -1.3rem -1.2rem 2rem rgba(63, 34, 7, 0.72),
      inset 0.6rem 0.5rem 1rem rgba(255, 242, 168, 0.42),
      0 0 1.2rem rgba(238, 195, 88, 0.7),
      0 0 5rem rgba(200, 161, 63, 0.36);
    transition: transform 0.55s cubic-bezier(0.2, 0.8, 0.2, 1);
    animation: float 4s ease-in-out infinite;
  }

  .anc-specimen-sheen {
    position: absolute;
    inset: 11%;
    border: 1px solid rgba(255, 241, 165, 0.38);
    border-radius: inherit;
    transform: rotate(-18deg);
  }

  .anc-specimen-pore {
    position: absolute;
    width: 9%;
    aspect-ratio: 1;
    border: 1px solid rgba(255, 227, 132, 0.44);
    border-radius: 50%;
    background: #68431c;
    box-shadow: inset 0.15rem 0.15rem 0.25rem rgba(0, 0, 0, 0.66);
  }

  .pore-one { left: 31%; top: 48%; }
  .pore-two { left: 57%; top: 62%; width: 6%; }
  .pore-three { left: 63%; top: 31%; width: 4%; }

  .anc-depth-tag {
    position: absolute;
    bottom: 10%;
    width: 100%;
    margin: 0;
    color: rgba(182, 225, 217, 0.7);
    font-size: 0.56rem;
    text-align: center;
  }

  .anc-sibling {
    position: absolute;
    width: clamp(1.15rem, 4.5vw, 2.7rem);
    aspect-ratio: 1;
    border-radius: 46% 54% 52% 48%;
    background: radial-gradient(circle at 34% 29%, #ffeaa0, #bd7d2a 58%, #523215);
    box-shadow: 0 0 1.2rem rgba(232, 190, 80, 0.68);
    animation: hatch 0.6s ease-out both, float 3.5s ease-in-out infinite 0.6s;
  }

  .anc-panel {
    padding: 0.9rem 1rem;
    border: 1px solid rgba(137, 207, 201, 0.27);
    background: rgba(2, 19, 27, 0.7);
    box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.22);
    backdrop-filter: blur(8px);
  }

  .anc-readout {
    left: clamp(1rem, 4vw, 3rem);
    bottom: clamp(2.4rem, 5vw, 3.4rem);
    width: min(15rem, calc(100% - 2rem));
  }

  .anc-actions {
    right: clamp(1rem, 4vw, 3rem);
    bottom: clamp(2.4rem, 5vw, 3.4rem);
    width: min(23rem, calc(100% - 2rem));
  }

  .anc-panel-label,
  .anc-fineprint {
    margin: 0;
    color: #91cac6;
    font-size: 0.55rem;
    line-height: 1.5;
  }

  .anc-meter {
    height: 0.3rem;
    margin: 0.55rem 0 0.35rem;
    overflow: hidden;
    background: rgba(141, 210, 204, 0.13);
  }

  .anc-meter span {
    display: block;
    width: 92%;
    height: 100%;
    background: linear-gradient(90deg, #73c9c0, #f2ce70);
    box-shadow: 0 0 0.7rem rgba(241, 205, 110, 0.72);
    transition: width 0.45s ease;
  }

  .anc-big-number {
    color: #f6d779;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 2.15rem;
    font-weight: 400;
  }

  .anc-small-number {
    color: #afe0d9;
    font-size: 1.7rem;
  }

  .anc-rule {
    height: 1px;
    margin: 0.65rem 0;
    background: rgba(138, 207, 201, 0.19);
  }

  .anc-classification {
    min-height: 2.8rem;
    margin: 0.55rem 0 0.65rem;
    color: #f8e6ae;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1rem;
    line-height: 1.3;
  }

  #classify-specimen {
    width: 100%;
    border: 1px solid #dcb35b;
    padding: 0.7rem 0.8rem;
    color: #281b0b;
    background: linear-gradient(180deg, #f4db8c, #bd8739);
    cursor: pointer;
    font-family: inherit;
    font-size: 0.63rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition: transform 0.15s ease, filter 0.15s ease;
  }

  #classify-specimen:hover {
    filter: brightness(1.12);
  }

  #classify-specimen:active {
    transform: translateY(2px);
  }

  .anc-fineprint {
    margin-top: 0.7rem;
    color: rgba(145, 202, 198, 0.68);
    font-size: 0.48rem;
  }

  .anc-footer {
    right: 1rem;
    bottom: 0.8rem;
    color: rgba(176, 219, 213, 0.46);
    font-size: 0.48rem;
  }

  .anc-shell.is-classifying .anc-orbital-ring {
    animation: ping 0.65s ease-out;
  }

  @keyframes float {
    0%, 100% { translate: 0 0; }
    50% { translate: 0 -0.65rem; }
  }

  @keyframes breathe {
    0%, 100% { transform: scale(0.97); opacity: 0.45; }
    50% { transform: scale(1.06); opacity: 1; }
  }

  @keyframes hatch {
    0% { transform: scale(0); opacity: 0; }
    75% { transform: scale(1.18); opacity: 1; }
    100% { transform: scale(1); opacity: 1; }
  }

  @keyframes ping {
    0% { transform: scale(0.75); opacity: 1; }
    100% { transform: scale(1.55); opacity: 0; }
  }

  @media (max-width: 720px) {
    .anc-specimen-zone {
      top: 46%;
      width: min(92vw, 30rem);
    }

    .anc-readout {
      left: 0.75rem;
      bottom: 11.4rem;
      width: 8.7rem;
    }

    .anc-actions {
      right: 0.75rem;
      bottom: 1.8rem;
      width: min(22rem, calc(100% - 1.5rem));
    }

    .anc-footer {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .anc-orbital-ring,
    .anc-specimen,
    .anc-sibling {
      animation: none;
    }
  }
</style>

<script>
  const shell = document.querySelector<HTMLElement>(".anc-shell")
  const canvas = document.getElementById("abyss-canvas") as HTMLCanvasElement | null
  const classifyButton = document.getElementById("classify-specimen")
  const classificationLine = document.getElementById("classification-line")
  const certaintyValue = document.getElementById("certainty-value")
  const certaintyBar = document.getElementById("certainty-bar")
  const siblingCount = document.getElementById("sibling-count")
  const siblingField = document.getElementById("sibling-field")
  const specimen = document.getElementById("golden-specimen")

  if (shell && canvas && classifyButton && classificationLine && certaintyValue && certaintyBar && siblingCount && siblingField && specimen) {
    const stage = canvas
    const field = siblingField
    const goldenSpecimen = specimen
    const ctx = stage.getContext("2d")

    if (ctx) {
      const draw = ctx
      const MAX_MOTES = 84
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches
      const classifications = [
        "Probable sponge, pending a formal apology from the sponge community.",
        "Marine ovum with a minor in public relations.",
        "Unlicensed moon, resting.",
        "Decorative organ belonging to a much larger administrative fish.",
        "Committee member. Voting rights unclear.",
        "Gold-adjacent weather system with pores.",
      ]
      const siblingPositions = [
        ["18%", "61%"], ["75%", "53%"], ["30%", "25%"], ["68%", "74%"],
        ["8%", "42%"], ["82%", "30%"], ["43%", "81%"], ["55%", "16%"],
        ["20%", "78%"], ["88%", "63%"], ["5%", "68%"], ["74%", "13%"],
      ]

      let width = 0
      let height = 0
      let dpr = 1
      let certainty = 92
      let siblings = 0
      let classificationIndex = 0
      let flash = 0

      interface Mote {
        x: number
        y: number
        size: number
        speed: number
        drift: number
        alpha: number
      }

      let motes: Mote[] = []

      function makeMote(boost = false): Mote {
        return {
          x: boost ? width * (0.38 + Math.random() * 0.24) : Math.random() * width,
          y: boost ? height * (0.38 + Math.random() * 0.28) : Math.random() * height,
          size: 0.6 + Math.random() * (boost ? 3 : 1.8),
          speed: 0.08 + Math.random() * 0.26,
          drift: -0.16 + Math.random() * 0.32,
          alpha: 0.18 + Math.random() * 0.48,
        }
      }

      function resize() {
        const rect = stage.getBoundingClientRect()
        width = rect.width
        height = rect.height
        dpr = Math.min(window.devicePixelRatio || 1, 2)
        stage.width = Math.floor(width * dpr)
        stage.height = Math.floor(height * dpr)
        draw.setTransform(dpr, 0, 0, dpr, 0, 0)
        motes = Array.from({ length: reduceMotion ? 22 : MAX_MOTES }, () => makeMote())
      }

      function drawSeabed() {
        const floorY = height * 0.79
        const gradient = draw.createLinearGradient(0, floorY - 60, 0, height)
        gradient.addColorStop(0, "rgba(9, 43, 45, 0)")
        gradient.addColorStop(0.32, "rgba(7, 36, 35, 0.74)")
        gradient.addColorStop(1, "rgba(1, 12, 14, 0.96)")
        draw.fillStyle = gradient
        draw.fillRect(0, floorY - 60, width, height - floorY + 60)

        draw.strokeStyle = "rgba(78, 139, 128, 0.2)"
        draw.lineWidth = 1
        for (let x = -20; x < width + 30; x += 32) {
          const stalk = 16 + (x % 70)
          draw.beginPath()
          draw.moveTo(x, floorY + 22)
          draw.quadraticCurveTo(x - 12, floorY - stalk * 0.4, x + 7, floorY - stalk)
          draw.stroke()
        }
      }

      function drawMotes() {
        for (const mote of motes) {
          mote.y -= mote.speed
          mote.x += mote.drift
          if (mote.y < -8 || mote.x < -8 || mote.x > width + 8) {
            Object.assign(mote, makeMote())
            mote.y = height + 5
          }
          draw.beginPath()
          draw.fillStyle = `rgba(168, 225, 210, ${mote.alpha})`
          draw.arc(mote.x, mote.y, mote.size, 0, Math.PI * 2)
          draw.fill()
        }
      }

      function drawFlash() {
        if (flash <= 0) return
        draw.beginPath()
        draw.strokeStyle = `rgba(244, 211, 118, ${flash})`
        draw.lineWidth = 1.5
        draw.arc(width * 0.5, height * 0.55, (1 - flash) * Math.min(width, height) * 0.55, 0, Math.PI * 2)
        draw.stroke()
        flash = Math.max(0, flash - 0.025)
      }

      function animate() {
        draw.clearRect(0, 0, width, height)
        drawSeabed()
        drawMotes()
        drawFlash()
        requestAnimationFrame(animate)
      }

      function addSibling() {
        const position = siblingPositions[siblings % siblingPositions.length]
        const sibling = document.createElement("span")
        sibling.className = "anc-sibling"
        sibling.style.left = position[0]
        sibling.style.top = position[1]
        field.appendChild(sibling)
      }

      classifyButton.addEventListener("click", () => {
        certainty = Math.max(7, certainty - (8 + classificationIndex * 3))
        siblings += 1 + Math.floor(classificationIndex / 2)
        classificationLine.textContent = classifications[classificationIndex % classifications.length]
        certaintyValue.textContent = `${certainty}%`
        certaintyBar.style.width = `${certainty}%`
        siblingCount.textContent = `${siblings}`
        goldenSpecimen.style.setProperty("--orb-scale", `${1 + Math.min(classificationIndex + 1, 5) * 0.045}`)
        addSibling()
        if (siblings > 2) addSibling()
        flash = 0.9
        shell.classList.remove("is-classifying")
        void shell.offsetWidth
        shell.classList.add("is-classifying")
        classificationIndex += 1

        const extraMotes = reduceMotion ? 2 : 12
        for (let index = 0; index < extraMotes && motes.length < MAX_MOTES; index += 1) {
          motes.push(makeMote(true))
        }
      })

      shell.addEventListener("pointermove", (event) => {
        const rect = shell.getBoundingClientRect()
        shell.style.setProperty("--spot-x", `${event.clientX - rect.left}px`)
        shell.style.setProperty("--spot-y", `${event.clientY - rect.top}px`)
      })

      window.addEventListener("resize", resize)
      resize()
      animate()
    }
  }
</script>
