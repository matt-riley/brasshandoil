---
const links = [
  {slug: "experiments", text: "Experiments"},
]

const repoUrl = "https://github.com/matt-riley/brasshandoil"
---

<header class="header glass">
  <a href="/" class="logo-link">
    <h1 class="logo-text text-gradient">Brass Hand Oil</h1>
  </a>
  <nav class="nav-links">
    {links.map(link => (
      <a href={`/${link.slug}`} class="nav-link">
        <h2 class="nav-text">{link.text}</h2>
      </a>
    ))}
    <a
      href={repoUrl}
      class="nav-link nav-icon-link"
      target="_blank"
      rel="noreferrer"
      aria-label="GitHub"
    >
      <svg
        class="nav-icon"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.28-.01-1.2-.02-2.18-3.2.7-3.88-1.36-3.88-1.36-.52-1.32-1.28-1.67-1.28-1.67-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.69 1.25 3.35.96.1-.75.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.28 1.19-3.08-.12-.29-.52-1.46.11-3.04 0 0 .97-.31 3.19 1.18a11.1 11.1 0 0 1 5.81 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.58.23 2.75.11 3.04.74.8 1.19 1.82 1.19 3.08 0 4.43-2.69 5.41-5.25 5.69.41.35.77 1.04.77 2.1 0 1.52-.01 2.74-.01 3.11 0 .31.21.68.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z" />
      </svg>
    </a>
  </nav>
</header>
